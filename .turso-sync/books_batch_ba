INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('08e60201-8ef2-4ad8-a4c5-5aa325848c00', 'Made To Order', 'A cutting-edge anthology, published on the 100th anniversary of the word “Robot”, exploring the possibilities and place of robots in society going forwards.

100 years after Karel Capek coined the word, “robots” are an everyday idea, and the inspiration for countless stories in books, film, TV and games.

They are often among the least privileged, most unfairly used of us, and the more robots are like humans, the more interesting they become. This collection of stories is where robots stand in for us, where both we and they are disadvantaged, and where hope and optimism shines through.

Including stories by: Brooke Bolander · John Chu · Daryl Gregory · Peter F. Hamilton · Saad Z. Hossain · Rich Larson · Ken Liu · Ian R. Macleod · Annalee Newitz · Tochi Onyebuchi · Suzanne Palmer · Sarah Pinsker · Vina Jie-Min Prasad · Alastair Reynolds · Sofia Samatar · Peter Watts', 'A dark sci-fi tale exploring robots, revolution, and the burden of student loans.', 2020, '1781087873', '9781781087879', 400, NULL, NULL, 'https://covers.openlibrary.org/b/id/10084515-L.jpg', '/works/OL20791355W', NULL, '2020-03-17', 'English', NULL, 1, 0, 'made-to-order-ken-liu', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:50:42', '2026-03-22 03:10:04');
