INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('02a9f3f5-9244-42c5-90d2-0d872a30e38b', 'Fake Skating', 'Growing up, Dani couldn’t help but follow around the adorable son of her mom’s best friend. Funny, kind of nerdy, and a little soft, Alec was always down to hang with Dani when they were little. From play dates on the playground to sneaking into movie theaters, Dani and Alec were inseparable. Until Dani moved away. Alec promised they’d stay in touch—except, they didn’t.

