INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('246fef27-9fc6-4636-b032-3b08f1f3361d', 'Anxious People', 'It''s New Year''s Eve and House Tricks estate agents are hosting an open viewing in an up-market apartment when an incompetent bank robber rushes in and politely takes everyone hostage.

For Anna-Lena and Roger, busy buying-up apartments to fill the hole in their marriage, it''s something else to talk about.

For Julia and Ro, panicky parents-to-be, it''s yet another worry.

Lonely bank manager Zara only came here for the view.

While 87-year-old grandmother Estelle seems rather pleased by the company . . .

As the police gather outside, the anxious strangers huddled within try to make the best of a very sticky situation - but could it be that they have a whole lot more in common than meets the eye?', 'A failed bank robbery spirals into an absurd hostage situation at an apartment open house, trapping a group of anxious strangers who uncover surprising connections.', 2020, '1982121602', '9780718186616', 352, NULL, 593, 'https://covers.openlibrary.org/b/id/10087939-L.jpg', '/works/OL20793817W', NULL, '2020', 'English', NULL, 1, 0, 'anxious-people-fredrik-backman', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:45:42', '2026-03-22 20:32:05');
