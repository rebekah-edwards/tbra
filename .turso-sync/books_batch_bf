INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4167c409-64a0-49a1-bef6-0fbc4c5cd3c8', 'Bad Thoughts', 'Your thoughts don''t have to control you. You can control your thoughts--if you know how. And that''s exactly what Judah Smith (New York Times bestselling author and popular pastor) and Les Parrott (New York Times bestselling author and trusted psychologist) will teach you.', 'A pastor and a psychologist team up to help readers overcome negative thoughts with faith and science.', NULL, NULL, '9780310370635', 363, NULL, NULL, NULL, '/works/OL42401261W', NULL, '2025', 'English', NULL, 0, 0, 'bad-thoughts-judah-smith', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:44:13', '2026-03-22 03:46:45');
