INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6e7a25b5-3cf6-412f-808b-2986ae7beeb9', 'Walking on Water', 'In this classic book, Madeleine L’Engle addresses the questions, What makes art Christian? What does it mean to be a Christian artist? What is the relationship between faith and art? Through L’Engle’s beautiful and insightful essay, readers will find themselves called to what the author views as the prime tasks of an artist: to listen, to remain aware, and to respond to creation through one’s own art.', 'Madeleine L''Engle explores the deep connection between faith and art in this reflective essay collection, inspiring Christian artists.', 1995, NULL, NULL, 208, NULL, NULL, 'https://books.google.com/books/content?id=5zHZCwAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL43236094W', NULL, '1995', 'English', NULL, 0, 0, 'walking-on-water-madeleine-lengle', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-18 18:40:24', '2026-03-22 04:16:36');
