INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('71856379-81b8-4aaf-a005-daec201f007d', 'Emily Wilde''s Compendium of Lost Tales', 'Emily Wilde has spent her life studying faeries. A renowned dryadologist, she has documented hundreds of species of Folk in her Encyclopaedia of Faeries. Now she is about to embark on her most dangerous academic project studying the inner workings of a faerie realm—as its queen. Along with her former academic rival—now fiancé—the dashing and mercurial Wendell Bambleby, Emily is immediately thrust into the deadly intrigues of Faerie as the two of them seize the throne of Wendell’s long-lost kingdom, which Emily finds a beautiful nightmare filled with scholarly treasures.', 'A curmudgeonly folklore scholar and her fae prince lover unravel mysteries in a magical, melancholic finale to the Emily Wilde series.', NULL, NULL, '9780593500224', NULL, NULL, 704, 'https://books.google.com/books/content?id=EOoCEQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', NULL, NULL, NULL, 'English', NULL, 1, 1, 'emily-wildes-compendium-of-lost-tales-heather-fawcett', 1, 'google_books', NULL, 0, NULL, 'import_only', '2026-03-18 19:46:10', '2026-03-25 00:23:59');
