INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('99fda2bc-6ac1-46e2-909b-aeb037c4f9f4', 'Worried About Everything Because I Pray About Nothing', 'Or maybe just a boring duty with little payoff. In this book, author and pastor Chad Veach demystifies the concept of prayer by explaining in practical terms what prayer looks like in our day-to-day lives. This passionate, personal approach to prayer removes the pressure to ''pray right'' and replaces it with the calm assurance that God wants to hear from us and respond to us in love. Along with building a case for the importance of prayer, Chad uses stories and compelling insights from the Bible to give practical advice for how to make your prayers more effective.', 'A practical guide to prayer, helping readers find peace and purpose over stress. Chad Veach demystifies prayer with biblical insights.', 2022, NULL, '9780764240188', 240, NULL, 525, 'https://covers.openlibrary.org/b/id/13303983-L.jpg', '/works/OL26628056W', NULL, '2022', 'English', NULL, 0, 0, 'worried-about-everything-because-i-pray-about-nothing-chad-veach', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:44:10', '2026-03-22 04:45:29');
