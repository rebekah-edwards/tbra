INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f3561b22-61ff-48f7-ba11-026d56bc16f3', 'A Ring of Endless Light', 'After a tumultuous year in New York City, the Austins are spending the summer on the small island where their grandfather lives. He’s very sick, and watching his condition deteriorate as the summer passes is almost more than Vicky can bear. To complicate matters, she finds herself as the center of attention for three very different boys.

Zachary Grey, the troubled and reckless boy Vicky met last summer, wants her all to himself as he grieves the loss of his mother. Leo Rodney has been just a friend for years, but the tragic loss of his father causes him to turn to Vicky for comfort—and romance. And then there’s Adam Eddington. Adam is only asking Vicky to help with his research on dolphins. But Adam—and the dolphins—may just be what Vicky needs to get through this heartbreaking summer.', 'Vicky Austin spends a heartbreaking summer on an island, grappling with her grandfather''s illness and finding solace with dolphins.', 1980, '0440972329', '9780745913834', 328, NULL, NULL, 'https://covers.openlibrary.org/b/id/224078-L.jpg', '/works/OL41481W', NULL, '1988', 'English', NULL, 1, 0, 'a-ring-of-endless-light-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 18:48:15', '2026-03-23 04:32:19');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f9dc5dc8-3ee3-4931-9f99-1b76537a8630', 'The Twenty-Four Days Before Christmas', '*An Austin Family Story*
Vicky Austin''s family does one special thing each day of December to prepare for Christmas. This year, they''re also preparing for the birth of a new brother or sister, due after the New Year. Vicky is worried that the baby will come early—what kind of Christmas Eve would it be without Mother to help them hang up stockings and sing everyone to sleep with carols?', 'Vicky Austin, age 7, prepares for Christmas with daily family traditions while worrying about her mother''s pregnancy. A heartwarming children''s holiday story.', 1964, '0374380058', '9781429945646', 56, NULL, NULL, 'https://covers.openlibrary.org/b/id/672145-L.jpg', '/works/OL41480W', NULL, '2011', 'English', NULL, 1, 0, 'the-twentyfour-days-before-christmas-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 18:48:17', '2026-03-23 04:36:43');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('79fe617d-dbca-4911-96d4-52c0ee8b34d9', 'The Genesis Trilogy', 'The Genesis Trilogy has long been awaited by fans of Madeleine L''Engle, who have expressed a desire to have all three of the authors books on Genesis in one volume. In addition to L''Engle''s vast reader base, The Genesis Trilogy will be embraced by the literary community (which deeply respects L''Engle''s award-winning work) and all those who seek to experience more fully the truths represented in Genesis. Book 1 of the trilogy, And It Was Good, speaks especially to those captivated by the creation story and those interested in new beginnings, while Book 2, A Stone for a Pillow, holds treasure for those seeking answers to the questions posed during their inner and outer journeys. Book 3, Sold into Egypt, provides hope to those who have experienced grief and loss.', 'A spiritual trilogy by Madeleine L''Engle exploring Genesis, offering insights on creation, journeys, and loss with a focus on biblical relevance.', 1997, '0877882916', '9780877882916', 635, NULL, NULL, 'https://covers.openlibrary.org/b/id/671944-L.jpg', '/works/OL41454W', NULL, '2001', 'English', NULL, 0, 1, 'the-genesis-trilogy-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-18 18:49:10', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('66955fa8-663f-4e42-a33d-2dc4bf2158e7', 'Prelude', '*Note: this book is an excerpt of L''Engle''s first book The Small Rain, and was reissued for teenagers (the original is an adult novel).*

The author "tells the story of Katherine Forrester, an imaginative and intensely creative young American girl who yearns to become a concert pianist, as was her mother. As she learns how to accept the conflicts of her unorthodox home life and then her fellow students in a boarding school in Switzerland, we follow Katherine through all the torment, loneliness, and adorations and passions of a fifteen-year-old girl as she tries to realize her ambitions in the tumultuous world of the arts and make her own way to maturity.', 'Katherine Forrester, a young pianist, navigates loneliness and passion at a Swiss boarding school, striving for maturity in the arts.', 1968, '0575005130', '9780575005136', 189, NULL, NULL, 'https://covers.openlibrary.org/b/id/8036089-L.jpg', '/works/OL41468W', NULL, '1970', 'English', NULL, 1, 0, 'prelude-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 18:50:30', '2026-03-22 04:11:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b34bba88-da51-496e-86d8-61404870b152', 'The Arm of the Starfish', 'When Adam Eddington, a gifted marine biology student, makes the acquaintance of blond and beautiful Kali Cutter at Kennedy International Airport on his way to Portugal to spend the summer working for the renowned scientist Dr. O''Keefe, he has no idea that this seemingly chance meeting will set into motion a chain of events he will be unable to stop. Caught between Kali''s seductive wiles and the trusting adoration of Dr. O''Keefe''s daughter, Poly, Adam finds himself enmeshed in a deadly power struggle between two groups of people, only one of which can have right on its side. As the danger escalates, Adam must make a decision that could affect the entire world--which side is he on?', 'A young marine biology student is caught in a deadly power struggle while working for a renowned scientist in Portugal. A thrilling tale of trust and betrayal.', 1965, '0606002901', '9780440913009', 243, NULL, NULL, 'https://covers.openlibrary.org/b/id/10113798-L.jpg', '/works/OL41477W', NULL, '1980', 'English', NULL, 1, 0, 'the-arm-of-the-starfish-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 18:52:11', '2026-03-22 05:03:36');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0c2ef2b0-6fab-49f0-a195-982c90cbfaff', 'A House Like a Lotus', 'Sixteen-year-old Polly is on her way to the island of Cyprus, where she will work as a gofer. The trip was arranged by Maximiliana Horne, a rich, brilliant artist who, with her longtime companion, Dr. Ursula Heschel, recently became the O’Keefe family’s neighbor on Benne Seed Island. Max and Polly formed an instant friendship and Max took over Polly’s education, giving her the encouragement and confidence that her isolated upbringing had not. Polly adored Max, even idolized her, until Max betrayed her. In Greece, Polly finds romance, danger, and unique friendships. But can she ever forgive Max?', 'Sixteen-year-old Polly navigates friendship, betrayal, and romance while working in Cyprus.', 1984, '0808566172', '9781466814134', 307, NULL, NULL, 'https://covers.openlibrary.org/b/id/223891-L.jpg', '/works/OL41483W', NULL, '2012', 'English', NULL, 1, 0, 'a-house-like-a-lotus-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 18:52:12', '2026-03-22 03:12:11');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('39066f37-0ad2-4708-9ef4-66445a9ec725', 'A Live Coal in the Sea', 'When Dr. Camilla Dickinson''s teenage granddaughter confronts her with the disquieting question of whether Camilla is, in fact, her grandmother, long-kept secrets rise to the surface to test the faith, love and loyalty of the Xanthakos family. This skillful, gripping tale shuttles between past and troubled present, providing clues to a multigenerational mystery -- clues that begin to focus on Camilla''s son, the deeply troubled TV idol Artaxias, and on Camilla''s mother, the irresistibly beautiful and adulterous Rose. Though riveting and psychologically complex, A Live Coal in the Sea is "infused with the warmth of love and mercy" (*Booklist*), showcasing the keen eye and deep compassion that have made L''Engle one of this century''s premier writers on faith and its place in human experience.', 'Dr. Camilla Dickinson faces family secrets and a multigenerational mystery, testing faith and love in a psychologically complex tale.', 1996, '0374189897', '9781504041560', 323, NULL, NULL, 'https://covers.openlibrary.org/b/id/223158-L.jpg', '/works/OL14949905W', NULL, '2017', 'English', NULL, 1, 0, 'a-live-coal-in-the-sea-madeleine-lengle', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 18:53:13', '2026-03-22 03:41:53');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9804be0f-8951-435e-a3bc-7a7becaddcf7', 'Frigid', 'For twenty-one-year-old Sydney, being in love with Kyler isn''t anything new. They''d been best friends ever since he pushed her down on the playground and she made him eat a mud pie. Somewhere over the years, she fell for him and fell hard. The big problem with that? Kyler puts the ''man'' in man-whore. He''s never stayed with a girl longer than a few nights, and with it being their last year in college, Syd doesn''t want to risk their friendship by declaring her love. Kyler has always put Syd on a pedestal that was too high for him to reach. To him, she''s perfect and she''s everything. But the feelings he has for her, he''s always hidden away or focused on any other female. After all, Kyler will always be the poor boy from the wrong side of tracks, and Syd will always be the one girl he can never have. But when they''re stranded together at a posh ski resort due to a massive Nor''easter, there''s nothing stopping their red-hot feelings for each other from coming to the surface. Can their friendship survive the attraction? Better yet, can they survive at all? Because as the snow falls, someone is stalking them, and this ski trip may be a life-changer in more ways than one.', 'A steamy friends-to-lovers romance with suspense, as Sydney and Kyler confront hidden feelings during a snowbound ski trip.', 2013, '8417312161', '9788417312169', 260, NULL, 571, 'https://covers.openlibrary.org/b/id/9250847-L.jpg', '/works/OL20637052W', NULL, '2018', 'English', NULL, 1, 0, 'frigid-j-lynn', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 19:16:26', '2026-03-22 04:43:55');
