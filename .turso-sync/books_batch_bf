INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6f5ea93b-8656-48ae-a47d-3ad093d0f74b', 'Ethics', 'From one of the most important theologians of the twentieth century, Ethics is the seminal reinterpretation of the role of Christianity in the modern, secularized world. The Christian does not live in a vacuum, says the author, but in a world of government, politics, labor, and marriage. Hence, Christian ethics cannot exist in a vacuum; what the Christian needs, claims Dietrich Bonhoeffer, is concrete instruction in a concrete situation.', 'A profound exploration of Christian ethics by Dietrich Bonhoeffer, addressing morality in a complex world.', 1970, NULL, NULL, NULL, NULL, NULL, 'https://books.google.com/books/content?id=djM15pn4yOsC&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL31698028W', NULL, '1970-01-01', 'English', NULL, 0, 0, 'ethics-dietrich-bonhoeffer', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:06', '2026-03-22 04:17:14');
