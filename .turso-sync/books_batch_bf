INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1bb7210c-77b3-474f-91cd-66a95242af84', 'Can''t Live with ''Em, Can''t Live Without ''Em', 'Living in a love-hate relationship-with your spouse, kids, parents, friends, co-workers, and even God-can leave you feeling confused and furious. But the practical strategies presented in this book will help you overcome your most agonizing relational predicaments. Drawing on a wealth of experience as therapists and as best-selling authors, David Stoop and Stephen Arterburn provide you with: Insightful analysis of the "problem behind the problem behind the problem" in love-hate relationships; Hands-on questionnaires and exercises to help you sort out your mixed-up feelings; Real-life case studies that show how you can protect yourself from abuse without cutting yourself off from people you care about; Professional advice to help you work through your bitterness and disappointment and manage the healing act of forgiveness.', 'A guide to navigating love-hate relationships with practical strategies for healing and forgiveness.', 2006, NULL, '9781418553654', 160, NULL, NULL, 'https://books.google.com/books/content?id=6xBs-e0mVR0C&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL25371004W', NULL, '2006', 'English', NULL, 0, 0, 'cant-live-with-em-cant-live-without-em-stephen-arterburn', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:03', '2026-03-22 03:22:08');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e9c47667-e97f-4604-945e-b2361237c8ce', 'Fiction from Tegel Prison', 'Writing fiction, letters to his family, fiancée, and friends and contending with his interrogator occupied Bonhoeffer during his first year in Tegel Prison. Of the incomplete drama, the novel fragment, and the short story, Bonhoeffer admitted to his friend and later biographer, Eberhard Bethge, ''There is a good deal of autobiography mixed with it.'' This book discloses a great deal of Bonhoeffer’s family context, social world, and cultural milieu. Events from his life are recounted in a way that embodies and illuminates his theology. Characters and situations that represent Nazi types and attitudes are a form of social criticism and help to explain Bonhoeffer''s participation in the resistance.', 'Dietrich Bonhoeffer''s fiction from Tegel Prison, blending autobiography and theology, explores family, society, and resistance during Nazi Germany.', 2010, NULL, '9781451406764', NULL, NULL, NULL, 'https://books.google.com/books/content?id=W9Jum8TfB3wC&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL32477650W', NULL, '2010', 'English', NULL, 1, 0, 'fiction-from-tegel-prison-dietrich-bonhoeffer', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:03', '2026-03-23 04:26:04');
