INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('92d4919f-61ab-42e8-b999-7d30debf5cbc', 'Red Leaves', 'Then, on an ordinary night, his teenage son Keith is asked to babysit Amy Giordano, the eight-year-old daughter of a neighboring family. The next morning Amy is missing. Suddenly Eric is one of the stricken parents he has seen on television, professing faith in his child''s innocence.', 'A suspenseful mystery about a missing girl and a family torn by suspicion and broken trust.', 2006, '0156032341', '9780156032346', 300, NULL, 463, 'https://covers.openlibrary.org/b/id/115910-L.jpg', '/works/OL15105764W', NULL, 'June 5, 2006', 'English', NULL, 1, 0, 'red-leaves-thomas-h-cook', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-18 19:47:29', '2026-03-22 04:40:47');
