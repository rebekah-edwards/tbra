INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5b1e1b38-9543-4477-b59a-86cd700e36c0', 'The Cost of Discipleship', 'What can the call to discipleship, the adherence to the word of Jesus, mean today to the businessman, the soldier, the laborer, or the aristocrat? What did Jesus mean to say to us? What is his will for us today? Drawing on the Sermon on the Mount, Dietrich Bonhoeffer answers these timeless questions by providing a seminal reading of the dichotomy between "cheap grace" and "costly grace."', 'A profound theological exploration of Christian discipleship, challenging readers with the concept of costly grace over cheap grace.', 1959, NULL, NULL, 294, NULL, 540, 'https://books.google.com/books/content?id=GW14EQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL31597598W', NULL, '1960-01-01', 'English', NULL, 0, 0, 'the-cost-of-discipleship-dietrich-bonhoeffer', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:10', '2026-03-22 04:03:55');
