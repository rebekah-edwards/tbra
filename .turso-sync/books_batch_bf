INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e6195047-fb73-4fa6-891e-778228e668f1', 'Made to Crave', 'Made to Crave is the missing link between a woman’s desire to be healthy and the spiritual empowerment necessary to make that happen. Filled with Biblical truth, gut-honest vulnerability, and refreshing wit, Lysa TerKeurst''s words will help you find redemption in every part of your story. Break the cycle of “I’ll start again Monday” and feel good about yourself today. Stop agonizing over numbers on the scale and make peace with your body. Replace rationalizations that lead to failure with wisdom that leads to victory. Reach your healthy goals and grow closer to God through the process.', 'A Christian guide linking healthy eating to spiritual growth, focusing on craving God over food.', 2010, '031029326X', '9780310293262', 224, NULL, 3000, 'https://covers.openlibrary.org/b/id/6677273-L.jpg', '/works/OL15623250W', NULL, '2011', 'English', NULL, 0, 0, 'made-to-crave-lysa-terkeurst', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-18 19:51:30', '2026-03-23 04:23:24');
