INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('11a887c6-c1e4-4cfa-b589-ac6cd84b7580', 'The Last Ronin', 'In a future, battle-ravaged New York City, a lone surviving Turtle embarks on a seemingly hopeless mission seeking justice for the family he lost. From the shadows of an authoritarian cityscape, the last of the Teenage Mutant Ninja Turtles searches for answers about the tragedy that destroyed his brothers. Can the surviving Turtle triumph? Eastman and Laird are joined by writer Tom Waltz, who penned the first 100 issues of IDW''s ongoing TMNT series, and artists Esau & Isaac Escorza (Heavy Metal) and Ben Bishop (The Far Side of the Moon) with an Introduction by filmmaker Robert Rodriguez!', 'A dark, dystopian Teenage Mutant Ninja Turtles tale of loss and revenge as the last surviving Turtle battles in a grim future.', 2023, NULL, '9798887240541', NULL, NULL, 480, 'https://covers.openlibrary.org/b/id/14619633-L.jpg', '/works/OL38056274W', NULL, '2023', 'English', NULL, 1, 0, 'the-last-ronin-tom-waltz', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:46', '2026-03-22 03:15:42');
