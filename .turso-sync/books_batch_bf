INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('81c829e1-9395-4a52-b26b-487d06e5882b', 'Road to 100', 'The landmark 100th issue of Teenage Mutant Ninja Turtles gets the celebration it deserves in this special hardcover edition. Concluding the epic ''City At War'' storyline, issue #100 brings nearly eight years of action-packed continuity by TMNT co-creater Kevin Eastman and series co-writer Tom Waltz to its dramatic finale. Featuring art by Dan Duncan, Dave Wachter, Sophie Campbell, Mateus Santolouco, and more. But that''s not all. In addition to the landmark issue, join TMNT scholar Patrick Ehlers for a review of the road to 100 issues through an in-depth look at everything that came before. This authoritative study of IDW''s TMNT continuity is the perfect companion for such a notable comic book milestone, bringing the story into sharp focus for new fans or readers that have been there since the start.', 'Celebrating the 100th issue of Teenage Mutant Ninja Turtles, this deluxe edition concludes the epic ''City At War'' storyline with action-packed drama.', 2020, NULL, '9781684057023', 120, NULL, NULL, 'https://covers.openlibrary.org/b/id/14619640-L.jpg', '/works/OL38056282W', NULL, '2020', 'English', NULL, 1, 0, 'road-to-100-tom-waltz', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:50', '2026-03-22 04:29:25');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('72e75ec3-15f8-4ef9-8379-f0c4734769ea', '100 Days of Healing', 'Experience the freedom and joy of God’s healing and promises in this daily devotional! Have you ever felt the ache of grief? The pang of disappointments or even the sting of betrayal? These feelings do not need to be your new normal. When life leaves us feeling raw and wounded, it’s easy to become disillusioned and disappointed, but if we stay open to God’s promises, we can grow stronger in our faith and relationship with the Lord through the trials. Enjoy Having a Short Daily Devotional on Healing and Peace from Stephen Arterburn. Begin a 100-day journey toward healing with this daily devotional.', 'A 100-day devotional journey toward healing with daily readings on faith and peace from Stephen Arterburn.', 2021, NULL, '9781496464545', NULL, NULL, NULL, NULL, '/works/OL26601179W', NULL, '2021', 'English', NULL, 0, 0, '100-days-of-healing-stephen-arterburn', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:45:50', '2026-03-22 04:19:20');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c028f54d-cd07-4501-a117-98b980c2da07', 'Meditating on the Word', 'Daily, quiet reflection on the Word of God as it applies to me becomes for me a point of crystallization for everything that gives interior and exterior order to my life, wrote Dietrich Bonhoeffer to his colleagues at the warfront in the winter of 1942. Now back in print after a decade, this collection of Bonhoeffer''s writings, sermons, and letters on meditation—including his unfinished meditation on Psalm 119—reveals his deep love for the Bible as a focus for his prayer life and a support in his courageous political life.', 'A collection of Dietrich Bonhoeffer''s sermons and meditations on scripture, guiding readers on biblical reflection.', 1990, '034535964X', '9780345359643', 146, NULL, NULL, 'https://covers.openlibrary.org/b/id/14495694-L.jpg', '/works/OL34602713W', NULL, '1990-01-01', 'English', NULL, 0, 0, 'meditating-on-the-word-dietrich-bonhoeffer', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:51', '2026-03-22 05:11:35');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f8667662-6a3c-4e36-9bf2-b50b16fe7945', 'The Armageddon Game--Opening Moves', 'But, before the game can truly begin, discover the histories of the Rat King, Kitsune, and the rest of the Pantheon, witness their previous encounters with the TMNT, and understand their connection to the recently resurrected Shredder. Collects TMNT: The Armageddon Game Pre-Game stories "Kingdom of Rats Prelude," Teenage Mutant Ninja Turtles #84, and the 2020 and 2021 TMNT Annuals, as well as TMNT: The Armageddon Game—Opening Moves #1 and 2.', 'The TMNT face a demi-god''s schemes in a high-stakes game, uncovering past rivalries and dark histories.', 2023, NULL, '9781684059737', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14619635-L.jpg', '/works/OL38056277W', NULL, '2023', 'English', NULL, 1, 0, 'the-armageddon-gameopening-moves-tom-waltz', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:51', '2026-03-23 04:35:48');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('17c38898-8ae7-46a6-b92d-5699e89abd3f', 'Act and Being', 'Act and Being, written in 1929-1930 as Bonhoeffer''s second dissertation, deals with the questions of consciousness and conscience in theology from the perspective of the Reformation insight about the origin of human sinfulness in the ''heart turned in upon itself and thus open neither to the revelation of God nor to the encounter with the neighbor.'' Here, therefore, we find Bonhoeffer''s thoughts about power, revelation, Otherness, theological method, and theological anthropology.', 'A theological exploration of consciousness and conscience from a Reformation perspective.', 1961, NULL, NULL, 66, NULL, NULL, 'https://covers.openlibrary.org/b/id/14863665-L.jpg', '/works/OL34590290W', NULL, '1962-01-01', 'English', NULL, 0, 0, 'act-and-being-dietrich-bonhoeffer', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:53', '2026-03-22 03:19:41');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('17b614ac-f601-460e-9865-ad101a7de80c', 'Jennika--The Fifth Turtle', 'The newest member of the TMNT team, Jennika, embarks on her own adventures in these standalone stories! First, relive the events that led up to Jennika''s mutation into a Turtle. Then, as she tries to acclimate to life as a mutant, she must come to terms with both her troubled past and conflicted present. Mutants begin turning into monsters and spreading fear in Mutant Town. Jennika takes to the underworld to get to the bottom of the situation, but enemies old and new await! Delving deeper into the mystery forces her to work with a former enemy and reveals that the threat is more complicated and dangerous than she thought!', 'Jennika, the newest TMNT member, navigates her mutation and solo adventures in a dangerous underworld.', 2024, NULL, '9798887241265', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14619631-L.jpg', '/works/OL38056273W', NULL, '2024', 'English', NULL, 1, 0, 'jennikathe-fifth-turtle-tom-waltz', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:53', '2026-03-22 03:19:40');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3726c376-5afa-4574-9ee9-d9c881de6769', 'NLT the One Year Bible for Men', 'Read through the Bible in one year in as little as 15 minutes a day. The One Year Bible for Men combines the bestselling daily Bible reading format with encouraging two-minute daily devotionals written just for men to create a one-of-a-kind devotional Bible that men of all ages will love.', 'A devotional Bible for men with daily readings and reflections to read the entire Bible in one year.', 2022, NULL, '9781496449504', NULL, NULL, NULL, NULL, '/works/OL28845585W', NULL, '2022', 'English', NULL, 0, 0, 'nlt-the-one-year-bible-for-men-stephen-arterburn', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:45:53', '2026-03-22 03:40:23');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('981d229a-4562-40eb-b8b8-f24ee9023ad6', 'Sanctorum Communio', 'Sanctorum Communio was Dietrich Bonhoeffer''s dissertation, completed in 1927 and first published in 1930. In it he attempts to work out a theology of the person in society, and then, particularly, in the church.', 'A theological study of the church as a social community, exploring the nature of personal and collective faith.', 1963, NULL, NULL, 262, NULL, NULL, 'https://covers.openlibrary.org/b/id/15056766-L.jpg', '/works/OL34569045W', NULL, '1963-01-01', 'English', NULL, 0, 0, 'sanctorum-communio-dietrich-bonhoeffer', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:54', '2026-03-22 04:44:01');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1ae2b6ca-d7a8-4186-a9a9-e6f99ffac869', 'The Armageddon Game', 'Written by longtime TMNT scribe Tom Waltz (The Last Ronin) and illustrated by artist Vincenzo Federici (Jennifer Blood, Red Sonja), the time has come at last to find out who is playing…and who is being played! Collects all eight issues of Teenage Mutant Ninja Turtles: The Armageddon Game.', 'The Teenage Mutant Ninja Turtles face the Rat King in a high-stakes battle for Earth in this epic crossover event.', 2024, NULL, '9798887241609', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14619630-L.jpg', '/works/OL38056271W', NULL, '2024', 'English', NULL, 1, 0, 'the-armageddon-game-tom-waltz', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:54', '2026-03-22 03:21:51');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8c71c9cf-6242-48bf-8b61-bde8cac681a5', 'One Year Devotions for Women on the Go', 'Designed to encourage readers to spend time reading and meditating on the truth of God''s Word, these brief devotions, based solidly in Scripture, are ideal for reading over morning coffee, waiting in the car for children after school, or anytime people ''on the go'' want to make the most of just a few minutes.', 'Daily devotions for busy women, offering spiritual encouragement through Scripture and prayer.', 2013, NULL, '9781414386560', NULL, NULL, NULL, NULL, '/works/OL25116544W', NULL, '2013', 'English', NULL, 0, 0, 'one-year-devotions-for-women-on-the-go-stephen-arterburn', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:45:55', '2026-03-22 04:36:36');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('541a1fea-9283-4437-9431-1b72b625512c', 'Life Together and Prayerbook of the Bible', 'The treatise contains Bonhoeffer''s thoughts about the nature of Christian community based on the common life that he and his seminarians experienced at the seminary and in the ''Brother''s House'' there. Bonhoeffer completed the writing of Life Together in 1938. Prayerbook of the Bible is a classic of Christian spirituality. In this theological interpretation of the Psalms, Bonhoeffer describes the moods of an individual''s relationship with God and also the turns of love and heartbreak, of joy and sorrow, that are themselves the Christian community''s path to God.', 'A profound exploration of Christian community and spirituality through Bonhoeffer''s experiences and theological insights on the Psalms.', 2004, NULL, '9781451410389', NULL, NULL, NULL, NULL, '/works/OL34350170W', NULL, '2004', 'English', NULL, 0, 0, 'life-together-and-prayerbook-of-the-bible-dietrich-bonhoeffer', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:45:55', '2026-03-22 03:59:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('27acaae2-13a4-4947-8400-0b4986b8fe4c', 'CSB Restoration Bible, Trade Paper', 'We all face difficulties in life. The death of a loved one, financial problems, divorce, health issues, job loss . . . the list can go on and on. In the midst of these difficult seasons of life there is hope. The CSB Life Restoration Bible features relevant and applicable notes and helps focus on life recovery in an easy-to-follow format to help individuals find hope and joy within the Bible as they embrace the truths and promises found in God’s Word during difficult seasons of life. The key helps in this Bible include over 500 guided notes following seven Life Restoration Principles via the easy-to-remember R.E.S.T.O.R.E acrostic (Rest and Reflect–Eternal Perspective–Support–Thanksgiving and Contentment–Other-centeredness–Relationships–Exercise of Faith).', 'A Bible edition with notes on life restoration, offering hope during difficult seasons.', 2018, '1462796907', '9781462796908', 1696, NULL, NULL, 'https://covers.openlibrary.org/b/id/11506257-L.jpg', '/works/OL24758345W', NULL, 'Dec 01, 2018', 'English', NULL, 0, 0, 'csb-restoration-bible-trade-paper-stephen-arterburn', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:45:56', '2026-03-22 03:30:03');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5763d0eb-434a-42da-a2f3-6cd5fef3a99c', 'Life Together - New Edition', 'This short book is a reflection on life as an intentional Christian community, written by Bonhoeffer during his time as a head of the Illegal Seminary of the Confessing Church in Finkenwalde (Eastern Prussia).', 'A reflective exploration of Christian community life by Dietrich Bonhoeffer, written during his time leading an illegal seminary.', 2015, NULL, '9780334049760', NULL, NULL, NULL, NULL, '/works/OL34330070W', NULL, '2015', 'English', NULL, 0, 0, 'life-together-new-edition-dietrich-bonhoeffer', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:45:57', '2026-03-22 04:01:38');
