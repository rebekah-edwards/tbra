INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('33b0cba8-a7af-4617-94f5-e31a4553c34c', '24 Days Before Christmas', 'The Austin family has a cherished tradition of doing something special every day counting down to Christmas - from baking cookies to decorating the tree. This year is a stressful one for Vicky Austin as she''s cast as the youngest angel in the Christmas Pageant.', 'A heartwarming holiday tale of the Austin family’s Christmas traditions and Vicky’s role as an angel in a pageant.', 2019, NULL, '9798890990938', NULL, NULL, NULL, 'https://books.google.com/books/content?id=DfBqEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL36724405W', NULL, '2019', 'English', NULL, 1, 0, '24-days-before-christmas-madeleine-lengle', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-18 18:40:46', '2026-03-22 03:38:11');
