INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a4719849-7cb9-4c89-a3d6-a4bcef14abdb', 'The Invasion', 'Sometimes weird things happen to people. Ask Jake. He may tell you about the night he and his friends saw the strange light in the sky. He may even tell you about what happened when they realized the "light" was only a plane -- from another planet.

Here''s where Jake''s story gets a little weird. He and his friends are told the human race is under attack, but they''re given the chance to fight back.

Now Jake, Rachel, Cassie, Tobias and Marco have the power to morph into any animal they choose. And they must use that power to outsmart an evil that is greater than anything the world has ever seen...', 'Teens gain morphing powers to fight a secret alien invasion in this visceral sci-fi graphic novel.', 2020, NULL, '9781338226485', 240, NULL, NULL, 'https://covers.openlibrary.org/b/id/10528200-L.jpg', '/works/OL21892447W', NULL, '2020', 'English', NULL, 1, 0, 'the-invasion-chris-grine', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-18 19:46:55', '2026-03-22 04:53:09');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5fde79c7-87dd-45c9-b313-5931e3df4eed', 'Tintenherz', 'Wenn Bücher lebendig werden ... 

In einer stürmischen Nacht taucht ein unheimlicher Gast bei Meggie und ihrem Vater Mo auf. Er warnt Mo vor einem Mann namens Capricorn. Am nächsten Morgen reist Mo überstürzt mit Meggie zu ihrer Tante Elinor. Elinor verfügt über die kostbarste Bibliothek, die Meggie je gesehen hat. Hier versteckt Mo das Buch, um das sich alles dreht. Ein Buch, das Mo vor vielen Jahren zum letzten Mal gelesen hat und das jetzt in den Mittelpunkt eines unglaublichen, magischen und atemberaubenden Abenteuers rückt, eines Abenteuers, in dessen Verlauf Meggie nicht nur das Geheimnis um Zauberzunge und Capricorn löst, sondern auch selbst in große Gefahr gerät.', 'A young girl, Meggie, uncovers magical secrets tied to a mysterious book, diving into a thrilling fantasy adventure.', 2005, '0439709105', '9780439709101', 563, NULL, 160, 'https://covers.openlibrary.org/b/id/14369481-L.jpg', '/works/OL941669W', NULL, '2005', 'English', NULL, 1, 0, 'tintenherz-cornelia-funke', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 19:47:01', '2026-03-22 04:06:54');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6432ed65-216e-4b9e-bd56-8356928c4c5d', 'Animorphs Graphix - The Visitor', 'Morphing is certainly more fun than Sega -- you can soar as an eagle and walk as a cat. But being an ANIMORPH is by no means just fun and games. Rachel knew better than anyone. One of her best friends, Melissa, is acting very strange. And it looks like Melissa''s dad, who is also the school''s Assistant Principal, may be connected to evil aliens. Rachel can''t tell Melissa what the ANIMORPHS have learned, but Melissa doesn''t seem interested in talking to Rachel these days anyway. Could Melissa be one of "them?"

With the help of Jake, Cassie, Tobias and Marco, Rachel plans to enter her friend''s house as a cat, intent on unlocking the secrets from within. If only Rachel could keep her mind off mice...', 'Rachel and the Animorphs morph into animals to uncover secrets about evil aliens. A thrilling graphic novel of friendship and danger.', 2021, '133853839X', '9781338538373', 208, NULL, NULL, 'https://covers.openlibrary.org/b/id/12386586-L.jpg', '/works/OL25445703W', NULL, '2021', 'English', NULL, 1, 0, 'animorphs-graphix-the-visitor-chris-grine', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 19:47:02', '2026-03-22 04:09:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2cade2b2-15c1-4433-b9b5-ab26cdc6fe32', 'The Encounter - Animorphs Graphix #3', 'When Tobias and his friends were given the power to morph, they were also given an important warning: Never stay in a morph for more than two hours. But Tobias broke the time limit, and now he''s trapped in the body of a hawk — forever.

When he discovers an important Yeerk secret, Tobias knows he has to do everything in his power to destroy it. But to do so, he''ll have to contend with a part of himself that''s wrestling for dominion. A part that isn''t human.

For Tobias, the fight against the Yeerks is more pressing than ever — not just for humankind, but for his own humanity.', 'Tobias, trapped as a hawk, battles Yeerks to protect humanity while struggling with his own identity.', 2022, '1338538411', '9781338538403', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/13326871-L.jpg', '/works/OL27171826W', NULL, '2022', 'English', NULL, 1, 0, 'the-encounter-animorphs-graphix-3-katherine-applegate', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 19:47:04', '2026-03-22 03:32:58');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2ea1f4da-b2f0-4fe4-ab55-28ea10b5c8dd', 'The Message - Animorphs Graphix #4', NULL, 'A graphic novel adaptation of the Animorphs series, following teens who morph into animals to fight an alien invasion. Packed with action and moral dilemmas.', 2023, '1338796208', '9781338796209', NULL, NULL, NULL, NULL, '/works/OL34380478W', NULL, '2023', 'English', NULL, 1, 0, 'the-message-animorphs-graphix-4-katherine-applegate', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 19:47:05', '2026-03-22 03:34:32');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('95bfc1fe-4727-4c91-b68b-ffffe3ee53e2', 'The World We Make', 'Every great city has a soul. A human avatar that embodies their city’s heart and wields its magic. New York? She’s got six.

But all is not well in the city that never sleeps. Though Brooklyn, Manny, Bronca, Venezia, Padmini, and Neek have temporarily managed to stop the Woman in White from invading–and destroying the entire universe in the process–the mysterious capital “E” Enemy has more subtle powers at her disposal. A new candidate for mayor wielding the populist rhetoric of gentrification, xenophobia, and “law and order” may have what it takes to change the very nature of New York itself and take it down from the inside. In order to defeat him, and the Enemy who holds his purse strings, the avatars will have to join together with the other Great Cities of the world in order to bring her down for good and protect their world from complete destruction.', 'New York City''s avatars battle a sinister force and a dangerous mayoral candidate in a magical, political sci-fi tale of identity and resistance.', 2022, NULL, '9780356512693', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14563917-L.jpg', '/works/OL26764574W', NULL, '3 November 2022', 'English', NULL, 1, 0, 'the-world-we-make-n-k-jemisin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-18 19:47:06', '2026-03-22 04:42:33');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d96e7479-dec4-437d-925b-12ea2f7291ed', 'Argylle', 'NATIONAL BESTSELLER • The globe-trotting spy thriller that inspired the star-studded film Argylle, now streaming on Apple TV+, featuring Henry Cavill, Bryce Dallas Howard, Samuel L. Jackson, and John Cena, and directed by Matthew Vaughn of Kingsman trilogy fame. A luxury train speeding towards Moscow and a date with destiny. A CIA plane downed in the jungles of the Golden Triangle. A Nazi hoard entombed in the remote mountains of South-West Poland. A missing treasure, the eighth wonder of the world, lost for seven decades. One Russian magnate''s dream of restoring a nation to greatness has set in motion a chain of events which will take the world to the brink of chaos. Only Frances Coffey, the CIA''s most legendary spymaster, can prevent it.', 'A globe-trotting spy thriller with Argylle, a troubled agent, facing powerful enemies and personal demons to prevent global chaos.', 2022, NULL, '9781787635913', 352, NULL, 814, 'https://covers.openlibrary.org/b/id/14635251-L.jpg', '/works/OL25342512W', NULL, '2022', 'English', NULL, 1, 0, 'argylle-elly-conway', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-18 19:47:08', '2026-03-23 04:14:45');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('afa019dd-c97a-473c-abd8-16dc0165820d', 'Hatchet', 'Brian Robison, a teenage boy struggling through his parents divorce, is flying up north to stay with his dad for the summer. However, his plane crashes and he is forced to survive the Canadian wilderness. Now living in a world completely opposite of his own, he is now able to discover himself in this forsaken and misunderstood beautiful world.

The story is continued in "The River" "Brian''s Winter" "Brian''s Return" and "The Hunt"', 'A teenage boy survives a plane crash, facing the Canadian wilderness alone with just a hatchet. A gripping tale of resilience and self-discovery.', 2003, '1416936475', '9781416936473', 186, NULL, 222, 'https://covers.openlibrary.org/b/id/15379-L.jpg', '/works/OL8125760W', NULL, '2006', 'English', NULL, 1, 0, 'hatchet-gary-paulsen', 0, NULL, NULL, 0, NULL, 'public', '2026-03-18 19:47:13', '2026-03-22 05:01:08');
