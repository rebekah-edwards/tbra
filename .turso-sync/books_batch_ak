INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('759d3306-be2e-42cb-90f4-1f86c2a888f4', 'A Torre Negra', 'No meio do caminho entre o Palácio Verde e Calla, Roland Deschain e seu ka-tet ― Jake, Susannah, Eddie e Oi, o trapalhão ― são obrigados a acampar numa cidade fantasma. Caso contrário, iriam congelar com a chegada súbita e mortal de uma borrasca, tempestade única ao Mundo Médio. Para afastar o tédio da espera, Roland distrai o grupo com uma história de seu passado.
Porém, no centro dessa lembrança, o jovem Roland, do passado, também narra uma fábula de sua infância, registrada em seu livro favorito: "O vento pela fechadura". A lenda do menino Tim e suas aventuras em busca do mago Merlyn acabam revelando muitas verdades sobre Gilead, o Mundo Médio e o Pistoleiro.', 'In the epic conclusion to Roland Deschain''s quest for the mysterious Dark Tower, he and his ka-tet face ultimate dangers in a crumbling multiverse blending King''s other stories.', 1976, NULL, NULL, 256, NULL, NULL, 'https://books.google.com/books/content?id=ADgqDwAAQBAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL44189005W', NULL, NULL, 'English', NULL, 1, 0, 'a-torre-negra-stephen-king', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 06:45:35', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a9942fc3-fc87-4000-b477-0ebcc63b2c38', 'If It Bleeds', 'A collection of four uniquely wonderful long stories, including a stand-alone sequel to the No. 1 bestseller THE OUTSIDER.

News people have a saying: ''If it bleeds, it leads''. And a bomb at Albert Macready Middle School is guaranteed to lead any bulletin.

Holly Gibney of the Finders Keepers detective agency is working on the case of a missing dog - and on her own need to be more assertive - when she sees the footage on TV. But when she tunes in again, to the late-night report, she realises there is something not quite right about the correspondent who was first on the scene. So begins ''If It Bleeds'', a stand-alone sequel to the No. 1 bestselling THE OUTSIDER featuring the incomparable Holly on her first solo case - and also the riveting title story in Stephen King''s brilliant new collection.

Dancing alongside are three more wonderful long stories from this ''formidably versatile author'' (The Sunday Times) - ''Mr Harrigan''s Phone'', ''The Life of Chuck'' and ''Rat''. All four display the richness of King''s storytelling with grace, humour, horror and breathtaking suspense. A fascinating Author''s Note gives us a wonderful insight into the origin of each story and the writer''s unparalleled imagination', NULL, 2021, '8466355812', '9788466355810', 464, NULL, NULL, 'https://covers.openlibrary.org/b/id/14654512-L.jpg', '/works/OL20663157W', NULL, 'Jul 08, 2021', 'English', NULL, 1, 0, 'if-it-bleeds-stephen-king', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 06:45:37', '2026-03-25 00:23:59');
