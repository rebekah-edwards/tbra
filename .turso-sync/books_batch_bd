INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6a5e213b-89b5-4ad1-a197-9a6bbaf08ed8', 'Timeless', 'At long last, New York Times bestselling author R. A. Salvatore returns with one of fantasy’s most beloved and enduring icons, the dark elf Drizzt Do’Urden, in an all-new trilogy full of swordplay, danger, and imaginative thrills.', 'A dark elf ranger, Drizzt Do’Urden, navigates dual timelines of family and danger in the Forgotten Realms.', 2024, NULL, '9780063391055', NULL, NULL, 3000, NULL, '/works/OL38042190W', NULL, '2024', 'English', NULL, 1, 0, 'timeless-r-a-salvatore', 0, NULL, NULL, 0, NULL, 'public', '2026-03-17 23:31:25', '2026-03-22 04:13:45');
