INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('03153b98-14a6-4d38-90da-0b1dd5b14a3a', 'Deadly Class, Vol. 11', 'Sins must be atoned for, and few have as many sins as the students of Kings Dominion. Old rivalries come to a head and dark secrets are revealed as the deadliest people on earth reunite one last time.', 'A dark, humorous dive into the 1980s underground with damaged teens at Kings Dominion facing deadly rivalries.', 2022, '1534321233', '9781534321236', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726905-L.jpg', '/works/OL25803108W', NULL, '2022', 'English', NULL, 1, 0, 'deadly-class-vol-11-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:31:57', '2026-03-22 02:55:49');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('386cba6f-f2e1-4701-8d8c-1e11e6a14fd4', 'Deadly Class, Vol. 10', 'A forgotten and misunderstood generation wedged between two monoliths struggles to find their place in a world that is wholly disinterested in them. Year-by-year, as their cynicism is proven the only rational perspective, as the elastic cushion of youth fades, our friends must face a worldwide pandemic made up of the evils that once seemed relegated only to the halls of Kings Dominion.', 'A forgotten generation battles cynicism and a deadly pandemic in the brutal world of Kings Dominion.', 2021, NULL, '9781534319325', 152, NULL, NULL, 'https://covers.openlibrary.org/b/id/12443870-L.jpg', '/works/OL25800199W', NULL, '2021', 'English', NULL, 1, 0, 'deadly-class-vol-10-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:00', '2026-03-22 03:41:26');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e4981de5-e355-4fa2-a69e-345a03916d93', 'Deadly Class, Vol. 9', 'The Sophomore exam draws near as another year comes to a close in RICK REMENDER and WES CRAIG’s smash-hit series.', 'The Sophomore exam looms as tensions rise in this intense comic series about deadly assassins.', 2020, '1534315683', '9781534315686', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/9353647-L.jpg', '/works/OL20682003W', NULL, 'May 26, 2020', 'English', NULL, 1, 0, 'deadly-class-vol-9-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:03', '2026-03-23 04:22:23');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b4897286-f902-4df9-96c1-9bc229c85893', 'Deadly Class, Vol. 8', 'The crew returns to Kings Dominion to discover things have changed in their absence. The program has changed. Master Lin’s schemes revealed. Betrayal. Mystery. The secret of the catacombs beneath the school. A reckoning for the corrupt. Our friends try to hold everything together as Freshman Finals loom ever closer…RICK REMENDER and WES CRAIG’s darkly humorous look at the 1980s underground comes full circle.', 'A darkly humorous dive into the 1980s underground at Kings Dominion, where betrayal and mystery unfold as Freshman Finals loom.', 2019, '1534310630', '9781534310636', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726902-L.jpg', '/works/OL21354305W', NULL, '2019', 'English', NULL, 1, 0, 'deadly-class-vol-8-wes-craig', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:05', '2026-03-22 05:04:23');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('aa31bf93-53da-4a65-a7b8-4f57a7b3f961', 'Deadly Class, Vol. 7', 'Marcus and Maria have resurfaced, and with them a whole ocean of bad blood crashes on the shores. Shabnam and the Student Council are out to put Marcus and Maria in the grave for good this time, Saya’s maniacal brother Kenji stokes the flames of hatred, and in the shadows of those flames looms Headmaster Lin, waiting to reward whoever is left standing with a place by his side—or a sharp knife in the back. It’s 1989 and the era is drawing to a close, but it’s going to take as many poor bastards with it into oblivion as it can.', 'In 1989, Marcus and Maria face deadly threats from rivals and a sinister headmaster in a brutal school of assassins.', 2018, '153430696X', '9781534306967', 120, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726901-L.jpg', '/works/OL19749249W', NULL, '2018', 'English', NULL, 1, 0, 'deadly-class-vol-7-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:07', '2026-03-22 04:57:11');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('582ece14-75a4-4f9a-8075-5f75cc55e9b8', 'Deadly Class, Vol. 6', 'The freshman class has gotten a bloody welcome to Kings Dominion, as the newly empowered student council holds brutal sway over the hallways and dorms. If you’re not part of the group, you’re part of the body count. Meanwhile, Saya’s own mysterious past comes back to haunt her. Betrayal and subterfuge are around every corner. And far from the bloodshed are Marcus and Maria, rare survivors of the deadliest school on earth, harboring dark desires for revenge. Don’t miss the darkest and most revealing chapter of RICK REMENDER & WES CRAIG’s smash-hit series DEADLY CLASS.', 'A brutal comic series set in a deadly school, where betrayal and revenge drive the darkest chapter yet for Marcus and Maria.', 2017, '1534302476', '9781534302471', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726900-L.jpg', '/works/OL19724802W', NULL, '2017', 'English', NULL, 1, 0, 'deadly-class-vol-6-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:09', '2026-03-22 04:02:18');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8e294d96-9ef4-45cc-97ea-06f6a0188104', 'Deadly Class, Vol. 5', 'It’s morning in America, and those who lived through last arc’s brutal finale barely have had time to consider what they’ve done before a new class of kids enroll in the school, eager to pick up the bloody mantle. Sophomore survivor Saya Kuroki is given a chance to ascend in the ranks of the school’s deadliest and most ruthless students, and all it will cost her is what’s left of her humanity. RICK REMENDER & WES CRAIG present a new beginning to the dark saga of DEADLY CLASS.', 'A dark saga continues as Saya Kuroki faces a brutal choice to ascend in a deadly school. A blood-splattered tale of lost humanity.', 2017, '1534300554', '9781534300552', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726898-L.jpg', '/works/OL20053568W', NULL, '2017', 'English', NULL, 1, 0, 'deadly-class-vol-5-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:11', '2026-03-22 04:38:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('980cb4d0-7409-4d7d-be21-87df61a5fe2b', 'Deadly Class, Vol. 4', 'It''s 1988 and Marcus Lopez''s first year at Kings Dominion, the elite academy where damaged teenagers are forged into the world''s deadliest assassins, is coming to a close, and the final exam is murder ... literally. What few friends, what little love Marcus managed to scrape together become his greatest weakness, as the school descends into chaos. Pass or Fail, no one survives the Freshman Finals without getting blood on their hands.', 'In 1988, Marcus Lopez faces a deadly final exam at an elite assassin academy. Chaos erupts as friendships and love become fatal weaknesses.', 2016, '1632157187', '9781632157188', 136, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726897-L.jpg', '/works/OL20032949W', NULL, '2016', 'English', NULL, 1, 0, 'deadly-class-vol-4-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:13', '2026-03-22 04:43:57');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('54f54247-54c3-4dd0-8538-1e403b88cbf2', 'Deadly Class, Vol. 3', 'Marcus and his girlfriend Maria are thrown to the wolves when a Mexican Cartel, the family of a classmate they were forced to kill, comes gunning for revenge. The true costs of the life he’s chosen to live are only just dawning on Marcus. The troubled teen has never been more troubled.', 'A troubled teen faces deadly consequences as a Mexican Cartel seeks revenge in this brutal comic series.', 2015, '1632154765', '9781632154767', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/12448646-L.jpg', '/works/OL20013075W', NULL, '2015', 'English', NULL, 1, 0, 'deadly-class-vol-3-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:15', '2026-03-22 04:00:19');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('bcb694e7-10a0-445f-9d07-7b96889c33c1', 'Deadly Class, Vol. 2', 'Marcus Lopez is settling into life at Kings Dominion for the Deadly Arts, a secret elite school, to train the next generation of assassins. He has a girl, a circle of friends, and he’s learning a trade: the craft of killing. But his murderous past is about to catch up with him, and there are a few things about Marcus that even his friends don’t know. Secrets that threaten the lives of everyone around him. Because there’s a reason Marcus was sought out by the school’s shadowy principal Master Lin, a man who’s long had an eye for Marcus’s unique talents. Continuing the story of a group of damaged, deranged, and struggling teenagers living through one of the country’s most vibrant and chilling eras.', 'Marcus Lopez navigates life at a deadly assassin school while his dark past threatens to unravel everything. A gritty, punk-infused tale of violence and secrets.', 2015, '1632152223', '9781632152220', 128, NULL, NULL, 'https://covers.openlibrary.org/b/id/12726895-L.jpg', '/works/OL19996262W', NULL, '2015', 'English', NULL, 1, 0, 'deadly-class-vol-2-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:17', '2026-03-22 05:09:23');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e2fc1974-1c0b-4588-af79-8e01d089d987', 'Deadly Class, Vol. 1', 'It’s 1987. Marcus Lopez hates school. His grades suck. The jocks are hassling his friends. He can’t focus in class. But the jocks are the children of Joseph Stalin’s top assassin, the teachers are members of an ancient league of assassins, the class he’s failing is “Dismemberment 101,” and his crush has a doubledigit body count. 

Welcome to the most brutal high school on earth, where the world’s top crime families send the next generation of assassins to be trained. Murder is an art. Killing is a craft. At Kings Dominion School for the Deadly Arts, the dagger in your back isn’t always metaphorical.', 'In 1987, Marcus Lopez enters a brutal high school for assassins, where murder is an art and danger is everywhere.', 2014, '1632150034', '9781632150035', 160, NULL, NULL, 'https://covers.openlibrary.org/b/id/7866728-L.jpg', '/works/OL17583010W', NULL, '2014', 'English', NULL, 1, 0, 'deadly-class-vol-1-rick-remender', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-17 23:32:19', '2026-03-23 04:21:14');
