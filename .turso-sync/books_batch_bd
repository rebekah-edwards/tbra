INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('212b9a5f-ac74-40d4-b053-3b73a7cca5d7', 'Fourth World by John Byrne Omnibus', 'Legendary writer/artist John Byrne brought his unique vision to New Genesis and Apokolips in the 1990s—starting with the destruction of the twin worlds! Only Metron of the New Gods survives to journey to Earth to try to save the New Gods'' future! With his son, Orion, and Takion, living avatar of the Source, Highfather sets his sights on the ultimate confrontation with Darkseid, master of Apokolips! And in the miniseries Genesis, Earth''s heroes are losing their powers—thanks to the Godwave, a force that created gods and planets across the galaxy eons ago. Collects New Gods #12-15 (1997), Jack Kirby''s Fourth World #1-20, and Genesis #1-4.', 'John Byrne reimagines Jack Kirby''s Fourth World, reviving epic battles between New Genesis and Apokolips with iconic characters like Orion and Darkseid.', 2021, NULL, '9781779510174', NULL, NULL, NULL, 'https://books.google.com/books/content?id=7teQEAAAQBAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL25774590W', NULL, '2021', 'English', NULL, 1, 1, 'fourth-world-by-john-byrne-omnibus-john-byrne', 1, 'google_books', NULL, 0, NULL, 'import_only', '2026-03-17 23:32:43', '2026-03-25 00:23:59');
