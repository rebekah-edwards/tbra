INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('773f8919-f9af-48aa-8cb5-d9ae82629a6a', 'A Million Junes', 'June O''Donnell a.k.a. Junior, a.k.a. Jack, a.k.a. Jonathan O''Donnell IV, a.k.a. the first female O''Donnell first-born has always been haunted by her family''s mythic but complicated legacy. As she prepares to begin her final year of high school, June is itching to leave behind her ghosts in Five Fingers, Michigan, and travel the world.', 'In a town where worlds blur, 18-year-old June O''Donnell defies her family''s ancient feud with the Angerts by falling for Saul, uncovering magical secrets and generational grief.', 2017, '0448493977', '9780448493978', 398, NULL, 630, 'https://covers.openlibrary.org/b/id/8436139-L.jpg', '/works/OL19325338W', NULL, 'May 15, 2018', 'English', NULL, 1, 0, 'a-million-junes-emily-henry', 0, NULL, NULL, 0, NULL, 'public', '2026-03-15 22:27:39', '2026-03-22 20:32:05');
