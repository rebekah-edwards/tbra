INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c4a09ac0-c427-424a-9aaa-5e8b993f1d7a', 'Loves Enduring Promise', 'Three years later, we rejoin the Davis family in the pages of Love''s Enduring Promise, the sequel to Love Come Softly. Missie is now five years old, and quite excited about the prospect of a school being built in town. Marty is expecting a third child, while Clare is growing into a healthy young boy. As hardships are placed upon the shoulders of neighbors and friends, Marty and Clark reach out their hands to help in any way they can. And when the community finds a need for a teacher, and a pastor, will they find who they are looking for, or will all their hard work be in vain?', 'Three years after the first book, the Davis family navigates pioneer life with young children, community building, and hardships among neighbors.', 1979, '0881132543', '9787900230843', 288, NULL, NULL, 'https://covers.openlibrary.org/b/id/7911852-L.jpg', '/works/OL97146W', NULL, '1979', 'English', NULL, 1, 0, 'loves-enduring-promise-janette-oke', 0, NULL, NULL, 0, NULL, 'public', '2026-03-15 22:28:07', '2026-03-22 20:32:05');
