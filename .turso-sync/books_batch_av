INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('838b07c4-8008-45d2-9ab7-58bf3e139cd3', 'Yukie''s Island', 'A moving picture book autobiography about a family''s resilience and path to healing after the devastation of war. It''s 1945, the final year of World War II. Yukie Kimura is eight years old, she lives on a tiny island with a lighthouse in the north of Japan with her family, and she knows that the fighting that once felt so far away is getting closer.', 'A picture book memoir of Yukie Kimura''s childhood on a Japanese island during WWII, capturing resilience amid war''s devastation.', 2023, NULL, '9781250206503', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14383589-L.jpg', '/works/OL28421236W', NULL, '2023', 'English', NULL, 0, 0, 'yukies-island-steve-sheinkin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:32:44', '2026-03-22 04:30:36');
