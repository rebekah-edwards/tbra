INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('90afb093-fb1c-44db-87af-e5e59d6337be', 'Red Moon', 'When government agents kick down Claire Forrester’s front door and murder her parents, Claire realizes just how different she is. Patrick Gamble was nothing special until the day he got on a plane and hours later stepped off it, the only passenger left alive, a hero. President Chase Williams has sworn to protect the people of the United States from the menace in their midst, but is becoming the very thing he has promised to destroy. So far the threat has been controlled by laws and violence and drugs.', 'A dystopian horror-thriller where werewolves, infected by a prion, are a persecuted minority in a post-9/11 allegorical America.', 2013, NULL, '9781444725018', 344, NULL, 1303, NULL, '/works/OL39120257W', NULL, '2013', 'English', NULL, 1, 0, 'red-moon-benjamin-percy', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:32:44', '2026-03-22 04:39:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5a7d8494-1298-4755-bf63-4a6182ab0ab2', 'Trouble with Peace - Carton of 10 Signed Copies', 'Conspiracy. Betrayal. Rebellion.

Peace is just another kind of battlefield . . . 

Savine dan Glokta, once Adua’s most powerful investor, finds her judgement, fortune and reputation in tatters. But she still has all her ambitions, and no scruple will be permitted to stand in her way. 

For heroes like Leo dan Brock and Stour Nightfall, only happy with swords drawn, peace is an ordeal to end as soon as possible. But grievances must be nursed, power seized and allies gathered first, while Rikke must master the power of the Long Eye . . . before it kills her.

Unrest worms into every layer of society. The Breakers still lurk in the shadows, plotting to free the common man from his shackles, while noblemen bicker for their own advantage. Orso struggles to find a safe path through the maze of knives that is politics, only for his enemies, and his debts, to multiply.

The old ways are swept aside, and the old leaders with them, but those who would seize the reins of power will find no alliance, no friendship, and no peace, lasts forever.

