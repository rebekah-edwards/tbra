INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4edc6f5b-2f08-4874-bd69-f8c9f46a05fb', 'Red Country', 'They burned her home. They stole her brother and sister. But vengeance is following. Shy South hoped to bury her bloody past and ride away smiling, but she''ll have to sharpen up some bad old ways to get her family back, and she''s not a woman to flinch from what needs doing. She sets off in pursuit with only a pair of oxen and her cowardly old stepfather Lamb for company. But it turns out Lamb''s buried a bloody past of his own, and out in the lawless Far Country, the past never stays buried.', 'A gritty fantasy-western blend, Red Country follows Shy South''s quest for vengeance after her home is burned and family stolen.', 2012, '0316187216', '9780316187213', 464, NULL, 1193, 'https://covers.openlibrary.org/b/id/14543402-L.jpg', '/works/OL19357923W', NULL, '2012-10-23', 'English', NULL, 1, 0, 'red-country-joe-abercrombie', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:32:35', '2026-03-22 03:56:18');
