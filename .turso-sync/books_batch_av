INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('942446e1-8bab-4eca-bce0-b2330ed56299', 'Xenocide', 'The Starways Congress so fears the effects of the descolada, should it escape from Lusitania, that they have ordered the destruction of the entire planet, and all who live there. The Fleet is on its way, a second xenocide seems inevitable. Xenocide is the third novel in Orson Scott Card''s The Ender Saga.', 'On Lusitania, a deadly virus threatens all life as a fleet prepares for planetary destruction in this philosophical sci-fi saga.', 1992, NULL, NULL, NULL, NULL, 1215, NULL, '/works/OL38068020W', NULL, '1992-08-15', 'English', NULL, 1, 0, 'xenocide-orson-scott-card', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:31:10', '2026-03-22 04:41:31');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ba149776-1363-483f-b6df-2eb66a5fe2f1', 'Ruins', 'From the author of Ender’s Game, the major motion picture! A complex fate. A deadly path. Book two in the New York Times bestselling series Publishers Weekly calls ''an epic in the best sense.'' When Rigg and his friends crossed the Wall between the only world they knew and a world they could not imagine, he hoped he was leading them to safety.', 'Rigg and friends navigate a vast new world beyond the Wall, facing complex fates and deadly paths in a sci-fi fantasy blend.', 2012, NULL, '9798855021288', 530, NULL, 3000, 'https://covers.openlibrary.org/b/id/10620725-L.jpg', '/works/OL16540648W', NULL, '2012', 'English', NULL, 1, 0, 'ruins-orson-scott-card', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:31:11', '2026-03-22 05:07:24');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('259d0d86-9f99-4541-91da-c58d2d4559e4', 'The Devils', 'Europe stares into the abyss.

Plague and famine stalk the land, monsters lurk in every shadow and greedy princes care for nothing but their own ambitions. Only one thing is certain: the elves will come again, and they will eat everyone.

Sometimes, only the darkest paths lead towards the light. Paths on which the righteous will not dare to tread . . .

And so, buried beneath the sacred splendour of the Celestial Palace, is the secret Chapel of the Holy Expediency. For its congregation of convicted monsters there are no sins that have not been committed, no lines that will not be crossed, and no mission that cannot be turned into a disastrous bloodbath.

Now the hapless Brother Diaz must somehow bind the worst of the worst to a higher cause: to put a thief on the throne of Troy, and unite the sundered church against the coming apocalypse.

