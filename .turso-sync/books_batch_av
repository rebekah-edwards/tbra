INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('52954f04-2299-4637-bf21-ac9f556e9828', 'Radio Free Albemuth', 'In Radio Free Albemuth, his last novel, Philip K. Dick morphed and recombined themes that had informed his fiction from A Scanner Darkly to VALIS and produced a wild, impassioned work that reads like a visionary alternate history of the United States. Agonizingly suspenseful, darkly hilarious, and filled with enough conspiracy theories to thrill the most hardened paranoid, Radio Free Albemuth is proof of Dick''s stature as our century''s greatest prankster-prophet.', 'A dystopian tale of a paranoid America under fascist rule, blending sci-fi with divine messages and conspiracy.', 1987, '0380702886', '9780380702886', 212, NULL, NULL, 'https://covers.openlibrary.org/b/id/6643179-L.jpg', '/works/OL2172484W', NULL, 'Jun 01, 1987', 'English', NULL, 1, 0, 'radio-free-albemuth-philip-k-dick', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:32:41', '2026-03-22 03:58:35');
