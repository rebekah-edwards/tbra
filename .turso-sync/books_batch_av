INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e3b32302-4893-458d-aec5-0741c49ea663', 'Sarah', 'Bestselling author Orson Scott Card uses his fertile imagination, and uncanny insight into human nature, to tell the story of a unique woman--one who is beautiful, tough, smart, and resourceful in an era when women had little power, and are scarce in the historical record. Sarah, child of the desert, wife of Abraham, takes on vivid reality as a woman desirable to kings, a devoted wife, and a faithful follower of the God of Abraham, chosen to experience an incomparable miracle.', 'A reimagining of Sarah, Abraham''s wife, as a strong, resourceful woman in a time of limited female power.', 2001, NULL, '9780765390691', NULL, NULL, 3000, NULL, '/works/OL38024710W', NULL, '2001', 'English', NULL, 1, 0, 'sarah-orson-scott-card', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:31:23', '2026-03-23 04:21:48');
