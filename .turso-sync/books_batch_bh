INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d1e2d66b-e59d-4a88-9e48-f787f631abc6', 'Infinite Stars', 'The 24 selections–which include classics from luminaries such as Robert Silverberg (who also contributes an informative historical introduction), Anne McCaffrey, Poul Anderson, and Cordwainer Smith, as well as 15 works original to this volume–illustrate the wide variety of themes that space opera can accommodate: galactic empire building across space and time in Leigh Brackett and Edmond Hamilton’s “Stark and the Star Kings”; the peculiar lives of extraterrestrial fauna in Orson Scott Card’s “Renegat” (a new episode in his long-running Ender saga); interstellar piracy in Elizabeth Moon’s “All in a Day’s Work”; cultural identity in Nnedi Okorafor’s Hugo-winning “Binti”; and military adventures (a staple of the subgenre) in stories by Lois McMaster Bujold, David Drake, and Bennett R.', 'A definitive anthology of space opera and military SF, featuring classic and new stories from genre masters.', 2018, '1785655949', '9781785655944', 736, NULL, NULL, 'https://covers.openlibrary.org/b/id/14532818-L.jpg', '/works/OL19724205W', NULL, '2018', 'English', NULL, 1, 0, 'infinite-stars-larry-niven', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 04:17:37', '2026-03-23 04:10:27');
