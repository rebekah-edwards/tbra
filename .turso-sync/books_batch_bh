INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ce13e1f0-b3c5-4b93-9e5b-079bc2fd127c', 'Every Spiral of Fate', 'The highly anticipated fourth novel in the Woven Kingdom romantasy series, brimming with fiery romance, spectacular magic, and breathtaking secrets, from Tahereh Mafi, the award-winning and bestselling author of the Shatter Me series. Perfect for fans of Sarah J.', 'A breathtaking romantasy saga of fiery love, spectacular magic, and devastating destinies in a prophesied kingdom.', 2025, '0063315343', NULL, NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/15128128-L.jpg', '/works/OL44092914W', NULL, 'September 30, 2025', 'English', NULL, 1, 0, 'every-spiral-of-fate-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:09', '2026-03-23 04:07:19');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6274c66c-5d79-42f0-8533-0de1127f2d93', 'These Infinite Threads', 'Instant #1 New York Times bestseller! A stunning romantasy full of explosive magic, searing romance, and heartbreaking betrayal, this breathtaking sequel to This Woven Kingdom is from the award-winning and bestselling author of the Shatter Me series and is perfect for...', 'A romantasy sequel with forbidden love, warring kingdoms, and a Jinn heir''s destiny, steeped in yearning and betrayal.', 2023, NULL, '9780008592233', NULL, NULL, 677, 'https://covers.openlibrary.org/b/id/13285209-L.jpg', '/works/OL28352549W', NULL, '2023', 'English', NULL, 1, 0, 'these-infinite-threads-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:10', '2026-03-22 04:08:36');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4b0b49bb-2aa1-41e5-b00f-fbeb01da2401', 'A Very Large Expanse of Sea', 'It’s 2002, a year after 9/11. It’s an extremely turbulent time politically, but especially so for someone like Shirin, a sixteen-year-old Muslim girl who’s tired of being stereotyped. Shirin is never surprised by how horrible people can be. She’s tired of the rude stares, the degrading comments—even the physical violence—she endures as a result of her race, her religion, and the hijab she wears every day. So she’s built up protective walls and refuses to let anyone close enough to hurt her. Instead, she drowns her frustrations in music and spends her afternoons break-dancing with her brother. But then she meets Ocean James. He’s the first person in forever who really seems to want to get to know Shirin. It terrifies her—they seem to come from two irreconcilable worlds—and Shirin has had her guard up for so long that she’s not sure she’ll ever be able to let it down.', 'A Muslim teen faces Islamophobia and finds unexpected love in post-9/11 America. A raw, emotional YA tale.', 2018, '0062866567', '9780062866561', 323, NULL, 403, 'https://covers.openlibrary.org/b/id/9242462-L.jpg', '/works/OL26337892W', NULL, '2018', 'English', NULL, 1, 0, 'a-very-large-expanse-of-sea-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:12', '2026-03-22 03:54:01');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('28cc6df5-7c9c-437b-a957-4ef71d5794ca', 'Kiskent', NULL, 'A mysterious narrative unfolds in ''Kiskent'' by Tahereh Mafi, exploring complex human emotions.', 2020, '6257973465', '9786257973465', 288, NULL, NULL, 'https://covers.openlibrary.org/b/id/12272091-L.jpg', '/works/OL26270048W', NULL, 'Nov 01, 2020', 'English', NULL, 1, 0, 'kiskent-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:13', '2026-03-22 03:30:34');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('15169a8f-df17-4e62-8f84-33c44cd805c8', 'Defy Me', 'Juliette and Warner’s story continues in the thrilling fifth installment of Tahereh Mafi’s New York Times bestselling Shatter Me series.

Juliette Ferrars isn’t who she thinks she is.

Nothing in her world is what it seemed. She thought she’d finally defeated the Reestablishment. She thought she’d finally taken control of her life, her power, and her pain. But Juliette has only just begun to unravel a lifetime of lies, and she finds herself faced with a familiar choice: 

Be a weapon. Or be a warrior. 

This time, she’s not alone. Stronger, braver, and more resilient than ever, Juliette will fight for life and love with her friends by her side—but first, she has to survive the war being waged against her mind:

She has to remember who she was.

Narrated by Juliette, Warner, and Kenji Kishimoto, this gripping novel will leave readers hungry for Imagine Me, the sixth novel in the series.', 'Juliette Ferrars uncovers shocking truths and fights for love and life in this thrilling dystopian saga.', 2019, '1780318545', '9780062676412', 376, NULL, NULL, 'https://covers.openlibrary.org/b/id/10499433-L.jpg', '/works/OL20145719W', NULL, '2019', 'English', 'HarperCollins', 1, 0, 'defy-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:15', '2026-03-22 03:17:58');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('05c22abb-194a-44ad-9438-993d151ab825', 'Believe Me', 'The devastatingly romantic fifth novella in the New York Times and USA Today bestselling Shatter Me series, chronicling the events after Imagine Me, the explosive sixth novel. Juliette and Warner fight to take down the Reestablishment once and for all.', 'A romantic finale to the Shatter Me series, focusing on Juliette and Warner''s wedding amidst dystopian struggles.', 2021, '0063228319', '9780063228313', 224, NULL, 278, 'https://covers.openlibrary.org/b/id/12428862-L.jpg', '/works/OL25344121W', NULL, 'Nov 16, 2021', 'English', 'HarperCollins', 1, 0, 'believe-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:16', '2026-03-22 02:57:19');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6fadf099-f81f-4b4b-a258-97b5d0f274df', 'This Woven Kingdom', 'To all the world, Alizeh is a disposable servant, not the long-lost heir to an ancient Jinn kingdom forced to hide in plain sight. Clashing empires, forbidden romance, and a long-forgotten prophecy entangle her fate in this spellbinding tale inspired by Persian mythology.', 'A secret Jinn queen hides as a servant, navigating forbidden romance and clashing empires in a Persian mythology-inspired fantasy.', 2022, '0062972448', '9780062972446', 512, NULL, 677, 'https://covers.openlibrary.org/b/id/15156725-L.jpg', '/works/OL24778640W', NULL, 'Feb 01, 2022', 'English', NULL, 1, 0, 'this-woven-kingdom-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:17', '2026-03-22 04:17:27');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1e9fa926-e8ec-41a5-b308-a1149ebaa433', 'Emotion of Great Delight', 'An Emotion of Great Delight is a searing look into the world of a single Muslim family in the wake of 9/11. It''s about a child of immigrants forging a blurry identity, falling in love, and finding hope--in the midst of a modern war.', 'A Muslim teen navigates grief, identity, and hope in post-9/11 America, facing prejudice and family tragedy.', 2022, '0062972421', '9780062972422', 272, NULL, 393, 'https://covers.openlibrary.org/b/id/11203749-L.jpg', '/works/OL24415205W', NULL, 'Jun 28, 2022', 'English', NULL, 1, 0, 'emotion-of-great-delight-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:18', '2026-03-22 03:24:01');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8145ee2b-fc83-4b6a-b79c-5d2444bb1cde', 'Imagine Me', 'Juliette Ferrars. Ella Sommers. Which is the truth and which is the lie? Now that Ella knows who Juliette is and what she was created for, things have only become more complicated.', 'Juliette Ferrars, also Ella Sommers, grapples with her identity and purpose in a dystopian world of war and romance.', 2020, '1094118001', '9781094118000', 352, NULL, 1500, 'https://covers.openlibrary.org/b/id/14408246-L.jpg', '/works/OL20689526W', NULL, 'Mar 31, 2020', 'English', 'HarperCollins', 1, 0, 'imagine-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:19', '2026-03-22 04:29:03');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8dc9acf8-250f-48fe-a712-2358fa7ada08', 'Reveal Me', 'This fourth companion novella to Tahereh Mafi’s New York Times bestselling Shatter Me series is narrated by fan favorite character Kenji Kishimoto! The explosive revelations in Defy Me have left readers reeling and desperate for answers. This fourth and final novella in the series will bring readers back to the world of the Shatter Me before the final novel installment hits shelves in winter 2020.', 'A novella in the Shatter Me series, Reveal Me follows Kenji Kishimoto navigating emotional turmoil and explosive revelations in a dystopian world.', 2019, NULL, '9780062906274', 86, NULL, NULL, 'https://covers.openlibrary.org/b/id/12782240-L.jpg', '/works/OL21858304W', NULL, '2019', 'English', 'HarperCollins', 1, 0, 'reveal-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:19', '2026-03-22 04:37:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('41a3ddb3-4276-4863-b35b-dd6e6f2dcd36', 'Shadow Me', 'Fan favorite character Kenji Kishimoto narrates this gripping companion novella to Tahereh Mafi’s New York Times bestselling Shatter Me series, set during the explosive events in Restore Me! Juliette is still reeling from Warner''s betrayal, and Kenji is trying to balance his friendship with her with his responsibilities as a leader of the resistance against the Reestablishment.', 'Kenji Kishimoto narrates a gripping novella in the Shatter Me series, balancing friendship and resistance duties amid betrayal.', 2019, NULL, '9780062906267', 112, NULL, NULL, 'https://covers.openlibrary.org/b/id/14408244-L.jpg', '/works/OL21856464W', NULL, '2019', 'English', 'HarperCollins', 1, 0, 'shadow-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:20', '2026-03-22 03:46:55');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('cf9e5055-7428-41a9-b108-6b98457aac78', 'Unite Me', 'Perfect for fans of Tahereh Mafi''s New York Times bestselling Shatter Me trilogy, this book collects her two companion novellas, Fracture Me and Destroy Me, in print for the first time ever. It also features an exclusive look into Juliette''s journal and a preview of Ignite Me, the third installment of the series. Destroy Me tells the events between Shatter Me and Unravel Me from Warner''s point of view.', 'Two novellas from the Shatter Me series, exploring Warner and Adam''s perspectives on Juliette in a dystopian world.', 2019, '1405296240', '9781405296243', 208, NULL, 281, 'https://covers.openlibrary.org/b/id/14646634-L.jpg', '/works/OL17112882W', NULL, 'Jun 13, 2019', 'English', 'HarperCollins', 1, 0, 'unite-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:21', '2026-03-23 04:08:32');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('13a447d2-62e9-477f-80d5-bb28eb044c5e', 'Fracture Me', 'In this electrifying sixty-page companion novella to the New York Times bestselling Shatter Me series, discover the fate of the Omega Point rebels as they go up against The Reestablishment. Set during and soon after the final moments of Unravel Me, Fracture Me is told from Adam''s point of view.', 'A gripping novella in the Shatter Me series, Fracture Me follows Adam''s perspective during a critical battle against The Reestablishment.', 2013, NULL, '9780062284839', 68, NULL, 281, 'https://books.google.com/books/content?id=HUFwAAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL21786339W', NULL, '2013', 'English', 'HarperCollins', 1, 0, 'fracture-me-tahereh-mafi', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 16:28:21', '2026-03-22 03:16:52');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8efb9672-0d2c-428c-be55-3e4e56409fb4', 'Destroy Me', 'Set after Tahereh Mafi''s Shatter Me and before Unravel Me, Destroy Me is a novella told from the perspective of Warner, the ruthless leader of Sector 45. Even though Juliette shot him in order to escape, Warner can''t stop thinking about her—and he''ll do anything to get her back.', 'A novella from Warner''s perspective, the ruthless leader of Sector 45, obsessed with reclaiming Juliette in a dystopian world.', 2012, NULL, '9780062208194', 111, NULL, 332, 'https://covers.openlibrary.org/b/id/12717315-L.jpg', '/works/OL21775531W', NULL, '2012', 'English', 'HarperCollins', 1, 0, 'destroy-me-tahereh-mafi', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:28:22', '2026-03-22 04:38:39');
