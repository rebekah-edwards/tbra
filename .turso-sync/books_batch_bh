INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e341ca1e-e4ee-4041-b541-4c69aae80a1c', 'Inside', 'With cliff-hangers ending every chapter, readers will be compelled to devour this quickly, but there’s plenty to think about, too, as Trella must decide who her friends are, what’s important to her, and what she is willing to sacrifice for an abstract, possibly false vision of hope. The romance Trella encounters ups the stakes as well. Snyder does a great job of tying up enough loose ends to make the story satisfying yet leaving enough questions open that lead right to a sequel. Grades 8-12. --Ilene Cooper', 'A dystopian sci-fi tale of rebellion in a confined world called Inside, where Trella uncovers secrets and sparks a revolution.', 2012, '037321068X', '9781459219113', 456, NULL, 572, 'https://covers.openlibrary.org/b/id/10766271-L.jpg', '/works/OL21763315W', NULL, '2012', 'English', NULL, 1, 0, 'inside-maria-v-snyder', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:39:58', '2026-03-23 04:21:23');
