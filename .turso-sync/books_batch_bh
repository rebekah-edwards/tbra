INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('423ff633-9b83-40db-a989-e83c663251f4', '26 Beauties', 'Beautiful young women are disappearing by the dozen. A celebration is cut short when a concerned father crashes Detective Inspector Lindsay Boxer’s party. His daughter is missing – and she’s not the only one. Lindsay’s been investigating the deaths of a Jane Doe washed up on a nearby beach, and a young woman found in Golden Gate Park. What if all these cases are connected? The answers lie with the 26 Beauties on the run and in the wind.', 'Detective Lindsay Boxer investigates the chilling disappearances of young women in this gripping Women''s Murder Club thriller.', 1905, '0316607290', '9780316607292', 150, NULL, 510, 'https://covers.openlibrary.org/b/id/15183082-L.jpg', '/works/OL45017077W', NULL, 'May 4, 2026', 'English', NULL, 1, 0, '26-beauties-james-patterson', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 02:55:38', '2026-03-22 03:47:33');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8baef23f-4283-46fc-9b72-35af65705551', 'The Unusual Second Life of Thomas Weaver', 'All Thomas Weaver wanted was death. What he got was time travel. Thomas Weaver, haunted by a teenage tragedy, lived a wasted life. He closed his eyes for what he believed was the last time in 2016, but opened them again in his teenage bedroom and body in 1976. Now a middle-aged man in a teenage body, he sets out to fix everything he did wrong in his first life. A budding serial killer in home room, a possible new romance, and high school algebra complicate his plans.', 'Thomas Weaver, haunted by tragedy, dies in 2016 and awakens in 1976 as his teenage self, seeking to fix past mistakes in this time travel tale.', 2016, '1535239492', '9781535239493', 320, NULL, NULL, 'https://covers.openlibrary.org/b/id/10515440-L.jpg', '/works/OL23588459W', NULL, 'Jul 28, 2016', 'English', NULL, 1, 0, 'the-unusual-second-life-of-thomas-weaver-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:10', '2026-03-22 04:36:03');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e6efe18d-abbd-4a5e-a936-4f42092c115d', 'The Collected Lives of Chuck Burke', 'Some lives are too heavy to carry until you learn what to set down. In this quietly powerful tale of recovery and renewal, Chuck must learn that real change isn’t about what he can keep—it’s about what he’s willing to release.', 'Chuck Burke navigates multiple lives, learning to release burdens in a tale of recovery and renewal.', 2025, NULL, NULL, 382, NULL, 669, 'https://covers.openlibrary.org/b/id/15176804-L.jpg', '/works/OL44984207W', NULL, '11/18/2025', 'English', NULL, 1, 0, 'the-collected-lives-of-chuck-burke-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:11', '2026-03-23 04:24:06');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('841c5dcf-06d4-4894-9686-aaa6d3102ce5', 'The Indomitable Lives of Tuesday West', 'In a town where time is as fluid as fate itself, Tuesday has a rare opportunity to rewrite her story. If she knows her future, can she change it? The Indomitable Lives of Tuesday West is a profound exploration of disability, acceptance, and the endless possibilities hidden in second chances.', 'Tuesday West navigates time travel and second chances in Middle Falls, exploring disability and acceptance.', 2025, NULL, NULL, 411, NULL, 712, 'https://covers.openlibrary.org/b/id/15176803-L.jpg', '/works/OL44984206W', NULL, '5/30/2025', 'English', NULL, 1, 0, 'the-indomitable-lives-of-tuesday-west-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:12', '2026-03-22 04:31:03');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('82760445-3f53-459e-83b1-bbe710865e81', 'The Unrepentant Lives of Reggie Blackwell', 'In the charming town of Middle Falls, Oregon, an extraordinary phenomenon occurs: those who die but aren''t ready to move on are inexplicably revived at key moments in their lives, with their memories fully intact. Reggie Blackwell is one such soul—a boy with a tragic past who threatens to grow into a man with a thirst for the easy life. An unrepentant rogue, Reggie seizes the rare opportunity these resets offer, diving headfirst into a life without consequences. But as Reggie spirals deeper into the hedonistic world he’s crafted, a troubling question arises: Is there a price for living without remorse? Can a man who refuses to seek redemption ever truly escape the shadows of his choices? The Unrepentant Lives of Reggie Blackwell asks a provocative question: Can anyone find redemption if they aren’t willing to seek it?', 'A rogue with a tragic past, Reggie Blackwell exploits time resets in Middle Falls, Oregon, chasing an easy life without remorse.', 2024, NULL, NULL, 377, NULL, 600, 'https://covers.openlibrary.org/b/id/15176802-L.jpg', '/works/OL44984205W', NULL, '12/31/2024', 'English', NULL, 1, 0, 'the-unrepentant-lives-of-reggie-blackwell-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:12', '2026-03-22 04:29:57');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a5945956-ca9b-459a-89ee-d1fb315cf0d8', 'The Topsy-Turvy Lives of Hattie Kildare', 'As she grapples with the weight of her newfound reality, Hattie embarks on a poignant quest to rewrite the fabric of history and save both Jimmy and her little sister, Jackie, from the clutches of fate. Against the backdrop of a nation at war and a community united in sacrifice, "The Topsy-Turvy Lives of Hattie Kildare" paints a vivid portrait of resilience, love, and the enduring power of hope in the face of adversity.', 'Hattie Kildare navigates time travel to rewrite history, embodying resilience and hope amid war and sacrifice.', 2024, NULL, NULL, 384, NULL, NULL, 'https://covers.openlibrary.org/b/id/15176801-L.jpg', '/works/OL44984204W', NULL, '3/31/2024', 'English', NULL, 1, 0, 'the-topsyturvy-lives-of-hattie-kildare-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:13', '2026-03-22 04:53:49');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b004c85c-1c49-4f17-8e70-4782c03ab813', 'The Ambitious Lives of Evan Sanderson', 'Evan Sanderson seems to be living a charmed life. He is a successful doctor, much respected in the community, and has a beautiful wife. Evan accomplished what he had because he had a burning ambition to achieve, to be the best. Evan lives in Middle Falls, where second--and third--chances abound, so perhaps he will be able to get to where he longs to be after all. Or will his ambition turn in new directions? The Ambitious Lives of Evan Sanderson is the nineteenth book in the Middle Falls Time Travel Series.', 'Evan Sanderson, a successful doctor, navigates ambition and second chances through time travel in Middle Falls.', 2023, NULL, NULL, 347, NULL, 593, 'https://covers.openlibrary.org/b/id/15176800-L.jpg', '/works/OL44984203W', NULL, '12/19/2023', 'English', NULL, 1, 0, 'the-ambitious-lives-of-evan-sanderson-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:14', '2026-03-22 05:01:25');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('53f0abca-92ce-44f1-afea-67ad2b04f43d', 'The Tumultuous Lives of Karl Strong', 'He is a talented athlete, but after high school, he lets himself go and dies of a heart attack. Luckily, this is Middle Falls, where death is rarely the end of the story. Karl will have every chance to find what he needs.', 'Karl Strong, a talented athlete, faces downfall and death, but in Middle Falls, second chances through time travel offer redemption.', 2023, NULL, NULL, 367, NULL, NULL, 'https://covers.openlibrary.org/b/id/15176799-L.jpg', '/works/OL44984202W', NULL, '3/25/2023', 'English', NULL, 1, 0, 'the-tumultuous-lives-of-karl-strong-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:15', '2026-03-22 03:59:30');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('48866148-3c4f-4f02-8416-a90744356728', 'Deadly Life of Diana Penn', 'All Diana Penn wanted was a quiet retirement. What she got was a chance to rewrite history. When a demolition crew uncovers unexploded WWII bombs in a quiet Northumberland park, retired MI6 agent Diana Penn instantly senses danger. But before she can act, the bombs detonate, changing her life forever. Now, thanks to the magic of Middle Falls (transplanted to the UK), Diana gets the chance to live her life over and learn to make connections. How many lives will it take until she succeeds? Only the magic of Middle Falls can tell.', 'Retired MI6 agent Diana Penn gets a chance to rewrite history after a deadly discovery in a Northumberland park.', 2025, NULL, '9781991331557', 346, NULL, NULL, NULL, '/works/OL44595004W', NULL, '2025', 'English', NULL, 1, 0, 'deadly-life-of-diana-penn-shawn-inmon', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 03:12:15', '2026-03-22 03:52:04');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6e4fb060-6959-4f23-81d0-13156864ded8', 'Second Chance Love', 'Once in college, they found themselves in love, but too afraid to admit it: Steve because he thought Elizabeth was too beautiful to want him; and Elizabeth because she thought Steve was too wealthy to be interested in someone so poor. But then, a family tragedy strikes, and they are pulled apart and lose touch with each other. A chance meeting on a Christmas tree lot twenty years later changes their fates forever.', 'A heartfelt second-chance romance between Steve and Elizabeth, rediscovering love after twenty years apart.', 2015, NULL, '9781507864616', 282, NULL, 534, NULL, '/works/OL40332242W', NULL, '2015', 'English', NULL, 1, 0, 'second-chance-love-shawn-inmon', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 03:12:16', '2026-03-22 04:16:27');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('92f30b71-b3b5-403b-8890-cb94f3e87160', 'Feels Like the First Time', 'September, 1975: Shawn meets Dawn, his one true love, when she moves into the vacant house next door. Soon, they were best friends, then became each other''s first loves. Shawn was outgoing but bookish, Dawn, beautiful and reserved. Their storybook romance came to an end when Dawn''s parents forbid them to see each other. They didn''t - for 27 years, until a chance meeting swept them up in a storm of emotions and memories.', 'A heartfelt true love story of Shawn and Dawn, torn apart for 27 years before a chance reunion rekindles their romance.', 2012, NULL, '9781479258949', 222, NULL, NULL, NULL, '/works/OL39823697W', NULL, '2012', 'English', NULL, 0, 0, 'feels-like-the-first-time-shawn-inmon', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 03:12:17', '2026-03-22 04:40:49');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('998eea5c-34ef-4e77-aa27-a1e3d736e00e', 'Kradak the Champion', 'They call him Kradak, but his friends call him Steve. He''s big and strong, an actor who plays a hero named Kradak in a series of B-movies. When Rista and Grint come through the portal from Arkana, they don''t understand what a movie is. They think Steve truly is Kradak the Champion.', 'An actor playing a B-movie hero, Kradak, is mistaken for the real champion by visitors from another world in this humorous fantasy adventure.', 2021, NULL, '9798502843959', NULL, NULL, 633, NULL, '/works/OL35871386W', NULL, '2021', 'English', NULL, 1, 0, 'kradak-the-champion-shawn-inmon', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 03:12:18', '2026-03-22 04:45:10');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5733183e-ba34-4573-81ff-254e8839148b', 'The Anxious Lives of Edwin Miller', 'Edwin Miller is uncertain. Not about any one thing, but about every thing. He''s smart, capable, and completely unable to move forward in his life because of his own anxiety. Luckily for Edwin, he lives in Middle Falls, Oregon, where the apparent end is often just a new beginning. The Anxious Life of Edwin Miller is the seventeenth book in the Middle Falls Time Travel Series.', 'Edwin Miller, crippled by anxiety, lives in Middle Falls, Oregon, where time travel offers new beginnings in this emotional tale.', 2022, NULL, NULL, 347, NULL, 587, 'https://covers.openlibrary.org/b/id/13147103-L.jpg', '/works/OL34304774W', NULL, 'November 22, 2022', 'English', NULL, 1, 0, 'the-anxious-lives-of-edwin-miller-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:18', '2026-03-22 04:01:31');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6de2b6ed-5624-4b07-b8de-489b7bac9aab', 'The Regretful Life of Richard Bell', 'Richard Bell is an old, bitter man. He once had everything–money, a family, prestige, a place in the community–until he frittered it all away. Now, he knows it is too late to change things. He can barely walk and manages to hurt himself badly while sleeping. With those limitations, how can he fix the lamentable situation he''s made of his life? But this is Middle Falls, where everyone gets a second chance. The Regretful Life of Richard Bell is the sixteenth book in the Middle Falls Time Travel Series. Like all Middle Falls stories, it can be read as a standalone novel, or as part of the series.', 'An old, bitter Richard Bell gets a second chance to fix his regrets in a time travel tale of redemption.', 2022, NULL, NULL, 331, NULL, NULL, 'https://covers.openlibrary.org/b/id/13147100-L.jpg', '/works/OL34304772W', NULL, 'August 24, 2022', 'English', NULL, 1, 0, 'the-regretful-life-of-richard-bell-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:18', '2026-03-22 04:16:07');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d2ebc915-bda8-4877-a232-bc3ff2a4d2f1', 'The Encore Lives of Effie Edenson', 'Effie Edenson is many things: a bestselling author, a runaway bride, a woman who cannot see the gifts she possesses. Though she is an adult, her mother dominates her life to a point that she feels she will never be able to break free. But Effie lives in Middle Falls, where all things are possible.', 'Effie Edenson, a bestselling author, seeks second chances in Middle Falls, Oregon, through time travel and life lessons.', 2022, NULL, NULL, 322, NULL, NULL, 'https://covers.openlibrary.org/b/id/13145662-L.jpg', '/works/OL34304550W', NULL, 'January 30, 2022', 'English', NULL, 1, 0, 'the-encore-lives-of-effie-edenson-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:19', '2026-03-23 04:11:06');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e02e5935-3c73-4534-af87-3598ed75a8b8', 'The Alternative Lives of Aiden Anderson', 'When Aiden dies in a car crash, he couldn''t be more surprised to open his eyes in his grandmother''s kitchen in 1961. He has a second chance at everything: family, friends, and fame. Even in Middle Falls, second chances don''t always turn out right. The Alternative Lives of Aiden Anderson is the fourteenth book in the Middle Falls Time Travel series.', 'Aiden Anderson dies in a car crash and awakens in 1961 at his grandmother''s kitchen, getting a second chance at life, family, and fame in this emotional time travel tale.', 2021, NULL, NULL, 280, NULL, 692, 'https://covers.openlibrary.org/b/id/13145660-L.jpg', '/works/OL34304549W', NULL, 'June 25, 2021', 'English', NULL, 1, 0, 'the-alternative-lives-of-aiden-anderson-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:19', '2026-03-23 04:19:16');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d57f9845-bead-4543-86f7-7e105bf638eb', 'Rock ''n Roll Heaven', 'Jimmy ''Guitar'' Velvet isn''t even a has-been; he''s a never-was. After a short trip to the bottom of a river, Jimmy is about to undertake the adventure of a lifetime. The celestial bureaucracy ships him to Rock ''n Roll Heaven, where he meets the true icons of rock ''n roll—and learns that even ''heaven'' is relative. But, what impact can a small-timer like Jimmy make on the biggest stage in the universe?', 'A washed-up rock guitarist dies and journeys to Rock ''n Roll Heaven, meeting iconic musicians in a quirky afterlife tale.', 2014, '1497467268', '9781497467262', 148, NULL, NULL, 'https://covers.openlibrary.org/b/id/13123117-L.jpg', '/works/OL33277043W', NULL, 'Mar 26, 2014', 'English', NULL, 1, 0, 'rock-n-roll-heaven-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:20', '2026-03-23 04:12:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('086824a2-bf47-4ae9-964e-1c86369afd6e', 'A Lap Around America', 'Have you ever wanted to quit your job, jump in the car with the person you love the most, and see what''s around the next bend in the road? I did just that.', 'A couple embarks on a two-month road trip across the U.S., sharing lighthearted tales and vivid state-by-state insights.', 2017, '1545068151', '9781545068151', 290, NULL, 459, 'https://covers.openlibrary.org/b/id/13114347-L.jpg', '/works/OL33027534W', NULL, 'Mar 30, 2017', 'English', NULL, 0, 0, 'a-lap-around-america-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:20', '2026-03-22 03:09:44');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('635a8460-afcf-48c7-8d61-f77e2b9e60dc', 'Tribes of Kragdon-ah', 'Alex Hawk has returned victorious from Drakana. He is a hero in Kragdon-ah and he and his daughters have decided to stay there forever.

An effort is afoot to unite the far-flung tribes of Kragdon-ah and Alex''s daughters Amy and Sanda are recruited to cross the wide land to help make that happen.

Alex is forced to take another journey across the wilds of Kragdon-ah, encountering more fantastic creatures, new enemies, and old allies.', 'Alex Hawk, a hero in Kragdon-ah, journeys across wild lands facing fantastic creatures and enemies to unite tribes.', 2022, NULL, NULL, 338, NULL, NULL, 'https://covers.openlibrary.org/b/id/13028802-L.jpg', '/works/OL31693752W', NULL, 'June 6, 2022', 'English', NULL, 1, 0, 'tribes-of-kragdonah-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:21', '2026-03-22 04:09:24');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2bb03044-723c-4557-96dd-c2bd39733dbf', 'Mists of Kragdon-ah', 'Mists of Kragdon-ah tells the story of what happened to Alex, Monda-ak, Amy and Sanda, and everyone aboard The Senta-eh inside the fog. Mysterious airships, strange creatures never seen on Earth, and dangerous quests will keep you on the edge of your seat. Mists of Kragdon-ah is the sixth book in the Alex Hawk Time Travel Adventure series.', 'Alex Hawk and crew face mysterious fog, airships, and strange creatures in a thrilling time travel adventure.', 2021, NULL, NULL, 352, NULL, 590, 'https://covers.openlibrary.org/b/id/13028792-L.jpg', '/works/OL31692585W', NULL, 'November 27, 2021', 'English', NULL, 1, 0, 'mists-of-kragdonah-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:21', '2026-03-22 03:32:23');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d93b285e-feb3-4ac5-8b44-6880dfd47b86', 'Prince of Kragdon-ah', 'After twenty years away from Kragdon-ah, Alex Hawk and his daughters returned to the future in Warrior of Kragdon-ah. They found invaders with guns in great numbers. Now Alex will take the fight to the invaders in their own homeland. He will face a superior force with more advanced technology. The battle will be for the very soul of Kragdon-ah.', 'Alex Hawk returns to Kragdon-ah after 20 years, facing invaders with advanced tech in a battle for the land''s soul.', 2021, NULL, NULL, 398, NULL, 590, 'https://covers.openlibrary.org/b/id/13028784-L.jpg', '/works/OL31690973W', NULL, 'March 15, 2021', 'English', NULL, 1, 0, 'prince-of-kragdonah-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:22', '2026-03-23 04:14:36');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('bc2141d3-c189-4f2e-aabd-e0270af760fe', 'Many Short Lives of Charles Waters', 'Charles Waters has thirty days to live. Those days pass in a blur and he dies a quiet, unnoticed death. He opens his eyes back in the doctor''s office as he is told, "I''m sorry to say, but you have thirty days to live." Thus begins The Many Short Lives of Charles Waters, who has to live the same thirty days over and over while he finds out what it is to be alive.', 'Charles Waters relives his final 30 days repeatedly, seeking the meaning of life in this time travel tale.', 2019, NULL, '9781695701229', 250, NULL, 432, 'https://covers.openlibrary.org/b/id/13028948-L.jpg', '/works/OL30219518W', NULL, 'September 26, 2019', 'English', NULL, 1, 0, 'many-short-lives-of-charles-waters-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:22', '2026-03-22 05:08:56');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e9e6b93d-664a-4182-8a80-b759ad11a42b', 'Empathetic Life of Rebecca Wright', 'From the outside, Rebecca Wright had an enviable life, and she enjoyed that envy. She had a beautiful house, handsome husband, and a no-limit credit card. What she didn''t have was empathy. But, it''s never too late in Middle Falls. A lesson that isn''t learned in one lifetime can be learned in the next, or the next. Rebecca may need every chance she can get. The Empathetic Life of Rebecca Wright is the tenth novel in the Middle Falls Time Travel series.', 'Rebecca Wright, living an enviable life, lacks empathy until time travel in Middle Falls offers her multiple chances to learn and grow.', 2019, NULL, '9781099075681', 248, NULL, NULL, 'https://covers.openlibrary.org/b/id/13028876-L.jpg', '/works/OL29870704W', NULL, 'May 17, 2019', 'English', NULL, 1, 0, 'empathetic-life-of-rebecca-wright-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:23', '2026-03-23 04:26:11');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d693f85c-be95-4124-a78e-40630a2f171f', 'Vigilante Life of Scott Mckenzie', 'Scott McKenzie''s father killed his mother and himself. Scott vowed to do anything in his power to stop similar murders. He longed to be a police officer, but a tour in Vietnam in 1970 derailed that career. Two years later, wounded in body and soul, Scott died. He didn''t go on to what was next, though. Instead, he woke up with a chance to live his life over and over until he got it right. Murderers will never see him coming. But, by using violence to save others, is he losing his own soul? The Vigilante Life of Scott McKenzie is the seventh book in the Middle Falls Time Travel series.', 'Scott McKenzie, driven by personal tragedy, uses time travel to preemptively stop murderers in a violent quest for justice.', 2018, NULL, '9781723793745', 297, NULL, NULL, 'https://covers.openlibrary.org/b/id/13029599-L.jpg', '/works/OL29643050W', NULL, 'September 21, 2018', 'English', NULL, 1, 0, 'vigilante-life-of-scott-mckenzie-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:23', '2026-03-23 04:13:11');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3c4eb7ae-0827-448b-b8fa-2c18e6c23e60', 'A Lap Around Alaska', 'Part personal odyssey, part travel memoir, take an expedition into one of North America’s last remaining wildernesses. If you dream of packing up your four-wheeler, your snow boots and camera, and setting off to explore the wilderness, A Lap Around Alaska will give you a rare glimpse into the Land of the Midnight Sun, of moose, bear, and bald eagles, of monumental glaciers and scenery so staggering it brings tears to your eyes. If you hunger for adventure and want to discover untouched beauty and to experience the majesty of the pristine North for yourself—Shawn saved the passenger seat just for you.', 'Join Shawn Inmon on an epic solo road trip through Alaska''s wilderness, blending personal odyssey with stunning travel memoir.', 2017, '1973750333', '9781973750338', 232, NULL, NULL, NULL, '/works/OL29314926W', NULL, 'Jul 19, 2017', 'English', NULL, 0, 0, 'a-lap-around-alaska-shawn-inmon', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 03:12:24', '2026-03-22 03:44:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('92211aa1-4aa7-4307-8187-8b825b21aa4a', 'The Redemption of Michael Hollister', 'All Michael Hollister wanted was death. What he got was time travel. Convicted of murder, and with nothing left to live for, Michael commits suicide in his jail cell in 1977, then opens his eyes in 1966, in his eight-year-old body, all memories of his previous life intact. His first thoughts are of the dark intentions of his father. But, can he right his childhood''s greatest wrong without becoming a killer all over again? The Redemption of Michael Hollister is the second in the Middle Falls Time Travel series, but is a complete novel that can be read without having read the first book - The Unusual Second Life of Thomas Weaver.', 'A convicted murderer seeks death but gets time travel, waking in his childhood body to rewrite his dark past.', 2017, '197802844X', '9781978028449', 234, NULL, 437, 'https://covers.openlibrary.org/b/id/13029594-L.jpg', '/works/OL27692906W', NULL, 'Oct 07, 2017', 'English', NULL, 1, 0, 'the-redemption-of-michael-hollister-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:24', '2026-03-22 04:40:29');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2d595566-eb8d-492c-908f-bf147d051310', 'Lost in Kragdon-Ah', 'In "A Door Into Time," Alex Hawk stepped through a mysterious, shimmering door in his basement and found himself flung in time. He is still on Earth, but it is an earth with giant creatures and no technology. Now, Alex is called upon to rescue the young girl who is thought to be the Chosen One - the savior of Kragdon-ah.', 'Alex Hawk travels through time to a future Earth with giant creatures, tasked with rescuing the Chosen One in Kragdon-ah.', 2020, NULL, '9798660092343', 402, NULL, 691, 'https://covers.openlibrary.org/b/id/13028942-L.jpg', '/works/OL27662530W', NULL, 'June 29, 2020', 'English', NULL, 1, 0, 'lost-in-kragdonah-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:25', '2026-03-22 03:33:30');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6613cb94-7142-4832-8eb6-cd58cfcb43b4', 'Return from Kragdon-Ah', 'Alex Hawk has spent six years in Kragdon-ah. He has led armies, won battles, and seen strange and fantastic creatures. He has been continually frustrated in his efforts to return to the twenty-first century and his daughter Amy. Return from Kragdon-ah not only wraps up this epic trilogy with more surprises, twists, and turns, it will reveal whether Alex Hawk will ever make it home.', 'Alex Hawk battles in Kragdon-ah, desperate to return to the 21st century and his daughter Amy in this epic time-travel adventure.', 2020, NULL, '9798686380325', 359, NULL, 691, 'https://covers.openlibrary.org/b/id/13028975-L.jpg', '/works/OL27661582W', NULL, 'September 15, 2020', 'English', NULL, 1, 0, 'return-from-kragdonah-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:25', '2026-03-22 04:11:22');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('619bd031-5297-4bb0-b52e-75a8a8cd4b19', 'The Tribulations of Ned Summers', 'A young woman is murdered in Middle Falls, Oregon in 1952. The police never make an arrest, but the town convicts Ned Summers of the crime anyway. He banishes himself to a small house in the woods where he lives alone for the rest of his life. When he dies, he opens his eyes back in 1952, just a few days before the murder occurred. Can Ned Summers stop the murder and save his friend? The Tribulations of Ned Summers is the ninth book in the Middle Falls Time Travel series, but can be read as a standalone novel.', 'Ned Summers, accused of a 1952 murder, relives time to prevent the crime in this heartfelt time travel tale.', 2019, '179812887X', '9781798128879', 224, NULL, 344, 'https://covers.openlibrary.org/b/id/12387940-L.jpg', '/works/OL26423880W', NULL, 'Feb 26, 2019', 'English', NULL, 1, 0, 'the-tribulations-of-ned-summers-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:25', '2026-03-22 04:08:06');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('902a0656-c192-456c-aa76-a04c1194512c', 'The Death and Life of Dominick Davidner', 'How many lives would you spend to find your beloved? Dominick Davidner was murdered. Then things got worse. Instead of going on to the afterlife, Dominick found himself back in his nine year old body, all memories of his previous life intact. All he can think about is Emily, the love of his life, left behind when he died. Unfortunately, she is now thousands of miles away.', 'Dominick Davidner, murdered in a school shooting, awakens in his nine-year-old body, driven to reunite with his lost love, Emily, in this time-travel tale of tragedy and hope.', 2017, '1982082399', '9781982082390', 310, NULL, NULL, 'https://covers.openlibrary.org/b/id/12065183-L.jpg', '/works/OL26023049W', NULL, 'Dec 26, 2017', 'English', NULL, 1, 0, 'the-death-and-life-of-dominick-davidner-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:26', '2026-03-22 04:39:20');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e85cf067-6a68-49d7-b8cf-a09b86a852c0', 'A Door into Time', 'Not all guys obsess over tiny details… but Army Special Forces do. The wall just didn’t look right. Alex has been trying to cope. Life after his deployment had been rough. His ex-wife thought he needed to stop disappointing their daughter. She was right. He found a brick wall. His house wasn’t made of brick. Behind that was another just like the first. He still had time. When the second wall came down, Alex stood and stared at the shining doorway. Next to it, held up by a knife, was a note. It was a warning—and he didn’t listen. You’ll love being transported through time, to a future unlike anything we’ve imagined, where Alex’s fight to get back home becomes an epic struggle.', 'Alex Hawk, an ex-Special Forces soldier, discovers a portal to a distant, primitive future, fighting to return home in this gripping time travel adventure.', 1957, NULL, '9798638122744', 192, NULL, 614, 'https://covers.openlibrary.org/b/id/13028872-L.jpg', '/works/OL25559785W', NULL, 'March 31, 2020', 'English', NULL, 1, 0, 'a-door-into-time-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:27', '2026-03-23 04:25:08');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('59ab5f9a-3318-46c6-b3c8-f09b4576a28d', 'The Changing Lives of Joe Hart', 'When Joe Hart dies after leading a wasted life, he chooses to use his second chance to make the world better. Even when he thinks he knows what is coming, changing the past is difficult. What would you do, if you could do it all again? The Changing Lives of Joe Hart is the sixth book in the Middle Falls Time Travel series, but can be read as a standalone novel.', 'Joe Hart gets a second chance at life to change the past and save others in this time travel tale of redemption.', 2018, '1723482609', '9781723482601', 236, NULL, 1213, 'https://covers.openlibrary.org/b/id/12024581-L.jpg', '/works/OL25449364W', NULL, 'Jul 23, 2018', 'English', NULL, 1, 0, 'the-changing-lives-of-joe-hart-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:27', '2026-03-22 04:03:07');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('14e5b3e8-3ed8-4daf-8673-d4e37882bb5c', 'Life is Short', 'Thirteen stories that are just right for a lunch time read. All stories stand alone, and are complete in this volume. Sigh - A young girl must learn to survive when those around her start to die after contacting the deadly Reaper virus. Fallen - A disgraced preacher at a mega church is exiled.', 'A collection of thirteen short stories by Shawn Inmon, spanning various genres with themes of redemption and twist endings.', 2017, '1542928516', '9781542928519', 234, NULL, 399, 'https://covers.openlibrary.org/b/id/11496701-L.jpg', '/works/OL24752124W', NULL, 'Feb 04, 2017', 'English', NULL, 1, 0, 'life-is-short-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:28', '2026-03-22 03:17:52');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e7bfcf0a-d9eb-4d4f-9db6-ba3b1251d113', 'Whatever''s Written in Your Heart', NULL, 'A heartfelt true love story of childhood friends who fall in love, face obstacles, and reunite after years apart.', 2019, '1707078661', '9781707078660', 358, NULL, NULL, 'https://covers.openlibrary.org/b/id/11416972-L.jpg', '/works/OL24700410W', NULL, 'Nov 10, 2019', 'English', NULL, 0, 0, 'whatevers-written-in-your-heart-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:28', '2026-03-23 04:24:40');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b218274f-5007-4e70-9411-fdf454989cf5', 'Both Sides Now', 'Told from Dawn’s perspective, this companion memoir to Feels Like the First Time traces the same decades-long love story from the other side, revealing her struggles, loyalties, and the strength it took to risk everything when their paths finally crossed again. This true love story follows teenage Shawn and Dawn in 1970s small-town Washington, from first crush and high school dances to a painful forced breakup and, twenty-seven years later, an unexpected second shot at the life they always wanted together.', 'A true love story of Shawn and Dawn, tracing their decades-long romance from teenage years to a second chance, told from Dawn''s perspective.', 2015, '1490965920', '9781490965925', 251, NULL, 410, 'https://covers.openlibrary.org/b/id/10619288-L.jpg', '/works/OL24190542W', NULL, '2013', 'English', NULL, 0, 0, 'both-sides-now-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:29', '2026-03-22 05:02:46');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5d1e36f6-86f0-4f90-8791-542e48b05049', 'The Final Life of Nathaniel Moon', 'Nathaniel Moon is the reluctant messiah. He has powers that define the word miraculous. But when he used those powers to help others, he brought about a world of trouble. Now Nathaniel lives a life of quiet obscurity, performing anonymous miracles. But, his anonymity has to end, because evil is coming to Middle Falls, Oregon, and threatens the people Nathaniel loves most. It''s going to take a reluctant messiah to put things right.', 'Nathaniel Moon, a reluctant messiah with miraculous powers, must confront evil threatening his loved ones in Middle Falls, Oregon.', 2018, '1986488276', '9781986488273', 225, NULL, 388, 'https://covers.openlibrary.org/b/id/10516933-L.jpg', '/works/OL23611932W', NULL, 'Mar 12, 2018', 'English', NULL, 1, 0, 'the-final-life-of-nathaniel-moon-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:29', '2026-03-22 04:05:18');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f1810db0-0c44-4350-893e-53ff9ac08696', 'The Emancipation of Veronica McAllister', 'Veronica McAllister died in 2018. She immediately opened her eyes again in 1958, all memories of her previous life intact. She goes from old age, pants suits, and a cane, to poodle skirts, saddle shoes, and Buddy Holly. At the end of her first life, Veronica said she ''wasn’t any good at life.'' With the most precious of gifts—perspective and a second chance, can she succeed where she failed during her first life? What would you do, if you could do it all again? The Emancipation of Veronica McAllister is the fifth book in the Middle Falls Time Travel series.', 'Veronica McAllister dies in 2018 and awakens in 1958 with her memories intact, seeking redemption in a second chance at life.', 2018, '1719491887', '9781719491884', 280, NULL, 1213, 'https://covers.openlibrary.org/b/id/10515439-L.jpg', '/works/OL23588451W', NULL, 'May 21, 2018', 'English', NULL, 1, 0, 'the-emancipation-of-veronica-mcallister-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:30', '2026-03-23 04:30:52');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('79baacaa-cce7-4d17-8124-574b66101074', 'The Reset Life of Cassandra Collins', 'Cassandra Collins is forced to make a choice. Do what she''s told and have a safe, protected life. Or, strike out on her own and make her own way. Cassandra chooses the easy path and regrets it her whole life. Until she dies and wakes up in her eighteen year old body, on the cusp of that same decision. What would you do, if you could do it all again? The Reset Life of Cassandra Collins is the eighth book in the Middle Falls Time Travel series, but can be read as a standalone novel.', 'Cassandra Collins gets a second chance at life, waking in her 18-year-old body to redo a pivotal choice in this time travel tale.', 2018, '179167089X', '9781791670894', 274, NULL, NULL, 'https://covers.openlibrary.org/b/id/10149565-L.jpg', '/works/OL20841141W', NULL, 'Dec 13, 2018', 'English', NULL, 1, 0, 'the-reset-life-of-cassandra-collins-shawn-inmon', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 03:12:30', '2026-03-22 04:24:00');
