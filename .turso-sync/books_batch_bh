INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('385ab77d-8f61-449b-b980-4807b1c7a92f', 'Motheater', 'In this nuanced queer fantasy set amid the Appalachian Mountains in Virginia, the last witch of the Ridge must choose sides in a clash between industry and nature.

After her best friend dies in a coal mine, Benethea “Bennie” Mattox sacrifices her job, her relationship, and her reputation to uncover what’s killing miners on Kire Mountain. When she finds a half-drowned white woman in a dirty mine slough, Bennie takes her in because it’s right—but also because she hopes this odd, magnetic stranger can lead her to the proof she needs. Instead, she brings more questions. The woman called Motheater can’t remember her true name, or how she ended up inside the mountain. She knows only that she’s a witch of Appalachia, bound to tor and holler, possum and snake, with power in her hands and Scripture on her tongue. But the mystery of her fate, her doomed quest to keep industry off Kire Mountain, and the promises she bent and broke have followed her a century and half into the future. And now, the choices Motheater and Bennie make together could change the face of the town itself.', 'A queer fantasy in Appalachian Virginia, where a witch and a miner confront industry, magic, and past promises.', 2025, NULL, '9781645661795', 416, NULL, NULL, 'https://books.google.com/books/content?id=l2IDEQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', NULL, NULL, NULL, 'English', NULL, 1, 0, 'motheater-linda-h-codega', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-20 15:49:51', '2026-03-20T15:50:04.293Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0fc0ba36-c9d1-4c8a-9a9d-48929447fda7', 'The Sabbat Worlds Crusade', 'An in-depth background book about the Sabbat Worlds Crusade, the war-torn backdrop to the hit Gaunt''s Ghosts novel series and a much-loved topic of our SF fans. It is presented as an authentic document, and examines the subject in all its grim detail.', 'A detailed background on the Sabbat Worlds Crusade, a vast war in the Warhammer 40,000 universe, chronicling epic battles and key figures.', 2005, '1844162494', '9781844162499', 96, NULL, 818, 'https://covers.openlibrary.org/b/id/894685-L.jpg', '/works/OL5843418W', NULL, 'November 15, 2005', 'English', NULL, 1, 0, 'the-sabbat-worlds-crusade-dan-abnett', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 15:53:47', '2026-03-22 03:14:32');
