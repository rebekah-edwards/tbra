INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4cc8b32b-ebb8-4389-a7c2-36c471e79791', 'Binary', 'Now, after hacking a government computer for secret files and stealing a shipment of VZ nerve gas, a binary agent, Wright has gathered everything he needs to unleash mass destruction on a million people—including the US president. As the clock winds down, Wright and Agent Graves play a high-stakes game of cat-and-mouse with the fate of the government and a million innocent people hanging in the balance.', 'A federal agent races against time to stop a deadly nerve gas attack in Los Angeles in this tense techno-thriller.', 1989, NULL, '9781306605595', 221, NULL, 306, NULL, '/works/OL38606307W', NULL, '2013', 'English', NULL, 1, 0, 'binary-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:31', '2026-03-22 03:54:56');
