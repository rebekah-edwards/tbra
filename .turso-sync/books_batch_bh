INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d639d820-5951-4978-869a-598c4949528a', 'Zero Cool', 'From the creator of Jurassic Park and ER For American radiologist Peter Ross, it sounded like the perfect vacation: deliver one study in Spain and then spend the rest of his time on a Mediterranean beach. But he wasn''t planning on meeting Angela Locke, a dark-haired beauty with a big problem-she''s on the run from two warring gangs, each dead set on finding a mysterious artifact, and they''ll kill anyone who stands in their way.', 'An American radiologist''s vacation in Spain turns deadly as he’s entangled with gangs hunting a mysterious artifact.', 2013, NULL, '9781453299265', 192, NULL, 305, NULL, '/works/OL38606841W', NULL, '2013', 'English', NULL, 1, 0, 'zero-cool-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:30', '2026-03-23 04:12:58');
