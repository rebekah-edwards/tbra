INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9ab689ff-c66a-4f6a-894c-78d1caa1824b', 'Seize the Day', 'Fading charmer Tommy Wilhelm has reached his day of reckoning and is scared. In his forties, he still retains a boyish impetuousness that has brought him to the brink of chaos: he is separated from his wife and children; at odds with his vain, successful father; and has invested the last of his savings in the commodities market on the advice of Dr. Tamkin, whose blunt philosophizing about living in modern times provides the core of this short novel.', 'Tommy Wilhelm, a failing man in modern America, faces personal and financial ruin in this dark comedy novella.', 1956, NULL, NULL, 118, NULL, NULL, 'https://covers.openlibrary.org/b/id/11711336-L.jpg', '/works/OL24681425W', NULL, '1956', 'English', NULL, 1, 0, 'seize-the-day', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 04:18:45', '2026-03-22 04:45:50');
