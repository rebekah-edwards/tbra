INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7d62d26d-0132-4396-b317-fcaeb7873324', 'Sekret', 'Yulia quickly realizes she can trust no one--not her KGB superiors or the other operatives vying for her attention--and must rely on her own wits and skills to survive in this world where no SEKRET can stay hidden for long.', 'A YA thriller set in 1960s Soviet Russia, where psychic teens are forced to spy for the KGB.', 2014, '1596438924', '9781596438934', 352, NULL, NULL, 'https://covers.openlibrary.org/b/id/9345173-L.jpg', '/works/OL20675218W', NULL, '2014', 'English', NULL, 1, 0, 'sekret-lindsay-smith', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 16:01:15', '2026-03-22 04:26:14');
