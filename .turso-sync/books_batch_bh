INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('53d8eac8-406b-4dd7-ab91-a2564d0cda48', 'Eruption', 'As the Big Island of Hawaii faces an eruption of unprecedented intensity, the U.S. military contends with the consequences of a long-held doomsday secret in this thriller.

The master of the techno-blockbuster joins forces with the master of the modern thriller. Eruption is the passion project Michael Crichton, creator of Jurassic Park, ER, Twister, and Westworld, had been pursuing for years ahead of his untimely passing in 2008.

After discovering his notes and the partial manuscript, his wife, Sherri Crichton, searched for more than a decade until she found the perfect partner: James Patterson, the world’s most popular storyteller.', 'A massive volcanic eruption threatens Hawaii''s Big Island, while a military secret could escalate the disaster worldwide in this gripping thriller.', 2024, '0316577847', '9798889697428', 448, NULL, 615, 'https://covers.openlibrary.org/b/id/14605218-L.jpg', '/works/OL37616158W', NULL, '2024-06-03', 'English', 'Little, Brown and Company', 1, 0, 'eruption-michael-crichton', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 02:55:21', '2026-03-21 03:53:31');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('70cf04b5-5139-4dfd-87d0-1a76c97f4bfc', 'Five Patient', 'In this incisive, detailed survey of five patients, famous thriller author and doctor Michael Crichton explores the dramatic workings of Massachusetts General Hospital, Boston’s oldest and most prestigious. This readable account covers not only the history of the hospital’s place in society, but also the personal experiences of the patients and the evolving landscape of healthcare.', 'A non-fiction exploration of hospital life through five patients at Massachusetts General Hospital, blending real cases with medical history and future predictions.', 1970, NULL, NULL, 262, NULL, NULL, NULL, '/works/OL43200951W', NULL, '1970', 'English', NULL, 0, 0, 'five-patient-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:24', '2026-03-22 04:18:09');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8d0035be-874e-4a16-8ede-30028c94d613', 'Disclosure', 'A brutal struggle in the cutthroat computer industry; a shattering psychological game of cat and mouse; an accusation of sexual harassment that threatens to derail a brilliant career...this is the electrifying core of Michael Crichton''s new novel.', 'A tech executive faces a sexual harassment scandal in this intense corporate thriller.', 1993, NULL, NULL, 422, NULL, 243, 'https://covers.openlibrary.org/b/id/14896975-L.jpg', '/works/OL43182149W', NULL, '1993', 'English', NULL, 1, 0, 'disclosure-michael-crichton', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 02:55:24', '2026-03-22 04:37:01');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('12b6a250-3f27-4fae-9eeb-3d8a114ed5ec', 'Congo', 'Deep in the African rain forest, near the legendary ruins of the Lost City of Zinj, an expedition of eight American geologists are mysteriously and brutally killed in a matter of minutes. Ten thousand miles away, Karen Ross, the Congo Project Supervisor, watches a gruesome video transmission of the aftermath: a camp destroyed, tents crushed and torn, equipment scattered in the mud alongside dead bodies—all motionless except for one moving image of a strange blurred figure. In San Francisco, primatologist Peter Elliot works with Amy, a gorilla with a 620-sign vocabulary and a fondness for finger painting. When Amy begins to have nightmares about a place she''s never been—a jungle with a huge black mountain—she signs her desire to go there. ERTS, a high-tech company, dispatches Karen Ross to find a rare blue diamond in the Congo, and Peter and Amy join the expedition. But they soon discover that something ancient and evil haunts the jungle—a deadly force that wipes out previous expeditions and threatens their lives.', 'A thrilling expedition into the Congo jungle uncovers a lost city and deadly secrets. Michael Crichton''s adventure blends science and suspense.', 1980, NULL, NULL, 326, NULL, 616, NULL, '/works/OL43092923W', NULL, '1980', 'English', NULL, 1, 0, 'congo-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:25', '2026-03-22 03:16:18');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1045ffbb-6288-423f-8d20-2a4c8979e45a', 'Timeline', 'Not since Jurassic Park has Michael Crichton given us such a magnificent adventure. Here, he combines a science of the future -- the emerging field of quantum technology -- with the complex realities of the medieval past. In a heart-stopping narrative, Timeline carries us into a realm of unexpected suspense and danger, overturning our most basic ideas of what is possible.', 'A group of history students time-travels to 14th-century France to rescue their professor in this thrilling sci-fi adventure.', 2000, NULL, NULL, 468, NULL, 361, NULL, '/works/OL43044063W', NULL, '2000', 'English', NULL, 1, 0, 'timeline-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:25', '2026-03-22 03:14:52');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c0ed3c5f-55a2-49b2-a441-dd70641c7aed', 'Andromeda Strain', 'The United States government is given a warning by the pre-eminent biophysicists in the country: current sterilization procedures applied to returning space probes may be inadequate to guarantee uncontaminated re-entry to the atmosphere.', 'A deadly extraterrestrial microorganism outbreaks in Arizona, as scientists race to contain the threat in a gripping technothriller.', 1969, NULL, NULL, 295, NULL, 495, NULL, '/works/OL42982415W', NULL, '1969', 'English', NULL, 1, 0, 'andromeda-strain-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:26', '2026-03-22 05:12:04');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6bf4691d-1ea2-453f-88c2-771b9093b322', 'The Great Train Robbery', 'In teeming Victorian London, where lavish wealth and appalling poverty live side by side, Edward Pierce charms the most prominent of the well-to-do as he cunningly orchestrates the crime of the century. Who would suspect that a gentleman of breeding could mastermind the extraordinary robbery aboard the pride of England’s industrial era, the mighty steam locomotive? Based on fact, but studded with all the suspense and style of fiction, here is a classic historical thriller, set a decade before the age of dynamite—yet nonetheless explosive…', 'A cunning gentleman orchestrates a daring gold heist in Victorian London, blending historical fact with thrilling fiction.', 1994, '061312703X', '9780613127035', NULL, NULL, 519, NULL, '/works/OL39556791W', NULL, '1994-01-', 'English', NULL, 1, 0, 'the-great-train-robbery-michael-crichton', 0, NULL, NULL, 0, NULL, 'public', '2026-03-20 02:55:27', '2026-03-22 04:14:46');
