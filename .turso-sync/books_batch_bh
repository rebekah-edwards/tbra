INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('add7e720-f7da-48d4-9a17-cf9456133f4a', 'Lawless', 'It took me a while to get into Lawless but I adore it now. I''m not usually a fan of sci-fi westerns but this one is fantastic. Abnett is highly experienced at writing for sci-fi franchises, which is no doubt why his writing is consistent with the Dreddverse, yet he''s also unafraid of putting his own spin on it. And Phil Winslade''s art is just *chef''s kiss*. Set in a frontier town on a planet owned by Mega City One, newly-appointed Colonial Marshal Lawson keeps the peace between various factions, while dealing with the shady corporation which effectively runs things.', 'A sci-fi western in the Judge Dredd universe, following Marshal Metta Lawson as she keeps peace in the frontier town of Badrock.', 2017, '1781085439', '9781781085431', NULL, NULL, NULL, 'https://books.google.com/books/content?id=klZrAQAACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL25745006W', NULL, '2017', 'English', NULL, 1, 0, 'lawless-dan-abnett', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-20 15:45:50', '2026-03-22 04:59:56');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e9d35702-6e45-4ea6-ab0e-d2bc8e0b7054', 'Lawless Book Four', 'And when a caravan of settlers is brutally slaughtered, it''ll take all that Colonial Marshal Metta Lawson has to stop an outright war. Dan Abnett (Aquaman, Guardians of the Galaxy) and Phil Winslade''s (Howard the Duck, Wonder Woman) frontier epic Lawless continues in this fourth action packed volume, which includes the all singin'', all dancin'', Lawless the Musical!', 'A sci-fi western on a backwater planet, where Marshal Metta Lawson fights to prevent war after a brutal settler massacre.', 2022, '1786185261', '9781786185266', NULL, NULL, NULL, 'https://books.google.com/books/content?id=nGPLzgEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL27087809W', NULL, '2022', 'English', NULL, 1, 0, 'lawless-book-four-dan-abnett', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-20 15:45:51', '2026-03-23 04:26:09');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2e8812c5-4033-46c1-89c7-877459fae2cc', 'The Horus Heresy', 'When Horus rebelled against the Emperor, the ensuing civil war nearly destroyed the Imperium. War raged across galaxy, resulting in a struggle where death was the only victor. Events from the Great Crusade and the early days of the Heresy are explored in a series of short stories covering the Space Wolves, Word Bearers, World Eaters, Dark Angels, Sisters of Silence, Custodian Guard...and the Emperor himself in a unique tale that will have you questioning all your assumptions about the Master of Mankind.', 'An anthology of short stories set in the Warhammer 40k universe, exploring the Horus Heresy’s galaxy-wide civil war and themes of loyalty and betrayal.', 2012, '1849701342', '9781849701341', 1, NULL, 734, 'https://covers.openlibrary.org/b/id/10465909-L.jpg', '/works/OL22451432W', NULL, 'Mar 01, 2012', 'English', NULL, 1, 1, 'the-horus-heresy-dan-abnett', 1, 'openlibrary', NULL, 0, NULL, 'import_only', '2026-03-20 15:47:00', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7f274e97-f5a3-4d63-b936-7c6b1687331d', 'Rocket Raccoon and Groot', 'Marvel''s first original prose novel, featuring the stars of Guardians of the Galaxy! These are not the Avengers or the Fantastic Four--in fact, they''re barely even famous--but Rocket Raccoon and the faithful Groot are the baddest heroes in the cosmos, and they''re on the run across the Marvel Universe! During a spaceport brawl, the infamous pair rescues an android Recorder from a pack of alien Badoons. Everyone in the galaxy, however, including the ruthless Kree Empire and the stalwart Nova Corps, seems to want that Recorder, who''s about as sane as a sandwich with no mustard. Join Rocket and Groot on a free-for-all across the stars while they try to save all of existence--again!', 'Rocket Raccoon and Groot, the baddest heroes in the cosmos, are on the run across the Marvel Universe in a wild, action-packed sci-fi adventure.', 2014, '0785189777', '9780785189770', 359, NULL, 403, 'https://covers.openlibrary.org/b/id/10216795-L.jpg', '/works/OL20887936W', NULL, '2014', 'English', NULL, 1, 0, 'rocket-raccoon-and-groot-dan-abnett', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 15:47:10', '2026-03-22 04:27:29');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0f2d10d6-f127-421a-934f-596525963eef', 'Groot', 'Monster, hero, Guardian: Groot! Before he was a Guardian of the Galaxy - before the Grootfall - young Groot lived a life of tranquility on his serene homeworld, Planet X. But when monstrous invaders attack his world, this courageous sapling ...', 'Explore Groot''s origin on Planet X, a young sapling facing monstrous invaders in an epic cosmic adventure.', 2023, '1302953184', '9781302953188', NULL, NULL, NULL, 'https://books.google.com/books/content?id=v8-izwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL35780501W', NULL, '2023', 'English', NULL, 1, 0, 'groot-dan-abnett', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-20 15:47:11', '2026-03-22 03:14:08');
