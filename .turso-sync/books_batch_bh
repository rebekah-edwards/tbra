INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('51b7ffa4-6bf1-42aa-b227-ce6e3926068a', 'Science Fiction Masterpieces', 'Stories like The Coldest Place, Becalmed in Hell, Neutron Star, and All the Myriad Ways set the boundaries for Known Space, one of science fiction''s grandest future histories, while Niven also explored the classic tavern story in his Draco''s Tavern sequence and even fantasy in his Magic Goes Away stories. Astoundingly, there has never been a single compendium that focused solely on Niven''s best short fiction until now. The Best of Larry Niven collects no less than twenty-seven stories written over a period of thirty-five years, bringing together some of the best-loved stories in science fiction for the first time, along with some overlooked classics.', 'A collection of Larry Niven''s finest science fiction stories, exploring grand future histories and unexpected twists.', 1993, '0883657139', '9780883657133', 633, NULL, 3000, 'https://covers.openlibrary.org/b/id/14613052-L.jpg', '/works/OL20654653W', NULL, '1993', 'English', NULL, 1, 0, 'science-fiction-masterpieces-larry-niven', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-20 04:17:39', '2026-03-22 03:58:06');
