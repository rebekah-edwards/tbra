INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4437240d-0c7e-4dfc-94a6-92fc4858c043', 'The Family Upstairs', 'Soon after her twenty-fifth birthday, Libby Jones returns home from work to find the letter she’s been waiting for her entire life. She rips it open with one driving thought: I am finally going to know who I am. She learns she has inherited a house in one of London’s most expensive areas. But everything in the house suggests a dark history. What happened here? And who has been waiting for Libby to return?', 'A dark thriller about Libby Jones uncovering chilling family secrets tied to a mysterious house. A suspenseful, disturbing read.', 2023, '1668026511', '9781668026519', 400, NULL, 576, 'https://covers.openlibrary.org/b/id/13453905-L.jpg', '/works/OL34738771W', NULL, 'Sep 26, 2023', 'English', NULL, 1, 0, 'the-family-upstairs-lisa-jewell', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:46:53', '2026-03-22 03:48:53');
