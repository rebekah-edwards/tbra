INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7f74c249-9c39-490e-b8e4-68892ae67cf9', 'Hell', 'We live in age when the fear of hell no longer holds sway in society and even in the church the subject is so rarely mooted it seems almost taboo. The reason for that, it is argued, is fundamentally the consequence of evolution becoming the accepted explanation for the origin of our existence: by undermining the biblical explanation for Creation it has undermined the whole.', 'A thought-provoking exploration of Hell''s reality, challenging beliefs about judgment and faith.', 2013, NULL, '9781492920236', 78, NULL, NULL, 'https://books.google.com/books/content?id=MeEeEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL41875612W', NULL, '2013', 'English', NULL, 0, 0, 'hell-k-j-parker', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:48:51', '2026-03-22 04:27:52');
