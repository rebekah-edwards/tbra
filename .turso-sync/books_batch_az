INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('100e919c-ee29-4dc3-b62f-53ae26ccc67f', 'Iron Gustav', 'A powerful story of the shattering effects of the First World War on both a family and a country - from Hans Fallada, bestselling author of Alone in Berlin. ''This remarkable work, now complete after 76 years, could well be one of the finest novels any of us will ever read'' Irish Times. Gustav Hackendahl''s will is law. Known as ''Iron Gustav'', he runs his family and his Berlin carriage business with stern, unyielding discipline. As war breaks out and Gustav''s beloved Germany is devastated by hardship and violence, he finds everything he believes in destroyed. Can the man of iron endure, or even change? Brutal and moving, written with Hans Fallada''s gift for capturing the small tragedies of ordinary lives, Iron Gustav is a heartbreaking family chronicle and an unflinching portrayal of the First World War and its aftermath.', 'A Berlin coachman, Iron Gustav, faces family and national devastation during and after World War I in this brutal, moving chronicle.', 2014, NULL, '9780141968087', NULL, NULL, NULL, 'https://books.google.com/books/content?id=LNKJAgAAQBAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL28349349W', NULL, '2014', 'English', 'Penguin Books, Limited', 1, 0, 'iron-gustav-hans-fallada', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:45:06', '2026-03-22 03:14:46');
