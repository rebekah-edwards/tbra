INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('43ea1bf3-6f8a-4c51-853c-bb2a7bed8957', 'Saevus Corax Captures the Castle', 'From one of the most original voices in fantasy comes a heroic tale of honor, friendship, and battlefield salvage. It’s important to look after your crew when you’re in the battlefield salvage business. It’s stressful work at the best of times, and although your employees are unlikely to be happy it makes sense to keep them alive. So when Saevus Corax finds himself having to capture a castle to stop his men from being killed, he has no choice but to give it a try. Needless to say, the conventional rules of siegecraft are unlikely to be followed.', 'Saevus Corax, a battlefield salvager, must capture a castle to save his crew in this witty, unconventional fantasy tale.', 2023, NULL, '9780316668958', NULL, NULL, NULL, 'https://books.google.com/books/content?id=CwWyEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL35744936W', NULL, '2023', 'English', NULL, 1, 0, 'saevus-corax-captures-the-castle-k-j-parker', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:48:58', '2026-03-22 03:48:44');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('19236e7b-df1a-4225-af49-ca908ffd224d', 'Under My Skin', 'Under My Skin, K.J. Parker’s superb new collection, includes almost 700 pages of novelettes and novellas, some appearing here for the first time anywhere, with one completely new novel-length tale, Relics. These stories are everything readers have come to expect from Parker, populated by con men and kings, magicians who don’t do magic and messiahs who don’t offer redemption, by holy men and holy fools. But be warned, not only is all perhaps not what it seems, all can usually be counted on to not be what it seems.', 'A collection of dark, cynical fantasy novellas and novelettes by K.J. Parker, featuring con men, kings, and tricky sorcerers in a medieval-inspired world.', 2023, '1645240797', '9781645240792', 680, NULL, NULL, 'https://books.google.com/books/content?id=nPGLzwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL34952543W', NULL, 'Mar 01, 2023', 'English', NULL, 1, 0, 'under-my-skin-k-j-parker', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:48:59', '2026-03-22 03:20:33');
