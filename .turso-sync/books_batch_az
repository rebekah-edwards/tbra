INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3a03bc6c-15ec-4bce-9cad-d21c4ccbeca4', 'Let in the Light', 'Do you need light for your path and hope for the dark times? No matter what you face today, it''s possible to encounter the power of God''s light even in dark and difficult seasons. From the Proverbs 31 Ministry team, including Joel Mudamalle, Alicia Britt Chole, and Asheritah Ciuciu (and many more!) comes Let In the Light: 50 Devotions to Confidently Know God is Good and Guiding Your Steps, a devotional to lead you into the light of God''s Word and presence. Friend, we were never meant to walk in darkness.', 'A devotional book with 50 entries to inspire hope and trust in God''s guidance during dark times.', 2025, NULL, '9781400253746', 208, NULL, NULL, NULL, '/works/OL44587075W', NULL, '2025', 'English', 'Nelson Incorporated, Thomas', 0, 0, 'let-in-the-light-lysa-terkeurst', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:49:03', '2026-03-22 03:42:34');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c2dcbece-25c1-498d-847f-48265883c610', 'Burning Books for Pleasure and Profit', NULL, 'A skilled bookbinder in a post-war society is coerced into forging a manuscript that could expose religious lies and dismantle the power structures built on them.', 2023, NULL, '9781250874979', NULL, NULL, NULL, 'https://books.google.com/books/content?id=bDSnEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL34425802W', NULL, '2023', 'English', NULL, 1, 0, 'burning-books-for-pleasure-and-profit-k-j-parker', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:49:04', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2c2c4e8f-e07a-421d-941b-8db7d0e04f3e', 'Aurora', 'In Aurora, Illinois, Aubrey Wheeler is just trying to get by after her semi-criminal ex-husband split, leaving behind his unruly teenage son.

Then the lights go out--not just in Aurora but across the globe. A solar storm has knocked out power almost everywhere. Suddenly, all problems are local, very local, and Aubrey must assume the mantle of fierce protector of her suburban neighborhood.

Across the country lives Aubrey''s estranged brother, Thom. A fantastically wealthy, neurotically over-prepared Silicon Valley CEO, he plans to ride out the crisis in a gilded desert bunker he built for maximum comfort and security.

But the complicated history between the siblings is far from over, and what feels like the end of the world is just the beginning of several long-overdue reckonings--which not everyone will survive . . .', 'A massive solar storm triggers a global blackout, forcing Aubrey Wheeler to safeguard her stepson in suburban Aurora amid societal collapse.', NULL, NULL, '9780062916471', 539, NULL, 546, 'https://covers.openlibrary.org/b/id/12773993-L.jpg', '/works/OL25812001W', NULL, 'June 1, 2022', 'English', NULL, 1, 0, 'aurora-david-koepp', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:49:04', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('42c53d62-3aa3-410a-8893-4e8b4c7ba7ec', 'Surviving an Unwanted Divorce', 'A Failed Marriage Doesn’t Make You a Failure in God’s Eyes. When Lysa TerKeurst experienced the painful and unwanted death of her marriage after nearly thirty years, she didn’t know who to turn to or what would actually help her. She needed to get her bearings on what the Bible really says about marriage and divorce. She also needed the tools to work through the fallout she was walking through.', 'A biblical guide to healing from unwanted divorce, blending personal experience with practical and theological insights.', 2025, NULL, '9781400250127', 160, NULL, NULL, 'https://books.google.com/books/content?id=AmZOEQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL44582337W', NULL, '2025', 'English', 'Nelson Incorporated, Thomas', 0, 0, 'surviving-an-unwanted-divorce-lysa-terkeurst', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:49:04', '2026-03-22 03:48:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d1f5e1a7-bf29-41f1-9cfc-a72672e22b6a', 'Chocolate Cream Pie Murder', 'Not even Lake Eden''s nosiest residents suspected Hannah Swensen would go from idealistic newlywed to betrayed wife in a matter of weeks. But as a deadly mystery unfolds in town, the proof is in the pudding...

When The Cookie Jar becomes the setting of a star-studded TV special about movies filmed in Minnesota, Hannah hopes to shine the spotlight on her bakery -- not the unsavory scandal swirling around her personal life. But that''s practically impossible with a disturbing visit from the shifty character she once believed was her one and only love, a group of bodyguards following her every move, and a murder victim in her bedroom. Now, swapping the crime scene in her condo for her mother Delores''s penthouse, Hannah and an old flame team up to solve a case that''s messier than an upended chocolate cream pie. As suspects emerge and secrets hit close to home, Hannah must serve a hefty helping of justice to an unnamed killer prowling around Lake Eden ... before someone takes a slice out of her!', 'Bakery owner Hannah Swensen returns to snowy Lake Eden, Minnesota, only to find her fraudulent ex-husband murdered in her bedroom.', 2020, '1496718879', '9781496718877', 400, NULL, 573, 'https://covers.openlibrary.org/b/id/8803829-L.jpg', '/works/OL20158719W', NULL, 'Jan 28, 2020', 'English', NULL, 1, 0, 'chocolate-cream-pie-murder-joanne-fluke', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:49:05', '2026-03-23 04:10:32');
