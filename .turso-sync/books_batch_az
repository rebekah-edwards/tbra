INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f7b3ec56-b040-450a-a1aa-2018e33212d1', 'The Familiar, Volume 2: Into the Forest', 'From the universally acclaimed, genre-busting author of House of Leaves comes the second volume of The Familiar, a novel which goes beyond the experimental into the visionary, creating a language and style that expands the horizon of meaning. In The Familiar, Volume 2: Into the Forest, the lives of the disparate and dynamic nine characters introduced in One Rainy Day in May begin to intersect in inexplicable ways, finding harmonies and echoes in each other.', 'The second volume of a genre-busting series, following nine characters whose lives intersect in mysterious ways.', 2015, '0375714979', '9780375714979', 880, NULL, NULL, 'https://covers.openlibrary.org/b/id/8409203-L.jpg', '/works/OL19091395W', NULL, 'Oct 27, 2015', 'English', NULL, 1, 0, 'the-familiar-volume-2-into-the-forest-mark-z-danielewski', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:46', '2026-03-23 04:35:18');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a3e846c8-e724-422c-8853-fe324bdc6312', 'Exhalation', 'In Exhalation, Ted Chiang addresses the most fundamental of issues – What is the nature of the universe? A portal through time forces a fabric-seller in ancient Baghdad to grapple with past errors and the temptation of second chances; an alien scientist makes a shocking discovery with ramifications not just for his own people, but for all of reality; a newfound ability to glimpse into alternate universes forces a radical re-examination of the concepts of choice and free will.', 'A collection of nine profound sci-fi stories by Ted Chiang, exploring humanity, technology, and the universe.', 2020, '8381168732', '9788381168731', 400, NULL, 682, 'https://covers.openlibrary.org/b/id/8793546-L.jpg', '/works/OL20149336W', NULL, 'May 06, 2020', 'English', NULL, 1, 0, 'exhalation-ted-chiang', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:47', '2026-03-22 04:52:44');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a934e156-6083-434e-9272-9b857d4ae6a0', 'The Familiar, Volume 1: One Rainy Day in May', 'From the author of the international best seller House of Leaves and National Book Award–nominated Only Revolutions comes a monumental new novel as dazzling as it is riveting. The Familiar (Volume 1) ranges from Mexico to Southeast Asia, from Venice, Italy, to Venice, California, with nine lives hanging in the balance, each called upon to make a terrifying choice.', 'A sprawling novel following nine interconnected lives on one rainy day in May, blending experimental design with suspense across global settings.', 2015, '0375714952', '9780375714955', 880, NULL, NULL, 'https://covers.openlibrary.org/b/id/8409202-L.jpg', '/works/OL19091393W', NULL, 'May 12, 2015', 'English', NULL, 1, 0, 'the-familiar-volume-1-one-rainy-day-in-may-mark-z-danielewski', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:48', '2026-03-22 04:56:37');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c9d6477c-d307-4f61-adfc-89cbc5089019', 'City of Illusions', 'He was a fully grown man, alone in dense forest, with no trail to show where he had come from and no memory to tell who — or what — he was.
His eyes were not the eyes of a human.
The forest people took him in and raised him almost as a child, teaching him to speak, training him in forest lore, giving him all the knowledge they had. But they could not solve the riddle of his past, and at last he had to set out on a perilous quest to Es Toch, the City of the Shining, the Liars of Earth, the Enemy of Mankind.
