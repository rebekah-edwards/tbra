INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6b7dbb35-c315-4f4c-b14d-260f3442756d', 'Female of the Species', 'Alex Craft knows how to kill someone. And she doesn t feel bad about it. When her older sister, Anna, was murdered three years ago and the killer walked free, Alex uncaged the language she knows best. The language of violence.', 'A dark YA novel about Alex Craft, a teen seeking violent justice after her sister''s murder, exploring rape culture and revenge.', 2017, '0606403981', '9780606403986', 368, NULL, NULL, 'https://covers.openlibrary.org/b/id/13277695-L.jpg', '/works/OL20037215W', NULL, 'Sep 05, 2017', 'English', NULL, 1, 0, 'female-of-the-species-mindy-mcginnis', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:21', '2026-03-22 04:14:28');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a61b35c1-562a-471c-bea5-1c2e170f5c78', 'Hoax for Hire', 'But when things go disastrously wrong and Dad and Gramps go missing, Grayson and his brother, Curtis, are the only people who can finish the job and save their family. ''The author piles hoaxes atop hoaxes on the way to a climactic end. The McNeil motto, "Keep the Legends Alive," takes on new meaning for Grayson, as it will for readers.'' — ALA Booklist', 'Grayson McNeil hails from a family of professional hoaxers staging cryptid sightings like Bigfoot and Loch Ness Monster for profit.', 2019, '0062803808', '9780062803801', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/9104330-L.jpg', '/works/OL20438022W', NULL, '2019', 'English', NULL, 1, 0, 'hoax-for-hire-laura-j-martin', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:47:21', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5da29d78-c56a-4ff1-888f-2e2b20d82467', 'Earthsea & The Left Hand of Darkness', 'It tells the stories of Ged and Tenar, inhabitants of a vast archipelago where magic is part of life. Young wizard Ged releases a terrible shadow into the world and must risk everything to restore the balance.', 'Two epic tales of magic and identity: Ged battles a shadow in Earthsea, while The Left Hand of Darkness explores alien worlds.', 2016, '1785293419', '9781785293412', NULL, NULL, 325, 'https://covers.openlibrary.org/b/id/11441350-L.jpg', '/works/OL24715772W', NULL, '2016-07-07', 'English', NULL, 1, 0, 'earthsea-the-left-hand-of-darkness-ursula-k-le-guin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:22', '2026-03-22 04:05:37');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('767bd560-8a73-4326-ad82-dde2dc338a37', 'Madness So Discreet', 'Grace Mae knows madness. She keeps it locked away, along with her voice, trapped deep inside a brilliant mind that cannot forget horrific family secrets. Those secrets, along with the bulge in her belly, land her in a Boston insane asylum. When her voice returns in a burst of violence, Grace is banished to the dank basements of the institution. But gruesome nights bring Grace and a doctor into the circle of a killer who stalks young women. Grace, continuing to operate under the cloak of madness, must hunt a murderer while she confronts the demons in her own past.', 'A dark historical thriller about Grace Mae, a young woman in a 19th-century asylum, navigating madness and murder.', 2015, '0062320866', '9780062320865', 376, NULL, NULL, 'https://m.media-amazon.com/images/I/81eCN3EguJL._SL1500_.jpg', '/works/OL20009522W', NULL, '2015', 'English', NULL, 1, 0, 'madness-so-discreet-mindy-mcginnis', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:22', '2026-03-22 04:21:56');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f1002d86-23c7-4573-a199-e987d2228801', 'Aliens', 'Under the countless billions of stars in the universe, what forms will alien life take? How will they live? And what will happen when we meet them? ***Aliens: Recent Encounters*** collects answers to these questions from some of today’s best science fiction writers. From first encounters to life alongside aliens ― and stories of the aliens’ own lives ― here are many futures: violent and peaceful, star-spanning and personal. Only one thing is certain: alien life will defy our expectations.', 'A collection of eight short stories exploring alien societies to delve into human themes of gender, sexuality, love, and alienation.', 1900, '1607013916', '9781607013914', 238, NULL, NULL, 'https://covers.openlibrary.org/b/id/8578255-L.jpg', '/works/OL19756882W', NULL, '2013-06-17', 'English', NULL, 1, 0, 'aliens-ursula-k-le-guin', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:47:23', '2026-03-23 04:30:26');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('23e19fea-ceaf-47c7-9873-ad4ab52d0fc0', 'In a Handful of Dust', 'Rumors of desalinization plants in California have lingered in Lynn’s mind, and the prospect of a ''normal'' life for Lucy sets the two of them on an epic journey west to face new dangers: hunger, mountains, deserts, betrayal, and the perils of a world so vast that Lucy fears she could be lost forever, only to disappear in a handful of dust. In this companion to Not a Drop to Drink, Mindy McGinnis thrillingly combines the heart-swelling hope of a journey, the challenges of establishing your own place in the world, and the gripping physical danger of nature in a futuristic frontier.', 'A gripping post-apocalyptic journey west, as Lucy and Lynn face hunger, disease, and betrayal in a water-scarce world.', 2014, '1483028496', '9781483028491', NULL, NULL, 484, 'https://covers.openlibrary.org/b/id/14478964-L.jpg', '/works/OL19987712W', NULL, 'Sep 23, 2014', 'English', NULL, 1, 0, 'in-a-handful-of-dust-mindy-mcginnis', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:24', '2026-03-22 03:27:17');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('064e3e26-2c50-4886-94e1-afc70dbfa04e', 'Little Blue Kite', 'We all have fears, but if we can’t face the small ones how will we face the big ones? Kai is afraid to fly a little blue kite. But Kai is also very, very brave, and overcoming this small fear will lead him on a great adventure. Remember: all great adventures start with one little moment. You know the one. It’s like a gentle breeze whispering in your ear what you already know by heart: not even the sky is the limit . . .', 'Kai, a brave child, faces his fear of flying a little blue kite, embarking on a transformative adventure. A poignant all-ages tale of courage and self-confidence.', 2019, NULL, '9781524747695', 96, NULL, NULL, 'https://books.google.com/books/content?id=oV6IDwAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL21347355W', NULL, '2019', 'English', 'Knopf Doubleday Publishing Group', 1, 0, 'little-blue-kite-mark-z-danielewski', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:47:25', '2026-03-22 03:04:45');
