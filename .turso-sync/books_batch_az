INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2c499600-0a06-4057-af0f-92b474c714c0', 'Saevus Corax Gets Away with Murder', 'There are two things he has to do before he can enjoy his retirement: get away with one last score, and get away with murder. For someone who, ironically, tends to make a mess wherever he goes, leaving his affairs in order is going to be Saevus Corax’s biggest challenge yet.', 'Saevus Corax faces his toughest challenge: pulling off one last score and getting away with murder in a grim, comedic fantasy.', 2023, NULL, '9780316668989', NULL, NULL, NULL, 'https://books.google.com/books/content?id=uGC3EAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL35751233W', NULL, '2023', 'English', NULL, 1, 0, 'saevus-corax-gets-away-with-murder-k-j-parker', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:48:57', '2026-03-22 03:32:42');
