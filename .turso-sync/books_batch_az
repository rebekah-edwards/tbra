INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4af522f9-e612-4035-8f00-630df3cf0860', 'Making of Us', 'From the New York Times bestselling author of None of This Is True comes a ''compelling and heartbreaking'' (Jojo Moyes) novel about family, identity, and the secrets that bind us. In a hospice in Bury St Edmunds, a man called Daniel is slowly fading away. His friend Maggie sits with him every day; she holds his hand and she listens to the story of his life, to his regrets and to his secrets. And then he tells her about the children he has never met and never will, children who were conceived with his donated sperm. Lydia, Dean, and Robyn don''t know each other, and they don''t know Daniel, but his death will change their lives forever. Filled with heart and humor, The Making of Us raises big questions about family and fitting in.', 'A poignant tale of family secrets and identity as siblings, linked by a sperm donor father, uncover their shared past.', 2012, '0753189143', '9780753189146', 480, NULL, 835, 'https://covers.openlibrary.org/b/id/10784292-L.jpg', '/works/OL24284271W', NULL, '2012', 'English', NULL, 1, 0, 'making-of-us-lisa-jewell', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:46:45', '2026-03-22 03:53:53');
