INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('57da3506-150d-499d-8be7-89397dc6fcdd', 'The Meaning of Liff', 'In life and, indeed, in liff, there are many hundreds of common experiences, feelings, situations and even objects which we all know and recognize, but for which no words exist. This text uses place names to describe some of these meanings.', 'A humorous dictionary of invented words for common experiences, using place names for absurd definitions by Douglas Adams and John Lloyd.', 1983, '0330281216', NULL, 191, NULL, NULL, 'https://covers.openlibrary.org/b/id/15146360-L.jpg', '/works/OL2163700W', NULL, '1983', 'English', NULL, 0, 0, 'the-meaning-of-liff-douglas-adams', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:48:43', '2026-03-22 04:02:01');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('15c7733a-3d3f-4991-a4a3-72633c92f3b1', 'End Specialist', 'John Farrell is about to get ''The Cure.'' Old age can never kill him now. The only problem is, everything else still can... Imagine a near future where a cure for aging is discovered and-after much political upheaval and moral controversy-made available to the general public. The End Specialist takes these daydreams further, posing questions and dilemmas of global eternal youth and what this means for society.', 'A dystopian tale of a future where aging is cured, exploring the grim societal consequences through John Farrell''s journey. Haunting and thought-provoking.', 2011, NULL, '9780007429080', NULL, NULL, NULL, 'https://m.media-amazon.com/images/I/61oGYaCF3oL._SL1500_.jpg', '/works/OL17464648W', NULL, '2011', 'English', NULL, 1, 0, 'end-specialist-drew-magary', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:48:43', '2026-03-22 03:18:24');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a48f01f0-1ec9-4922-b27e-557471380a0c', 'Men with Balls', 'This will be the very last book you ever read. Because after you have read this book, you, Good Sir, will know how to be a pro athlete. And pro athletes don''t need books. Or strong family bonds. Or any of that stupid crap. Not when they have ready access to millions of dollars and scores of smoking hot chicks with questionable judgment.', 'A satirical guide for aspiring pro athletes, packed with crude humor and sports culture jabs.', 2008, '0316023078', '9780316023078', 280, NULL, NULL, 'https://covers.openlibrary.org/b/id/15016205-L.jpg', '/works/OL11904298W', NULL, '2008', 'English', NULL, 0, 0, 'men-with-balls-drew-magary', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:48:45', '2026-03-22 04:53:16');
