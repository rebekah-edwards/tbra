INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d2b34dd1-06f4-46bc-9b6e-0ae0d8c1938e', 'Wynn Bullock', 'In images of haunting beauty Wynn Bullock explores the ineffability of time and space, the mystery beneath the static surface of reality, and the contradictory and compelling nature of existence itself.', 'A haunting collection of photographs by Wynn Bullock exploring time, space, and the mystery of existence, with contributions by Ursula K. Le Guin.', 1999, '061392584X', '9780613925846', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/15172591-L.jpg', '/works/OL15056627W', NULL, 'May 1999', 'English', NULL, 0, 0, 'wynn-bullock-ursula-k-le-guin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:05', '2026-03-23 04:11:00');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4e2604ec-2649-4a67-a3f4-f60ba7d327f3', 'Under This Red Rock', 'Neely’s monsters don’t always follow her rules, so when the little girl under her bed, the man in her closet, and the disembodied voice that shadows her every move become louder, she knows she’s in trouble. With a history of mental illness in her family, and the suicide of her older brother heavy on her mind, Neely takes a job as a tour guide in the one place her monsters can’t follow—the caverns.', 'A teen girl battles mental illness and grief while unraveling a murder mystery in Ohio caverns.', 2024, NULL, '9780063230415', NULL, NULL, NULL, 'https://books.google.com/books/content?id=qiPGEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL37579041W', NULL, '2024', 'English', 'HarperCollins Publishers', 1, 0, 'under-this-red-rock-mindy-mcginnis', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:47:05', '2026-03-22 03:55:55');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e661359b-40ad-4596-8de6-ee3d9afb55ff', 'World''s Smartest Detectives', 'A treasure trove of mysteries drawn from the case files of the world’s cleverest private investigators. The Adventures of Sherlock Holmes features many of the consulting detective’s best-known cases. ''A Scandal in Bohemia'' finds Holmes matching wits with—and being outfoxed by—a beautiful American opera singer. A struggling shop owner stumbles into a lucrative side job, and a criminal conspiracy, in ''The Red-Headed League.'' And in ''The Adventure of the Speckled Band,'' which Arthur Conan Doyle named as the best of his Sherlock Holmes stories, our brilliant hero and his loyal friend Dr. Watson solve a chilling mystery.', 'A collection of clever detective stories featuring Sherlock Holmes and other brilliant investigators solving intricate mysteries.', 2016, NULL, '9781504038270', NULL, NULL, NULL, 'https://books.google.com/books/content?id=t605DAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL26746958W', NULL, '2016', 'English', 'MysteriousPress.com', 1, 0, 'worlds-smartest-detectives-arthur-conan-doyle', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:47:05', '2026-03-23 04:23:37');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ac82877b-fdee-4a0a-98e3-aa98cf52880c', 'Long Stretch of Bad Days', 'This gripping mystery from award-winning author Mindy McGinnis shows the power of a name and one lie and how two girls can use their voices to change a town forever. Lydia Chass doesn’t mind living in a small town; she just doesn’t want to die in one. A lifetime of hard work has put her on track to attend a prestigious journalism program and leave Henley behind—until a school error leaves her a credit short of graduating.', 'A gripping YA mystery about two teen girls uncovering small-town secrets through a podcast, facing escalating threats.', 2023, NULL, '9780063230361', 368, NULL, NULL, 'https://covers.openlibrary.org/b/id/13626551-L.jpg', '/works/OL28355314W', NULL, '2023', 'English', NULL, 1, 0, 'long-stretch-of-bad-days-mindy-mcginnis', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:06', '2026-03-22 04:58:52');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5d596389-57be-41a4-8435-35c97d0b2c95', 'Round the Red Lamp', 'Before Sherlock Holmes ever lit his pipe, Arthur Conan Doyle was a physician, and from the dimly lit consulting rooms and crowded hospital wards he drew inspiration for one of his most striking works. "Round the Red Lamp" takes the reader behind the closed doors of Victorian medicine, where the red lamp outside a doctor’s home signaled a place of healing—and sometimes of heartbreak.', 'A collection of short stories by Arthur Conan Doyle exploring medical life with themes of horror and realism in Victorian settings.', 1903, NULL, NULL, 307, NULL, NULL, 'https://books.google.com/books/content?id=6aU_DgAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL44904109W', NULL, '1903', 'English', 'Appleton and Co.', 1, 0, 'round-the-red-lamp-arthur-conan-doyle', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:47:07', '2026-03-22 04:05:27');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('05e75fef-27af-4eaf-9f64-12b7bc930794', 'Tales from Earthsea', 'In this stellar collection…Ursula K. Le Guin makes a triumphant return to the magic-drenched world of Earthsea. Featuring the award-winning author’s new Earthsea novella, two original stories and two classic tales, as well as new maps and a special essay on Earthsea’s history, languages, literature and magic, the publication of this collection is a major event in fantasy literature.', 'A collection of fantasy stories set in the magical world of Earthsea, exploring themes of power, magic, and human connection.', 2008, NULL, NULL, NULL, NULL, NULL, 'https://books.google.com/books/content?id=ueRzTEnB96wC&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL39143892W', NULL, NULL, 'English', NULL, 1, 0, 'tales-from-earthsea-ursula-k-le-guin', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:47:07', '2026-03-20T22:23:00.081Z');
