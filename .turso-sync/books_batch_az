INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5db35fda-3dfd-4f75-a050-28e002f70b4b', 'The Bird Is Gone', 'Imagine a world where the American government signed a conservation act to ''restore all indigenous flora and fauna to the Great Plains,'' which means suddenly the Great Plains are Indian again. Now fast-forward fourteen years to a bowling alley deep in the Indian Territories.', 'A surreal murder mystery set in a re-indigenized Great Plains, blending Native American fiction with experimental, fractured storytelling.', 2003, '1573661090', NULL, 173, NULL, NULL, 'https://covers.openlibrary.org/b/id/825364-L.jpg', '/works/OL5717238W', NULL, '2003', 'English', NULL, 1, 0, 'the-bird-is-gone-stephen-graham-jones', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:44:40', '2026-03-22 04:05:40');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('133b373b-46f7-4689-8ca9-ac3fe3fc18e7', 'Snow Crash', 'Within the Metaverse, Hiro is offered a datafile named Snow Crash by a man named Raven who hints that it is a form of narcotic. Hiro''s friend and fellow hacker Da5id views a bitmap image contained in the file which causes his computer to crash and Da5id to suffer brain damage in the real world.

This is the future we now live where all can be brought to life in the metaverse and now all can be taken away. Follow on an adventure with Hiro and YT as they work with the mob to uncover a plot of biblical proportions.', NULL, 1992, '059359973X', '9789731023021', 460, NULL, 1023, 'https://covers.openlibrary.org/b/id/7997181-L.jpg', '/works/OL38501W', NULL, 'Nov 19, 2010', 'English', NULL, 1, 0, 'snow-crash-neal-stephenson', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:44:42', '2026-03-24 23:24:42');
