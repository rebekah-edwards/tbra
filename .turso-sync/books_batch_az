INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('62103ea4-ec1e-4a83-b9e7-8c0ede24d191', 'Edge of Awe', 'Anyone who has visited the awe-inspiring Malheur-Steens country or plans to do so, and anyone with an interest in the region, will find inspiration in this literary companion. With a foreword by William Kittredge and line drawings by Ursula K. Le Guin, this literary anthology gathers together personal impressions of the Malheur-Steens region of Oregon, known for its birding opportunities, its natural beauty and remoteness, and, more recently, for the 2016 armed takeover of the Malheur National Wildlife Refuge.', 'A literary anthology capturing personal impressions of the awe-inspiring Malheur-Steens region of Oregon, with illustrations by Ursula K. Le Guin.', 2019, '0870719610', '9780870719615', 272, NULL, NULL, 'https://covers.openlibrary.org/b/id/8808247-L.jpg', '/works/OL20162364W', NULL, '2019-05-26', 'English', NULL, 0, 0, 'edge-of-awe-ursula-k-le-guin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:17', '2026-03-22 04:08:25');
