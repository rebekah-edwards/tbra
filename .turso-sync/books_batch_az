INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c52a7337-661a-4cab-b64d-9c1f0f370c75', 'The Monster Missions', 'From the author of Float and Glitch comes a new stand-alone middle grade novel set in a flooded future, where two friends battle legendary sea monsters to protect what''s left of humanity. Berkley and her best friend, Garth, live on an old cruise ship, scavenging for supplies from the drowned cities left behind after the Big Flood. When they are recruited for a marine biology study on the Britannica, a submarine run by a group of grizzled scavengers, Berkley is excited to explore the ocean depths and study the creatures that now rule the sea. But the submarine isn''t just studying sea monsters, it''s on a mission to protect the last of humanity from their deadly attacks. As Berkley, Garth, and their crewmates are drawn into battles against everything from prehistoric sharks to mischievous octopuses, they discover that there are even greater threats lurking in the ocean''s depths. Can Berkley find a way to save her ship, her crew, and her family before it''s too late?', 'In a flooded world, Berkley and Garth join a submarine crew to study and prevent attacks by legendary sea monsters. A fast-paced, action-packed middle grade sci-fi adventure.', 2022, '0062894390', '9780062894397', 336, NULL, NULL, 'https://covers.openlibrary.org/b/id/11313027-L.jpg', '/works/OL24634243W', NULL, 'May 03, 2022', 'English', NULL, 1, 0, 'the-monster-missions-laura-j-martin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:47:39', '2026-03-22 05:14:49');
