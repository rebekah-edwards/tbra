INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6eb4ea50-1ffe-4fe2-a921-22b066b562fc', 'Cobweb', 'From his triumphant debut with Snow Crash to the stunning success of his latest novel, Quicksilver, Neal Stephenson has quickly become the voice of a generation. In this now-classic political thriller, he and fellow author J. Frederick George tell a savagely witty, chillingly topical tale set in the tense moments of the Gulf War.When a foreign exchange student is found murdered at an Iowa University, Deputy Sheriff Clyde Banks finds that his investigation extends far beyond the small college town--all the way to the Middle East. Shady events at the school reveal that a powerful department is using federal grant money for highly dubious research. And what it''s producing is a very nasty bug. Navigating a plot that leads from his own backyard to Washington, D.C., to the Gulf, where his Army Reservist wife has been called to duty, Banks realizes he may be the only person who can stop the wholesale slaughtering of thousands of Americans. It''s a lesson in foreign policy he''ll never forget.From the Trade Paperback edition.', 'Set against the backdrop of the 1991 Gulf War, a rural Iowa deputy sheriff and a CIA analyst unravel a conspiracy involving Iraqi biological weapons and U.S. government incompetence.', 2006, NULL, '9780099478850', 400, NULL, NULL, 'https://covers.openlibrary.org/b/id/8347568-L.jpg', '/works/OL14911607W', NULL, '2006', 'English', NULL, 1, 0, 'cobweb-neal-stephenson', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:44:46', '2026-03-22 20:32:05');
