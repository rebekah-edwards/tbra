INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c34afa39-fd0e-4945-8191-246681c722d6', 'Steal Like an Artist', 'When asked to talk to students at Broome Community College in upstate New York in the spring of 2011, Austin Kleon wrote a simple list often things he wished he''d heard when he was their age: ''Steal like an artist; Don''t wait until you know who you are to start making things; Write the book you want to read; Use your hands; Side projects are important; Do good work and put it where people can see it; Geography is no longer our master; Be nice (the world is a small town.); Be boring (it''s the only way to get work done.); and, Creativity is subtraction.'' After giving the speech, he posted the text and slides to his popular blog, where it quickly went viral. Now Kleon has expanded his original manifesto into an illustrated guide to the creative life for writers, artists, entrepreneurs, designers, photographers, musicians, and anyone attempting to make things - art, a career, a life - in the digital age. Brief, direct, and visually interactive, the book includes illustrative anecdotes and mini-exercise sections calling out practical actions readers can take to unleash their own creative spirits.', 'Steal Like an Artist demystifies creativity by arguing that originality comes from remixing influences, offering ten practical principles through anecdotes, quotes, and exercises.', 2012, '1626546789', '9780761169253', 160, NULL, 272, 'https://covers.openlibrary.org/b/id/7244512-L.jpg', '/works/OL16489931W', NULL, '2012', 'English', NULL, 0, 0, 'steal-like-an-artist-austin-kleon', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:46:25', '2026-03-22 20:32:05');
