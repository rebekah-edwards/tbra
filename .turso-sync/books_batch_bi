INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('400623c5-72e8-49dd-9120-0c5724f70d06', 'Harry Potter and the Cursed Child', 'The Eighth Story. Nineteen Years Later. Based on an original new story by J.K. Rowling, John Tiffany, and Jack Thorne, a new play by Jack Thorne, "Harry Potter and the Cursed Child" is the eighth story in the Harry Potter series and the first official Harry Potter story to be presented on stage. The play will receive its world premiere in London''s West End on July 30, 2016. It was always difficult being Harry Potter and it isn''t much easier now that he is an overworked employee of the Ministry of Magic, a husband and father of three school-age children. While Harry grapples with a past that refuses to stay where it belongs, his youngest son Albus must struggle with the weight of a family legacy he never wanted. As past and present fuse ominously, both father and son learn the uncomfortable truth: sometimes, darkness comes from unexpected places.', 'Harry Potter returns in a stage play, navigating fatherhood and past shadows as his son Albus faces a dark legacy.', 2001, '1410496201', '9781536419368', 343, NULL, 380, 'https://covers.openlibrary.org/b/id/10716080-L.jpg', '/works/OL17360811W', NULL, '2017', 'English', NULL, 1, 0, 'harry-potter-and-the-cursed-child-jack-thorne', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-21 18:20:38', '2026-03-22 03:46:00');
