INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b1c2d3e4-2222-4bbb-cccc-ringworld0004', 'Ringworld''s Children', '"The Ringworld: a landmark engineering achievement, a flat band three million times the surface of the Earth, encircling a distant star. Home to trillions of inhabitants, not all of whom are human, and host to amazing technological wonders, the Ringworld is unique in all of the universe." "Explorer Louise Wu, an Earth-born human who was part of the first expedition to Ringworld, becomes enmeshed in interplanetary and interspecies intrigue as war, and a powerful new weapon, threaten to tear the Ringworld apart forever. Now the future of Ringworld lies in its children: Tunesmith, the Ghoul protector; Acolyte, the exiled son of Speaker-to-Animals, and Wembleth, a strange Ringworld native with a mysterious past. All must play a dangerous game in order to save Ringworld''s population - and the stability of Ringworld itself."--BOOK JACKET.', NULL, 2005, NULL, '9780765396594', 288, NULL, NULL, 'https://covers.openlibrary.org/b/id/12719970-L.jpg', '/works/OL510427W', NULL, '2005', 'English', NULL, 1, 0, 'ringworlds-children-larry-niven', 0, 'openlibrary', NULL, 0, NULL, 'import_only', '2026-03-22 22:46:36', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c2d3e4f5-1111-4ddd-eeee-glassspy00003', 'Spy Glass', 'After siphoning her own blood magic in the showdown at Hubal, Opal Cowan can no longer create glass magic. More, she''s immune to the effects of magic ... until the beautiful pieces of glass she makes flash in the presence of magic, and she discovers that someone has stolen some of her blood-- and that finding it might let her regain her powers ...', NULL, 2013, '0778314685', '9780778314684', 480, NULL, NULL, 'https://covers.openlibrary.org/b/id/7964302-L.jpg', '/works/OL17690554W', NULL, '2013', 'English', NULL, 1, 0, 'spy-glass-maria-v-snyder', 0, 'openlibrary', NULL, 0, NULL, 'import_only', '2026-03-22 22:47:28', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('adf351e6-a2e5-4e6d-86ce-3d998cabd9ce', 'Hunted', '**She only went off the trail for a moment...**

Twenty-two-year-old Eileen goes missing while hiking in the remote Ashlough Forest. Five days later, her camera is discovered washed downriver, containing bizarre photos taken after her disappearance.

Chris wants to believe Eileen is still alive. When the police search is abandoned, he and four of his friends create their own search party to scour the mountain range. As they stray further from the hiking trails and the unsettling discoveries mount, they begin to believe they''re not alone in the forest... and that Eileen''s disappearance wasn''t an accident.

By that point, it''s too late to escape.', 'A chilling horror-thriller as friends search a menacing forest for a missing hiker, uncovering dark secrets.', 2018, '1728220173', '9781728220178', 436, NULL, 629, 'https://covers.openlibrary.org/b/id/15128714-L.jpg', '/works/OL21862106W', NULL, '2020', 'English', 'Poisoned Pen Press', 1, 0, 'hunted-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:23', '2026-03-22T22:48:42.468Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5262c5d9-c331-44c8-87b7-3c6a66e60f94', 'The House Next Door', 'I live next to a haunted house.

I began to suspect something was wrong with the gothic building when its family fled in the middle of the night, the children screaming, the mother crying.

They never came back to pack up their furniture. No family stays long. Animals avoid the place.

Once, I thought I saw a woman’s silhouette pacing through the upstairs room… but that seems impossible; no one was living there at the time.

A new occupant, Anna, has just moved in. I paid her a visit to warn her about the building. I didn’t expect us to become friends, but we did. And now that Marwick House is waking up, she’s asked me to stay with her.

I never intended to become involved with the building or its vengeful, dead inhabitant. But now I have to save Anna… before it’s too late for the both of us.', 'A chilling ghost story of Jo, who lives next to a haunted house, and Anna, the new tenant, as they face a vengeful spirit.', 2020, NULL, '9781728220161', 256, NULL, 339, 'https://covers.openlibrary.org/b/id/9324257-L.jpg', '/works/OL20660617W', NULL, '2020', 'English', 'Poisoned Pen Press, an imprint of Sourcebooks', 1, 0, 'the-house-next-door-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:24', '2026-03-22T22:48:39.946Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('980060ce-cef8-4593-9a2d-f90667cdfabe', 'Uninhabited', NULL, 'A haunting tale of a neglected house, uninhabited for 40 years, where vines strangle the walls and dark secrets lurk.', 2025, NULL, '9781728270265', 416, NULL, NULL, 'https://books.google.com/books/content?id=azLw0AEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL42444947W', NULL, '2025', 'English', 'Sourcebooks, Incorporated', 1, 0, 'uninhabited-darcy-coates', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-22 22:48:25', '2026-03-22T22:48:44.838Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('52c92fef-c279-4079-b26d-62643eadbda5', 'Vengeful Dead', 'How far will she go to save the damned? Keira is caught in a deadly battle. Her ability to help ghosts move on from the mortal world has made her a threat to Artec, a powerful corporation intent on exploiting the dead for energy.', 'Keira, who can see ghosts, battles a sinister corporation exploiting the dead in this chilling finale.', 2025, NULL, '9781728239255', 352, NULL, 674, 'https://books.google.com/books/content?id=pyCv0AEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL42406411W', NULL, '2025', 'English', 'Sourcebooks, Incorporated', 1, 0, 'vengeful-dead-darcy-coates', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-22 22:48:26', '2026-03-22T22:48:39.303Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('46de6a8a-d3bc-47eb-90b3-99ff80da9a4c', 'Hollow Dead', 'Peeling back layer upon layer of the mystery surrounding her origins, Keira has finally learned that the strange masked men work for Artec, an organization profiting off spectral energy produced by hundreds of chained, tormented souls. Their goal is to spread their macabre cemeteries across the world, using the agony of the dead to extend their power and reach―and only Keira and her loyal group of friends can stop them.', 'Keira, who can talk to ghosts, battles Artec, a sinister organization exploiting tormented souls, in this eerie paranormal mystery.', 2024, NULL, '9781728239248', NULL, NULL, 492, 'https://books.google.com/books/content?id=PAbZzwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL37581837W', NULL, '2024', 'English', 'Sourcebooks, Incorporated', 1, 0, 'hollow-dead-darcy-coates', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-22 22:48:26', '2026-03-22T22:48:35.510Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e35e7ec6-4949-4188-8ca3-464154f4984d', 'Where He Can''t Find You', 'From USA Today bestselling horror/thriller author Darcy Coates comes the chilling legend of a monster no one can escape. DON''T WALK ALONE, OR THE STITCHER WILL FIND YOU. Abby Ward lives in a town haunted by disappearances. People vanish, and when they''re found, their bodies have been dismembered and sewn back together in unnatural ways.', 'A chilling YA horror tale of a serial killer, The Stitcher, haunting a small town with gruesome murders.', 2023, NULL, '9781728278940', NULL, NULL, 644, 'https://covers.openlibrary.org/b/id/15147754-L.jpg', '/works/OL34339426W', NULL, '2023', 'English', 'Sourcebooks, Incorporated', 1, 0, 'where-he-cant-find-you-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:27', '2026-03-22T22:48:41.006Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d8f05643-44b8-41cf-945c-c02ccbef16e4', 'Dead of Winter', 'When Christa joins a tour group heading deep into the snowy expanse of the Rocky Mountains, she''s hopeful this will be her chance to put the ghosts of her past to rest. But when a bitterly cold snowstorm sweeps the region, the small group is forced to take shelter in an abandoned hunting cabin. Despite the uncomfortably claustrophobic quarters and rapidly dropping temperature, Christa believes they''ll be safe as they wait out the storm.

She couldn''t be more wrong.

Deep in the night, their tour guide goes missing...only to be discovered the following morning, his severed head impaled on a tree outside the cabin. Terrified, and completely isolated by the storm, Christa finds herself trapped with eight total strangers. One of them kills for sport...and they''re far from finished. As the storm grows more dangerous and the number of survivors dwindles one by one, Christa must decide who she can trust before this frozen mountain becomes her tomb.', 'A deadly snowstorm traps Christa and strangers in a remote cabin, where a killer hunts them one by one in this chilling horror thriller.', 2023, '1728270251', '9781728270258', 352, NULL, 677, 'https://covers.openlibrary.org/b/id/14025773-L.jpg', '/works/OL29046947W', NULL, '2023', 'English', 'Poisoned Pen Press', 1, 0, 'dead-of-winter-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:27', '2026-03-22T22:48:40.078Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b7da83a5-7853-4230-b225-d7523583e23b', 'Twisted Dead', 'Keira is ready for her life to return to normal. Though, to be fair, normal is a tall ask when your ability to see ghosts has landed you the job of groundskeeper in a small town’s cemetery. When Keira receives an invitation to dinner at Dane Crispin’s crumbling estate, she’s ecstatic to meet the family of her long-lost idol. But there’s something dark happening in the world beyond most peoples’ vision, and if Keira isn’t able to sever the ties between the living and the dead, the chained spirits may not be the only things twisted beyond saving.', 'Keira, a cemetery groundskeeper who sees ghosts, faces dark forces and chained spirits in a chilling yet humorous supernatural mystery.', 2023, NULL, '9781728239231', NULL, NULL, 677, 'https://covers.openlibrary.org/b/id/13410725-L.jpg', '/works/OL27816141W', NULL, '2023', 'English', 'Poisoned Pen Press', 1, 0, 'twisted-dead-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:28', '2026-03-22T22:48:36.009Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7e123667-c5c3-480f-b06d-c4bfd5355b2c', 'Gallows Hill', 'It’s time to come home…

The Hull family has owned the Gallows Hill Winery for generations. Their wine wins awards. Their business prospers. Their family thrives. People whisper that the curse has awakened once more.

The sprawling old house has long been perched on top of a hill overlooking the nearby town, jealously guarding the estate''s secrets.

It''s been more than a decade since Margot Hull last saw her childhood home. She was young enough when she was sent away that she barely remembers its dark passageways and secret corners. But now she''s returned to bury her parents and reconnect with the winery that is her family''s legacy―and the bloody truth of exactly what lies buried beneath the crumbling estate. Alone in the sprawling, dilapidated building, Margot is forced to come face to face with the horrors of the past―and realize that she may be the next victim of a house that never rests...', 'Margot Hull returns to her haunted family winery, Gallows Hill, unearthing deadly secrets and ghostly horrors.', 2022, NULL, '9781728220246', NULL, NULL, 806, 'https://m.media-amazon.com/images/I/81xdOxZQf4L._SL1500_.jpg', '/works/OL27009988W', NULL, '2022', 'English', 'Poisoned Pen Press', 1, 0, 'gallows-hill-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:28', '2026-03-22T22:48:41.224Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('befc45ea-f77e-48e4-a4f1-6303a16d6cba', 'Craven Malikanesi', NULL, 'A mysterious letter leads Daniel to a gardener job at the eerie Craven Manor, uncovering dark secrets and supernatural horrors.', 2019, '9753484461', '9789753484466', 312, NULL, NULL, 'https://covers.openlibrary.org/b/id/12309584-L.jpg', '/works/OL26366186W', NULL, '2019-11-04', 'Turkish', 'Çınar Yayınları', 1, 0, 'craven-malikanesi-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'import_only', '2026-03-22 22:48:29', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('84cb5ae8-af7f-4fc6-a5e6-5922ef0451d7', 'From Below', 'No light. No air. No escape.
Hundreds of feet beneath the ocean''s surface, a graveyard waits...

Years ago, the SS Arcadia vanished without a trace during a routine voyage. Though a strange, garbled emergency message was broadcast, neither the ship nor any of its crew could be found. Sixty years later, its wreck has finally been discovered more than three hundred miles from its intended course...a silent graveyard deep beneath the ocean''s surface, eagerly waiting for the first sign of life.

Cove and her dive team have been granted permission to explore the Arcadia''s rusting hull. Their purpose is straightforward: examine the wreck, film everything, and, if possible, uncover how and why the supposedly unsinkable ship vanished.

But the Arcadia has not yet had its fill of death, and something dark and hungry watches from below. With limited oxygen and the ship slowly closing in around them, Cove and her team will have to fight their way free of the unspeakable horror now desperate to claim them.', 'A dive team explores the eerie wreck of the SS Arcadia, facing unspeakable horrors in the ocean''s depths.', 2022, NULL, '9781728220239', NULL, NULL, 754, 'https://m.media-amazon.com/images/I/71hzPo8trqL._SL1500_.jpg', '/works/OL25809399W', NULL, '2022', 'English', 'Poisoned Pen Press', 1, 0, 'from-below-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:30', '2026-03-22T22:48:38.500Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f18f9767-2610-4d8e-93cb-f3da7624e7be', 'The Haunting of Leigh Harker', 'From bestselling gothic horror author Darcy Coates comes a chilling story of a quiet house on a forgotten suburban lane that hides a deadly secret... Leigh Harker''s quiet suburban home was her sanctuary for more than a decade, until things abruptly changed. Curtains open by themselves.', 'A chilling gothic horror tale of Leigh Harker, trapped in her once-sanctuary home with deadly secrets and ghostly presences.', 2021, '172822022X', '9781728220222', 272, NULL, NULL, 'https://covers.openlibrary.org/b/id/11516232-L.jpg', '/works/OL24765348W', NULL, '2021-09-07', 'English', 'Poisoned Pen Press', 1, 0, 'the-haunting-of-leigh-harker-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:31', '2026-03-22T22:48:39.489Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1ffaa443-246f-4379-88bb-2aa25387cac8', 'Ghost Camera', 'When Jenine finds an abandoned polaroid camera, she playfully snaps a photo without a second thought. But there’s something wrong with the image: a ghostly figure stands in the background, watching her. As the spirits begin to hunt her down, she’s forced into a deadly race to free herself from the camera’s curse. This collection by Darcy Coates includes the title story and eight additional horror tales, ranging from mildly disturbing to downright terrifying.', 'A chilling horror anthology featuring ghostly cameras and supernatural curses, delivering unsettling and terrifying tales.', 2014, '0992594901', '9780992594909', 128, NULL, 540, 'https://covers.openlibrary.org/b/id/11516174-L.jpg', '/works/OL24765307W', NULL, '2014-10-21', 'English', 'Black Owl Books', 1, 0, 'ghost-camera-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:32', '2026-03-22T22:48:41.845Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('31965fd5-8f29-40f7-86ee-0e7660048ec8', 'The Ravenous Dead', 'The Ravenous Dead by Darcy Coates is a paranormal mystery novel, and the second in the Gravekeeper series. I wouldn&#x27;t call it horror. First, let me thank NetGalley, the publisher Poisoned Pen Press, and of course the author, for providing me with a copy of this book in exchange for an honest review.', 'Keira, a graveyard keeper, faces a ravenous serial killer''s spirit in a chilling paranormal mystery.', 2022, '1728239222', '9781728239224', 272, NULL, 481, 'https://covers.openlibrary.org/b/id/11516169-L.jpg', '/works/OL24765304W', NULL, '2022-03-15', 'English', 'Poisoned Pen Press', 1, 0, 'the-ravenous-dead-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:33', '2026-03-24T22:54:09.971Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1cf113da-1719-4be9-8b6f-cebb1a3f4b96', 'The Whispering Dead', 'USA Today bestseller and rising queen of atmospheric horror Darcy Coates returns with a ghost story that will haunt you long after the final page. She hears them whispering... Homeless, hunted, and desperate to escape a bitter storm, Keira takes refuge in an abandoned groundskeeper’s cottage. Her new home is tucked away at the edge of a cemetery, surrounded on all sides by gravestones: some recent, some hundreds of years old, all suffering from neglect. And in the darkness, she can hear the unquiet dead…', 'A woman with no memory hides in a haunted cemetery cottage, hearing the whispers of the dead in this atmospheric horror tale.', 2021, '1728239214', '9781728239217', 272, NULL, 435, 'https://covers.openlibrary.org/b/id/10975743-L.jpg', '/works/OL24422212W', NULL, '2021-05-04', 'English', 'Poisoned Pen Press', 1, 0, 'the-whispering-dead-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:34', '2026-03-22T22:48:42.596Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8d510068-4a9e-49fa-8acd-b3c0e80f62b8', 'Silence in the Shadows', 'USA Today bestseller and rising queen of atmospheric horror Darcy Coates returns with the fourth book in her haunting winter horror series. There''s no safety in the stillness… This riveting Black Winter series is: For fans of V.C. Andrews and Stephen King, for lovers of horror and paranormal thrillers, full of heart-pounding horror mysteries. The stark world continues to change.', 'The final book in an apocalyptic horror series, following Clare and Dorran’s fight against the Hollow ones in a twisted, stark world.', 2020, NULL, '9781728220215', 400, NULL, 609, 'https://covers.openlibrary.org/b/id/10486033-L.jpg', '/works/OL21882175W', NULL, '2020', 'English', 'Poisoned Pen Press', 1, 0, 'silence-in-the-shadows-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:35', '2026-03-22T22:48:44.844Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e4f10543-c773-428e-8d92-b3e16a868c5f', 'Craven Manor', 'Daniel is desperate for a job. When someone slides a note under his door offering him the groundskeeper’s position at an old estate, it seems too good to be true. Alarm bells start ringing when he arrives at Craven Manor. The mansion’s front door hangs open, and leaves and cobwebs coat the marble foyer. Before long, Daniel begins to notice strange occurrences and warnings he can’t explain. As he digs into the manor’s past, he uncovers a history of betrayal, grief, and something far more dangerous than ghosts. Craven Manor is more than haunted—it’s hungry. And it doesn’t want Daniel to leave.', 'A desperate man takes a groundskeeper job at eerie Craven Manor, uncovering haunting secrets and danger.', 2017, NULL, '9780994630636', 298, NULL, 505, 'https://m.media-amazon.com/images/I/91x2joMuw8L._SL1500_.jpg', '/works/OL21853550W', NULL, '2017', 'English', 'Poisoned Pen Press', 1, 0, 'craven-manor-darcy-coates', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-22 22:48:37', '2026-03-22T22:48:49.846Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('14729766-dbdb-4b4e-940a-4b0f71da5851', 'Small Horrors', 'Lose yourself in fifty chilling tales of horror and suspense from USA Today bestselling author Darcy Coates. Push past the curtains of your rational, safe world and explore the un-nameable horrors living in the darkest corners of our conscience. This is the realm of monsters and shifting shadows, where a single wrong step can plunge you into a terrifying fight for your life.', 'A chilling anthology of fifty short horror stories by Darcy Coates, exploring dark corners of the human psyche with suspense and terror.', 2016, NULL, '9780992594923', 364, NULL, 386, 'https://books.google.com/books/content?id=qTT5swEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL21852916W', NULL, '2016', 'English', 'Poisoned Pen Press', 1, 0, 'small-horrors-darcy-coates', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-22 22:48:39', '2026-03-22T22:48:48.177Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0386f4dc-eb22-4f9d-9890-06005f493cbf', 'Haunting of Ashburn House', 'Everyone knows about Ashburn House. They whisper its old owner went mad, and restless ghosts still walk the halls. They say it’s the dwelling place of something cruel and sinister. But when Adrienne―desperate and in need of a place to stay―inherits the crumbling old mansion, she only sees it as a lifeline…', 'Adrienne inherits the eerie Ashburn House, uncovering its haunted history and sinister secrets in this cozy horror tale.', 2016, NULL, '9780994630605', 342, NULL, 543, 'https://books.google.com/books/content?id=0JESvgAACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL21831580W', NULL, '2016', 'English', 'Poisoned Pen Press', 1, 0, 'haunting-of-ashburn-house-darcy-coates', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-22 22:48:39', '2026-03-22T22:48:50.279Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9124e2fc-3c44-4519-8138-d522ce2794f2', 'Quarter to Midnight', 'Discover fifteen chilling tales of gothic horror and suspense from USA Today bestselling author Darcy Coates. Push past the curtains of the rational, safe world and explore the un-nameable horrors living in the darkest corners of our conscience. This is the realm of monsters and shifting shadows, where a single wrong step can plunge you into a terrifying, irreversible fight for your life.', 'Fifteen chilling tales of gothic horror and suspense exploring dark fears and supernatural terrors.', 2015, NULL, '9780992594954', 312, NULL, 490, 'https://covers.openlibrary.org/b/id/13255066-L.jpg', '/works/OL21825114W', NULL, '2015', 'English', 'Poisoned Pen Press', 1, 0, 'quarter-to-midnight-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:41', '2026-03-22T22:48:49.443Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1dcf7abb-7c3b-4f8d-922d-ec99c245e077', 'The Haunting of Gillespie House', 'Elle is thrilled to spend a month minding the beautiful Gillespie property. Over an hour''s drive from the nearest town, the aging mansion is ideal for someone seeking solitude. But as she explores her new home, Elle makes a startling discovery: there''s a graveyard nestled deep in the woods, containing a generation of the house''s residents... all who died the same year.

Then things start to go very wrong, very quickly.

There are skittering noises inside the walls... slamming doors... whispers in the night... a locked room... and a horrifying mystery that wants to be solved. As she investigates further, Elle begins to unravel the property''s dark and dangerous history. At its center is Jonathan Gillespie, a tyrannical cult leader and the house''s original owner. And as Elle soon learns...

Just because he''s dead, doesn''t mean he''s gone.', 'Elle house-sits a remote mansion, uncovering a haunted past tied to a tyrannical cult leader. A creepy, atmospheric horror tale.', 2015, '0992594944', '9780992594947', 240, NULL, 229, 'https://covers.openlibrary.org/b/id/10245231-L.jpg', '/works/OL20904640W', NULL, '2020-08-04', 'English', 'Poisoned Pen Press', 1, 0, 'the-haunting-of-gillespie-house-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:42', '2026-03-22T22:48:51.280Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3f2d19d6-c1f7-491f-a66a-0c4ae99824ce', 'Dead Lake', 'A remote lake. A locked cabin. A woman alone—with someone watching. In Dead Lake, bestselling horror author Darcy Coates plunges you into an eerie, psychological survival story where every shadow feels alive—and the silence is anything but empty. Sam is an artist seeking inspiration at her uncle''s isolated cabin on Harob Lake. But the dream retreat disintegrates into a nightmare when Sam sees a stranger by the lake.', 'A woman seeks solitude at a remote Harob Lake cabin, but eerie isolation and a lurking stranger turn her retreat into a nightmare.', 2015, '1728221773', '9781728221779', 256, NULL, 166, 'https://covers.openlibrary.org/b/id/10385786-L.jpg', '/works/OL21599285W', NULL, '2020-08-04', 'English', 'Poisoned Pen Press', 1, 0, 'dead-lake-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:42', '2026-03-22T22:48:51.728Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2ff3bcb2-8711-4986-ad0a-6e87fa308517', 'House of Shadows', 'Sophie''s world is shattered when disaster bankrupts her family, forcing her into a marriage of convenience with a mysterious stranger, Mr. Argenton. His relatives are cold, and Mr. Argenton himself is keeping secrets. Even worse, the house is more than it seems. Doors slam. Inhuman figures slink through the surrounding forest. A piano plays itself in the middle of the night. Blood drips a macabre warning down the walls. Day by day, Sophie is inevitably pulled towards the terrifying truth at the heart of this gothic mystery: Northwood''s ancient halls are haunted, and the man she married—the man she''s coming to love—is hiding an unforgiveable truth about his ancestral home...and the spirits that now haunt them both.', 'A gothic horror tale of Sophie uncovering sinister secrets in a haunted ancestral home full of ghosts and shadows.', 2016, '0992594987', '9780992594985', 292, NULL, 368, 'https://covers.openlibrary.org/b/id/10376665-L.jpg', '/works/OL21507422W', NULL, '2016-05-25', 'English', 'Black Owl Books', 1, 0, 'house-of-shadows-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:43', '2026-03-22T22:49:05.344Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6a89816c-d5a7-4dda-b01f-cf9abac2214e', 'Parasite', 'When a guard discovers an unusual lifeform on her remote moon outpost, she disregards protocol to investigate―with catastrophic consequences. It soon becomes clear she’s stuck in isolation with an alien capable of incredible depravity. The parasite wears its victims’ skins and adopts their personalities.', 'A guard on a remote moon outpost discovers a deadly parasitic alien that mimics humans, sparking a tense sci-fi horror across space stations.', 2016, NULL, '9780992594916', 408, NULL, NULL, 'https://covers.openlibrary.org/b/id/14823214-L.jpg', '/works/OL21230447W', NULL, '2016', 'English', 'Poisoned Pen Press', 1, 0, 'parasite-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:45', '2026-03-22T22:48:54.692Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('37dd0308-a9be-4243-b298-7e000a7b03f0', 'The Haunting of Blackwood House', 'As the daughter of spiritualists, Mara''s childhood was filled with séances and scam mediums. Now she''s ready to start over with her fiancé, Neil, far away from the superstitions she''s learned to loathe... but her past isn''t willing to let her go so easily.

And neither is Blackwood House.

When Mara and Neil purchased the derelict property, they were warned that ever since the murder of its original owner, things have changed. Strange shadows stalk the halls. Doors creak open by themselves. Voices whisper in the night. And watchful eyes follow her every move. But Mara''s convinced she can''t possibly be in danger. She doesn''t believe in ghost stories, and she didn''t buy a haunted house―it''s just not possible.

Because ghosts aren''t real... are they?', 'Mara and Neil buy the eerie Blackwood House, ignoring warnings of hauntings. A chilling gothic horror unfolds as shadows and whispers test their disbelief.', 2015, '0992594979', '9781728220147', 338, NULL, 504, 'https://covers.openlibrary.org/b/id/9341176-L.jpg', '/works/OL20672054W', NULL, '2015-12-19', 'English', 'Black Owl Books', 1, 0, 'the-haunting-of-blackwood-house-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:45', '2026-03-22T22:48:54.724Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('616059d1-54ae-48b0-87c7-7bf43afcd755', 'Whispers in the Mist', 'From USA Today bestseller and rising queen of paranormal horror Darcy Coates comes Book 3 in the Black Winter Series. You won''t survive the stillness... The mist is full of evil things--dark, twisted beings that think only of their own hunger--but Clare has clawed her way through.', 'A chilling post-apocalyptic horror tale where Clare battles evil beings in a deadly mist.', 2020, '1728220203', '9781728220208', 480, NULL, 737, 'https://covers.openlibrary.org/b/id/10239141-L.jpg', '/works/OL20901098W', NULL, '2020-07-07', 'English', 'Poisoned Pen Press', 1, 0, 'whispers-in-the-mist-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:47', '2026-03-22T22:48:55.736Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3db9c22c-fb52-4491-9f3c-b0f75aa52ca5', 'House of Secrets', 'Sophie and Joseph Argenton have survived the impossible… for now. But their escape from Northwood is short-lived. The sinister shadow that haunted their ancestral home survived, and has attached itself to Joseph''s young cousin. Desperate, they travel to meet her father at Kensington, a long-abandoned mansion overlooking a dead town.', 'A gothic horror sequel where Sophie and Joseph face a sinister shadow at a haunted mansion.', 2020, '1728221757', '9781728221755', 240, NULL, 368, 'https://covers.openlibrary.org/b/id/9363898-L.jpg', '/works/OL20690066W', NULL, '2020-05-05', 'English', 'Poisoned Pen Press', 1, 0, 'house-of-secrets-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:49', '2026-03-22T22:48:58.079Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('42c953fc-44bb-4a85-a8ae-155fc3d861b9', 'The Haunting of Rookward House', 'Rookward House may be hours away from its nearest neighbor, but he can''t escape the feeling that he''s being watched. Still, he doesn''t believe in ghost stories and decides to camp in the crumbling old mansion while he does repairs. Surely nothing too bad can happen in the space of a week. But there''s a reason no one lives in the haunting house, with its twisting shadows and whispering walls.', 'A man camps in isolated Rookward House to repair it, unaware of its haunting secrets and ghostly presence.', 2017, '099463062X', '9780994630629', 296, NULL, NULL, 'https://covers.openlibrary.org/b/id/8749419-L.jpg', '/works/OL20075875W', NULL, '2017-09-27', 'English', 'Black Owl Books', 1, 0, 'the-haunting-of-rookward-house-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:49', '2026-03-22T22:48:56.818Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('bdfbbb57-a398-4518-8ec6-27b776b1ae13', 'The haunting of Ashburn House', 'Everyone knows about Ashburn House. They whisper its old owner went mad, and restless ghosts still walk the halls. They say it''s the dwelling place of something cruel and sinister. But when Adrienne―desperate and in need of a place to stay―inherits the crumbling old mansion, she only sees it as a lifeline... until darkness falls.

Strange messages are etched into the walls. Furniture moves when she leaves the room. There''s something here―something powerful, angry, and hell-bent on shaking things up. Worse, a grave hidden in the depths of the forest hints at a terrible, unforgivable secret. Eventually Adrienne can''t ignore that a twisted thing lives in the house, its hungry eyes ever-watchful. Chasing the threads of a decades-old mystery, it isn''t long before she realizes she''s become prey to something deeply unnatural and intensely resentful.

She has no idea how to escape. She has no idea how to survive. Only one thing is certain: Ashburn''s dead are not at rest.', 'A desperate woman inherits Ashburn House, a crumbling mansion haunted by cruel, restless spirits.', 2019, '1728220130', '9781728220130', NULL, NULL, 543, 'https://covers.openlibrary.org/b/id/9324259-L.jpg', '/works/OL20660619W', NULL, '2019', 'English', 'Poisoned Pen Press, an imprint of Sourcebooks', 1, 0, 'the-haunting-of-ashburn-house-darcy-coates', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-22 22:48:51', '2026-03-22T22:48:59.437Z');
