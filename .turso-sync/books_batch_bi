INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('27d24be6-3edf-4148-b94c-1ddc78f2ee33', 'The Ill-Made Knight', '"Este libro presenta un acercamiento al "proceso de cambio" que tuvo lugar en Bolivia (2006-2019) desde las políticas deportivas implementadas por el gobierno de Evo Morales, a partir de la siguientes preguntas generadoras: ¿Qué lugar ocupa el deporte en el mundo indígena boliviano? ¿Cómo fue incorporado el deporte en el "proceso de cambio" que implementó el gobierno de Evo Morales? ¿Cuál fue la participación desplegada por el presidente Evo Morales en el campo deportivo? ¿Cuáles han sido los alcances, logros y limitaciones de esas acciones presidenciales y políticas gubernamentales en el proceso de descolonización? Partiendo de una aproximación histórica al lugar del deporte en las comunidades y movimientos indígenas, se revisa la trayectoria deportiva de Evo Morales, así como las políticas que su gobierno implementó en el campo deportivo, para concluir con una reflexión sobre su impacto en el "proceso de cambio" y, en particular, en la dimensión descolonizadora del mismo. El libro es prologado por Luis H. Antezana"--publisher''s website.', NULL, 1940, NULL, '9798458587716', NULL, NULL, NULL, 'http://books.google.com/books/content?id=pCFzvAEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL1388009W', NULL, '2021', 'English', NULL, 1, 0, 'the-illmade-knight-t-h-white', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-23 00:16:31', '2026-03-25 00:23:59');
