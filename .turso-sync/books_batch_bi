INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f506711a-8750-4f23-8ab6-a3c58b2cbf00', 'Lights Out', '**“I don’t need another kink.”**

That thought pops into my head whenever I pull up my favorite social media app, but alas, every time I scroll, I learn something new about myself, and another one is born. And yes, I know I’m responsible for what the algorithm shows me, but I’m trying to ignore that fact.

Lately, my feed has been dominated by masked men. I’ve favorited videos with them dressed in full cosplay, decked out in futuristic military apparel, and wrapped up like ghouls.

But more than anything else, my FYP is filled with shirtless men wearing ghost masks. Bonus points if they’re heavily tattooed, wielding a knife, or covered in fake blood. At night, I dream about being chased by them, of them catching me and doing deliciously dark things to my more than willing body.

I never could have guessed that by sending one drunken text, those dreams would become my new reality.

Lights Out is a fast-paced dark romance with a morally grey male lead. Some themes and scenes may be disturbing to readers. Please check the TWs at the beginning of the book.', 'A dark romance where a trauma nurse''s online fantasies become reality after a drunken text, blending stalking and desire.', 2024, '1638932239', '9781529442397', 416, NULL, 816, 'https://covers.openlibrary.org/b/id/14840901-L.jpg', '/works/OL38128674W', NULL, '2024', 'English', NULL, 1, 0, 'lights-out-navessa-allen', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-21 02:35:39', '2026-03-23 04:33:36');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b231b43e-f6d7-4d8b-b6a1-a9ff4d198be8', 'Caught Up', 'From the viral TikTok author of the stalker romcom, Lights Out, comes Navessa Allen’s second book in bestselling The Into Darkness Trilogy, upping the ante with voyeurism and play club kink. ''I wanted this woman, and I was a man who always got what he wanted.'' Nico ''Junior'' Trocci knows Lauren Marchetti is off limits.', 'A dark romance with mafia ties, camgirl plots, and intense kink, Caught Up explores toxic love and obsession.', 2025, NULL, '9781638932253', 370, NULL, NULL, 'https://covers.openlibrary.org/b/id/15093928-L.jpg', '/works/OL42544936W', NULL, '2025', 'English', NULL, 1, 0, 'caught-up-navessa-allen', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-21 02:35:40', '2026-03-22 05:02:54');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('834912f7-2a44-4093-81df-c159f99a7f86', 'Clever is the Devil', 'This is the advice I wish someone had given me. I implore you to learn from my mistakes. And if you see a tall, handsome man with the devil in his eyes, run.', 'A dark tale of obsession and danger, warning of a devilish man to avoid. Intense and disturbing themes dominate this gripping story.', 2017, NULL, NULL, NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14641128-L.jpg', '/works/OL38407127W', NULL, 'January 1, 2017', 'English', NULL, 1, 0, 'clever-is-the-devil-navessa-allen', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-21 02:35:41', '2026-03-22 04:30:26');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('37326726-7f26-41ae-b54c-49481fe54497', 'Snowed In', 'Ella Jones knows what to expect from the long, hard winters in the northern reaches of Maine: mostly boredom and monotony, broken up with a bit of skiing or quality time spent with her family.

Which leaves her utterly unprepared for the arrival of Benjamin Kakoa, a professional athlete turned advocate in need of a break from fame and notoriety.

With her world – okay, locally – famous wit and special brand of self-deprecation, Ella goes on a full-blown charm offensive to coax Ben out of his shell. But with a rocky past and an uncertain future, Ben’s walls are tougher to tear down than she could have ever anticipated.

And once they fall, Ella and Ben will have to come to terms with the potentially tragic reality of their love.', 'A winter romance in a remote Maine town, blending humor with heavy themes of grief and mental illness.', 2017, NULL, NULL, NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14641125-L.jpg', '/works/OL38407125W', NULL, 'December 1, 2017', 'English', NULL, 1, 0, 'snowed-in-navessa-allen', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-21 02:35:41', '2026-03-22 03:40:27');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3cabc126-860e-4159-bebf-902165e10956', 'Scandal', 'Scandal is an erotic historical fiction set amidst the chaos and intrigue of the Napoleonic Wars. It follows Katherine, the Duchess of Hampshire, as she, her husband, John, and their lover, Henry, try to unravel the mystery of who is blackmailing them and why.', 'A steamy historical romance with spies and secrets during the Napoleonic Wars, blending eroticism and intrigue.', 2019, NULL, NULL, 587, NULL, NULL, 'https://covers.openlibrary.org/b/id/14641124-L.jpg', '/works/OL38407124W', NULL, 'January 28, 2019', 'English', NULL, 1, 0, 'scandal-navessa-allen', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-21 02:35:42', '2026-03-22 03:44:18');
