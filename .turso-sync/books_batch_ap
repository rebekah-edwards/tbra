INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('547fc252-b008-436b-b06b-b40722208b96', 'The Fall of the Readers', 'When Alice defeated her uncle Geryon and declared war on the totalitarian ways of the Old Readers, she knew she would have a hard fight ahead. What she didn’t anticipate was how ruthless the Old Readers would be. All the creatures she promised to help are being threatened, and slowly all of Alice’s defenses, emotional and physical, are being worn away. So when Ending (the giant cat-like creature who helps rule the magical labyrinth in Geryon’s library) hints at a dangerous final solution, Alice jumps at the chance, no matter the cost to her life. She and her friends—a fire sprite, Ashes the cat, and the other young Readers she met during her previous adventures—go on a quest to free the one creature possibly strong enough to overturn the Old Readers once and for all.

