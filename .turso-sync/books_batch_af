INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8ee9a15c-6187-4658-9097-11d2d2364a99', 'Conversations with Friends', 'Frances is a coolheaded and darkly observant young woman, vaguely pursuing a career in writing while studying in Dublin. Her best friend is the beautiful and endlessly self-possessed Bobbi. At a local poetry performance one night, they meet a well-known photographer, and as the girls are then gradually drawn into her world, Frances is reluctantly impressed by the older woman’s sophisticated home and handsome husband, Nick. But however amusing Frances and Nick’s flirtation seems at first, it begins to give way to a strange—and then painful—intimacy.

Written with gemlike precision and marked by a sly sense of humor, Conversations with Friends is wonderfully alive to the pleasures and dangers of youth, and the messy edges of female friendship.', 'In Dublin, college student Frances and her ex-girlfriend Bobbi befriend a married couple, leading to an affair between Frances and actor Nick.', 2019, '2823610715', '9782823610710', 400, NULL, 501, 'https://covers.openlibrary.org/b/id/8199499-L.jpg', '/works/OL17887575W', NULL, 'Sep 05, 2019', 'English', NULL, 1, 0, 'conversations-with-friends-sally-rooney', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:30:44', '2026-03-22 20:32:05');
