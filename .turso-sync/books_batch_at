INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d0a5974c-4d62-45f4-9e9f-272a9760315e', 'The Book of Shane', 'Friend and traitor. Conqueror and king. Hero and villain. Shane is just a boy, but in order to free his people, he''s resolved to do whatever -- to become whomever -- his mission requires. With an introduction by Tui T. Sutherland, this collection sheds a light on the past, present, and future of the boy who would be conqueror -- and the role Shane has yet to play in the dangers still to come.', 'A collection of stories exploring Shane, a complex boy turned conqueror, and his pivotal role in the Spirit Animals world.', 2015, '1467621013', '9781467621014', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/11578487-L.jpg', '/works/OL24809144W', NULL, 'Nov 01, 2015', 'English', NULL, 1, 0, 'the-book-of-shane-nicola-barber', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 15:20:09', '2026-03-23 04:09:11');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('920fbd36-5c16-4235-abca-a3d24df6e4d5', 'The Body Keeps the Score', 'Trauma is a fact of life. Veterans and their families deal with the painful aftermath of combat; one in five Americans has been molested; one in four grew up with alcoholics; one in three couples have engaged in physical violence. Dr. Bessel van der Kolk, one of the world’s foremost experts on trauma, has spent over three decades working with survivors. In _The Body Keeps the Score_, he uses recent scientific advances to show how trauma literally reshapes both body and brain, compromising sufferers’ capacities for pleasure, engagement, self-control, and trust. He explores innovative treatments—from neurofeedback and meditation to sports, drama, and yoga—that offer new paths to recovery by activating the brain’s natural neuroplasticity. Based on Dr. van der Kolk’s own research and that of other leading specialists, _The Body Keeps the Score_ exposes the tremendous power of our relationships both to hurt and to heal—and offers new hope for reclaiming lives.', 'This nonfiction book delves into the science of trauma, explaining how it reshapes the brain and body while compromising emotional capacities.', 2014, '8412067193', '9788494759208', 520, NULL, 1500, 'https://covers.openlibrary.org/b/id/9014487-L.jpg', '/works/OL18147687W', NULL, NULL, 'English', NULL, 0, 0, 'the-body-keeps-the-score-bessel-van-der-kolk', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 15:20:09', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a47a80dc-f376-4e76-9617-fd35b4d4f001', 'Glimpse of Jesus', 'Beloved Christian writer Brennan Manning has long been illuminating the transforming power of God''s constant love for us in his bestselling books. Now he identifies self-hatred as the reason that so many of us seem unable to accept this incredible, unchanging love. By clearly examining and understanding Jesus'' life, we can put self-hatred behind us forever and truly be transformed in the ways God intended.', 'A spiritual exploration of Jesus'' life, focusing on overcoming self-hatred through God''s unconditional love.', 2010, NULL, '9780062032041', NULL, NULL, NULL, NULL, '/works/OL27332860W', NULL, '2010', 'English', NULL, 0, 0, 'glimpse-of-jesus-brennan-manning', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 15:20:10', '2026-03-22 04:53:14');
