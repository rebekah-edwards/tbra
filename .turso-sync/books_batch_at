INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4376166c-d0a4-4e25-8238-6f7d1085523b', 'Machine Man', 'Scientist Charles Neumann loses a leg in an industrial accident. It’s not a tragedy. It’s an opportunity. Charlie has always thought his body could be better. He begins to replace parts of himself with his own mechanical designs, leading to a dangerous obsession with improvement. A wickedly observed, disturbing, darkly funny and surprisingly moving parable for a new tech-obsessed age by the acclaimed author of Jennifer Government.', 'A scientist loses a leg and sees it as a chance to upgrade his body with tech in this dark, satirical novel on progress and humanity.', 2013, NULL, '9781448169832', 278, NULL, 564, 'https://m.media-amazon.com/images/I/41yZ5JSMjHL.jpg', '/works/OL24768661W', NULL, '2013', 'English', NULL, 1, 0, 'machine-man-max-barry', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 15:20:07', '2026-03-22 03:48:26');
