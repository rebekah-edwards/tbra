INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('97ebdce4-de2f-474c-89e5-2fec9c853f10', 'Dead Heat', '2009 Retailer''s Choice Award winner!
The stage is set for war. Oil prices are surging to record highs. A new dictator is rising in Iraq. China is threatening Taiwan. North Korean forces appear ready to strike south. Israel is feverishly trying to complete the Third Temple. And in the midst of a world ready to explode, American president James MacPherson’s second term is ending. The battle to succeed him is heating up into the most fiercely contested presidential election in American history. Who will lead a bitterly divided country over the next four years? And just what role—if any—does the US play in history''s last days?

As the presidential campaign narrows to a dead heat, the Secret Service learns of a catastrophic terrorist plot to assassinate one of the candidates—but which one? Whom do they want dead? And can US forces stop the terrorists before millions lose their lives?

From New York Times best-selling novelist Joel C. Rosenberg, this explosive political thriller is sure to provoke discussion, along with fervent hopes that this frightening vision of the future will not come true.
(From the Amazon.com Book Description)', 'Werewolf mates Charles and Anna head to Arizona for a relaxing horse-buying trip, but stumble into a chilling case of fae magic forcing a mother to attack her children.', 2008, '1414311613', '9781414311616', 350, NULL, 641, 'https://covers.openlibrary.org/b/id/1785580-L.jpg', '/works/OL5817005W', NULL, 'March 18, 2008', 'English', NULL, 1, 0, 'dead-heat', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 05:05:57', '2026-03-22 04:43:47');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ff0c8390-62a0-4208-9d8a-5d7e9c66678c', 'The last jihad', 'Jon Bennett is a senior White House advisor, but nothing has prepared him for the terror that he will face. Saddam Hussein dispatches his top hit men to assassinate the President of the United States. Iraqi terrorists spread carnage throughout London, Paris, and Riyadh . . . and the Butcher of Baghdad has a nuclear ace in his hand that he has not yet played.', NULL, 2005, '1414312725', '9781414312729', 334, NULL, NULL, 'https://covers.openlibrary.org/b/id/6858984-L.jpg', '/works/OL15943353W', NULL, '2005', 'English', NULL, 1, 0, 'the-last-jihad', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:05:58', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('355dba8d-e607-4f65-862e-96e1da230ea9', 'The Tehran Initiative', 'This is an exciting, pulse pounding story about events in the Middle East that could happen.  Characters are well drawn, and the level of international intrigue, espionage and political pressure comes through every page.  From back cover:  "The world is on the brink of disaster.
Iran has just conducted its first atomic weapons test.  Millions of Muslims around the world are convinced their messiah--know as the Twelfth Imam--has just arrived on earth.  Israeli leaders fear Tehran, under the Twelfth Imam''s spell, will soon launch a nuclear attack that could bring 
about a second Holocaust and the annihilation of Israel.  The White House fears Jerusalem will strike first, launching a massive preemptive attack against Irans nuclear facilities that could cause the entire Middle East to go up in flames, oil prices to skyrocket, and the global economy to collapse.  With the stakes high, and few viable options left, the president of the United States orders CIA operative David Shirazi and his team to track down and sabotage Irans nuclear warheads before Iran or Israel can launch a devastating first strike.  But will they be too late?"', NULL, 2011, NULL, '9781414319353', 462, NULL, NULL, 'https://covers.openlibrary.org/b/id/7271612-L.jpg', '/works/OL16002500W', NULL, '2011', 'English', NULL, 1, 0, 'the-tehran-initiative', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:06:01', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d228e9a6-0a17-4b26-b06a-15026fbc9879', 'Implosion', 'Bestselling author and international political expert Joel C. Rosenberg tackles the question: Is America an empire in decline or a nation poised for a historic Renaissance? America teeters on a precipice. In the midst of financial turmoil, political uncertainty, declining morality, the constant threat of natural disasters, and myriad other daunting challenges, many wonder what the future holds for this once-great nation. Will history''s greatest democracy stage a miraculous comeback, returning to the forefront of the world''s economic and spiritual stage? Can America''s religious past be repeated today with a third Great Awakening? Or will the rise of China, Russia, and other nations, coupled with the US''s internal struggles, send her into a decline from which there can be no return? Implosion helps readers understand the economic, social, and spiritual challenges facing the United States in the 21st century, through the lens of biblical prophecy. - Publisher.', NULL, 2012, '1414319673', '9781414319674', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/7151362-L.jpg', '/works/OL16521299W', NULL, '2012', 'English', NULL, 1, 0, 'implosion', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:06:03', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('beb674db-2817-4a28-a86c-b8aa15b32595', 'The Invested Life', NULL, NULL, 2012, NULL, '9781414376370', 304, NULL, NULL, 'https://covers.openlibrary.org/b/id/10356521-L.jpg', '/works/OL16664272W', NULL, '2012', 'English', NULL, 1, 0, 'the-invested-life', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:06:04', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8e6f54f7-f197-44fc-acee-d1c419cfdf03', 'The Seven Husbands of Evelyn Hugo', 'Aging and reclusive Hollywood movie icon Evelyn Hugo is finally ready to tell the truth about her glamorous and scandalous life. But when she chooses unknown magazine reporter Monique Grant for the job, no one is more astounded than Monique herself. Why her? Why now?

Monique is not exactly on top of the world. Her husband has left her, and her professional life is going nowhere. Regardless of why Evelyn has selected her to write her biography, Monique is determined to use this opportunity to jumpstart her career.

Summoned to Evelyn''s luxurious apartment, Monique listens in fascination as the actress tells her story. From making her way to Los Angeles in the 1950s to her decision to leave show business in the ''80s, and, of course, the seven husbands along the way, Evelyn unspools a tale of ruthless ambition, unexpected friendship, and a great forbidden love. Monique begins to feel a very real connection to the legendary star, but as Evelyn''s story near its conclusion, it becomes clear that her life intersects with Monique''s own in tragic and irreversible ways.

Written with Reid''s signature talent for creating "complex, likable characters" (Real Simple), this is a mesmerizing journey through the splendor of old Hollywood into the harsh realities of the present day as two women struggle with what it means—and what it costs—to face the truth', NULL, 2017, '8416517274', '9789895644513', 400, NULL, NULL, 'https://covers.openlibrary.org/b/id/8354226-L.jpg', '/works/OL18203673W', NULL, 'Dec 09, 2021', 'English', NULL, 1, 0, 'the-seven-husbands-of-evelyn-hugo-taylor-jenkins-reid', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:06:08', '2026-03-24 23:24:42');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('45b2747e-672d-4e4c-92cc-47038e01ffa9', 'Carrie Soto Is Back', 'Carrie Soto is the greatest player the world has ever seen.

But six years after her last match, she watches a young British tennis player steal her world record - and Carrie knows she has to go back and reclaim her rightful place at the top. Even if the world doesn''t believe in her. Even if it almost breaks her.

This is a story about the cost of greatness and the burden of fame.

The fight for a place in history is about to begin . . .', 'Retired tennis legend Carrie Soto stages a fierce comeback to defend her Grand Slam record against a rising rival, grappling with ambition, loss, and a rekindled romance.', 2022, '8419030031', '9788419030030', 392, NULL, 630, 'https://covers.openlibrary.org/b/id/12900643-L.jpg', '/works/OL27305925W', NULL, 'Sep 06, 2022', 'English', NULL, 1, 0, 'carrie-soto-is-back-taylor-jenkins-reid', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:06:40', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d1ef2be9-0d44-48c9-ad57-3403b746e66e', 'Atmosphere', 'Joan Goodwin has been obsessed with the stars for as long as she can remember. Thoughtful and reserved, Joan is content with her life as a professor of physics and astronomy at Rice University and as aunt to her precocious niece, Frances. That is, until she comes across an advertisement seeking the first women scientists to join NASA’s Space Shuttle program. Suddenly, Joan burns to be one of the few people to go to space.

Selected from a pool of thousands of applicants in the summer of 1980, Joan begins training at Houston’s Johnson Space Center, alongside an exceptional group of fellow candidates: Top Gun pilot Hank Redmond and scientist John Griffin, who are kind and easy-going even when the stakes are highest; mission specialist Lydia Danes, who has worked too hard to play nice; warm-hearted Donna Fitzgerald, who is navigating her own secrets; and Vanessa Ford, the magnetic and mysterious aeronautical engineer, who can fix any engine and fly any plane.

As the new astronauts become unlikely friends and prepare for their first flights, Joan finds a passion and a love she never imagined. In this new light, Joan begins to question everything she thinks she knows about her place in the observable universe.

Then, in December of 1984, on mission STS-LR9, everything changes in an instant.', 'In 1980s NASA, aspiring astronaut Joan Goodwin navigates rigorous training, family pressures, and a forbidden romance with another woman amid societal homophobia and sexism.', 1917, '1529152984', '9781529152982', 183, NULL, 592, 'https://covers.openlibrary.org/b/id/15098710-L.jpg', '/works/OL42412330W', NULL, '3 June 2025', 'English', NULL, 1, 0, 'atmosphere-taylor-jenkins-reid', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:06:41', '2026-03-23 04:10:31');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0a386d44-0c42-40dc-bfda-fc998e43db6f', 'Maybe in Another Life', '"Hannah Martin''s life isn''t shaping up into much of anything. Since graduating college eight years ago, she has lived in six different cities and held countless meaningless jobs ... She takes up residence in her best friend Gabby''s guest room. Along with Gabby and Gabby''s husband Mark, [she goes] out to a bar where they meet up with some of [their] old friends, including Hannah''s high school boyfriend, Ethan. Shortly after midnight, Gabby asks Hannah if she''s ready to go. But then Ethan offers to give her a ride later if she wants to stay. Hannah hesitates. What happens if she leaves with Gabby? What happens if she leaves with Ethan? [This book] is told in two concurrent storylines following the consequences of each choice"--', NULL, 2021, '8416327939', '9788416327935', 320, NULL, NULL, 'https://covers.openlibrary.org/b/id/13840389-L.jpg', '/works/OL20004833W', NULL, 'Jan 31, 2021', 'English', NULL, 1, 0, 'maybe-in-another-life-taylor-jenkins-reid', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:06:41', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8dd5f463-029f-4a08-ad19-9f95e4f676a5', 'Por Siempre, Unidos', 'Elsie Porter es una joven con una vida sencilla. Un día de Año Nuevo decide salir a por una pizza y mientras espera, conoce a Ben Ross. La química será instantánea. Ben le pregunta si puede llamarla pronto o ha de esperar los tres días reglamentarios. Elsie queda desarmada ante su sinceridad y su aspecto. En dos semanas están locamente enamorados y no pueden vivir el uno sin el otro. Ben le pide matrimonio y ella acepta. Se fugan a Las Vegas y se casan, sin avisar siquiera a sus familias. Nueve días después de la boda, Ben sale con su bicicleta a comprar unos dulces y un camión lo atropella. Muere al instante. La policía lleva a Elsie al hospital y allí certifican su muerte. Aparece su mejor amiga Ana para apoyarla, pero también su suegra Susan, quien nunca ha oído hablar de su nuera. No se puede creer que su hijo hubiera salido con ella durante seis y se casaran sin decírselo. Las diferencias entre ellas se pondrán de manifiesto y tendrán un difícil reto para solventarlas. Una historia increíble sobre la muerte, el duelo y el amor verdadero, capaz de sobrevivir a las adversidades, al paso del tiempo… e incluso a la muerte.', NULL, 2020, '8416327971', '9788416327973', 288, NULL, NULL, 'https://covers.openlibrary.org/b/id/11302643-L.jpg', '/works/OL24626655W', NULL, 'Oct 06, 2020', NULL, NULL, 1, 0, 'por-siempre-unidos-taylor-jenkins-reid', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:06:43', '2026-03-25 00:23:59');
