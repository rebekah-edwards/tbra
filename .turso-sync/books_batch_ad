INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e8dd78e5-9c58-49c4-a585-8d929e8c146b', 'Armageddon', 'The scattered Tribulation Force is drawn inexorably toward the Middle East, as are all the armies of the world, when history homes in on the battle of the ages.  During the last year of the Great Tribulation, safe houses are no longer safe, and the cast of characters dramatically changes.  By the time of the war of the great day of the God Almighty, the globe has become a powder keg of danger.  Except those already in Petra, everyone has been forced to relocate, as Antichrist ratchets up the anti in the world''s most treacherous game.  Who will be left standing when the battle leaves the Tribulation Force on the brink of the end of time and the Glorious Appearing?', 'In this apocalyptic thriller, the Tribulation Force battles the Antichrist''s forces amid global chaos and biblical prophecies unfolding.', 2003, '0786272805', '9780842332361', 441, NULL, NULL, 'https://covers.openlibrary.org/b/id/639583-L.jpg', '/works/OL137679W', NULL, '2003', 'English', NULL, 1, 0, 'armageddon-tim-f-lahaye', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:03:12', '2026-03-23 04:25:30');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('47614144-1156-4a18-b9bf-c5489a16c150', 'The Old Man and the Sea', 'Set in the Gulf Stream off the coast of Havana, Hemingway''s magnificent fable is the tale of an old man, a young boy and a giant fish. This story of heroic endeavour won Hemingway the Nobel Prize for Literature. It stands as a unique and timeless vision of the beauty and grief of man''s challenge to the elements.', 'An elderly Cuban fisherman, unlucky for months, sets out alone to sea and hooks a massive marlin, leading to a grueling multi-day struggle that pushes him to his physical and mental limits.', 1952, '1505263093', '9798411443394', 132, NULL, 150, 'https://covers.openlibrary.org/b/id/463307-L.jpg', '/works/OL63073W', NULL, '2022', 'English', NULL, 1, 0, 'the-old-man-and-the-sea-ernest-hemingway', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:03:54', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0baa6b0b-b987-4492-a91d-aa240daafcae', 'A Farewell to Arms', 'A Farewell to Arms is about a love affair between the expatriate American Henry and Catherine Barkley against the backdrop of the First World War, cynical soldiers, fighting and the displacement of populations. The publication of A Farewell to Arms cemented Hemingway''s stature as a modern American writer, became his first best-seller, and is described by biographer Michael Reynolds as "the premier American war novel from that debacle World War I."', 'An American ambulance driver in the Italian army during World War I falls in love with a British nurse amid the chaos of battle.', 1929, NULL, '9781983704567', 332, NULL, 512, 'https://books.google.com/books/content?id=Z-FSAgAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL38952692W', NULL, '2018', 'English', NULL, 1, 0, 'a-farewell-to-arms-ernest-hemingway', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:04:33', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b1f503fc-f4e5-4ef0-94a3-62bc0d6ba520', 'Death in the Afternoon Many Photo Illustrations', 'Seen through his eyes, bullfighting becomes a richly choreographed ballet, with performers who range from awkward amateurs to masters of great elegance and cunning. A fascinating look at the history and grandeur of bullfighting, Death in the Afternoon is also a deeper contemplation of the nature of cowardice and bravery, sport and tragedy, and is enlivened throughout by Hemingway''s sharp commentary on life and literature.', 'Ernest Hemingway delves into the art and spectacle of Spanish bullfighting, offering detailed observations on its techniques, history, and participants.', 1952, NULL, NULL, NULL, NULL, NULL, 'https://books.google.com/books/content?id=i6J_EAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL39364074W', NULL, '1952', 'English', NULL, 0, 0, 'death-in-the-afternoon-many-photo-illustrations-ernest-hemingway', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 05:04:35', '2026-03-22 05:02:43');
