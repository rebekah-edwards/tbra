INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('cf37f731-4538-4632-9352-49ac309310bf', 'From Every Tribe and Nation', 'From Every Tribe and Nation is a spirited tale told in the first person of how a boy who grew up in a Baptist community in Cedar Rapids, Iowa, came to know, in his life and in his scholarship, the truth of the words of Revelation, ''By your blood you ransomed for God saints from every tribe and language and people and nation.'' Noll is a good storyteller, and his lively accounts of Christian life and witness across the globe, in Asia and Africa and Eastern Europe, will delight and inspire readers.', 'A historian''s memoir on discovering global Christianity''s diverse stories and cultural shifts.', 2014, NULL, '9781441246424', NULL, NULL, NULL, 'https://books.google.com/books/content?id=mDrknQEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL26788997W', NULL, '2014', 'English', NULL, 0, 0, 'from-every-tribe-and-nation-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:31', '2026-03-23 04:08:14');
