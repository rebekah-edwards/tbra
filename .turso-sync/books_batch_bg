INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f06db183-8b46-4f40-9cc7-f4531baf0bfa', 'Daredevil/Elektra', 'Writer Frank Miller and artist Bill Sienkiewicz are two visionary creators - and when their talents combine, the results are spectacular! In the acclaimed Daredevil graphic novel Love and War, Miller and Sienkiewicz take a unique look at the bitter rivalry between the Man Without Fear and the Kingpin of Crime - as all that Wilson Fisk holds dear is placed in grave danger!', 'A gritty tale of Daredevil and Elektra, exploring their intense rivalry with the Kingpin in a noir-style graphic novel.', 2003, '0785110321', '9780785110323', 328, NULL, NULL, 'https://books.google.com/books/content?id=6s0bAQAAIAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL15016235W', NULL, 'August 2003', 'English', NULL, 1, 0, 'daredevilelektra-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:07:09', '2026-03-23 04:30:06');
