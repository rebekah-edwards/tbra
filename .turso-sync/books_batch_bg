INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e5910ead-9201-4480-ac9f-0e82c8e4fb92', 'Absolute Batman', 'Thirty years after its debut, DC Comics is proud to present the definitive Absolute Edition of this modern comics classic. Together with a wealth of behind-the-scenes material from its creators--including the complete scripts and pencil breakdowns for all four issues--ABSOLUTE BATMAN: YEAR ONE offers two distinct versions of the legendary story: Book One features the acclaimed single-volume graphic novel edition with every page newly rescanned and remastered by Mazzucchelli and Lewis from their original boards, while Book Two features the never-before-collected process color edition of the original newsprint comics, sourced from all-new scans made by Mazzucchelli and Lewis from their personal copies of BATMAN #404-407.', 'A gritty retelling of Batman''s origin, exploring his early days and James Gordon''s fight against Gotham''s corruption.', 2010, '8467452641', '9788467452648', 192, NULL, NULL, 'https://books.google.com/books/content?id=L8IfPAAACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL34990121W', NULL, 'Feb 05, 2010', 'English', NULL, 1, 0, 'absolute-batman-d-mazzucchelli', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:08:05', '2026-03-23 04:22:58');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a8812391-be78-4c9d-9d63-77e096d57ab8', 'All-Star Batman & Robin, the Boy Wonder', 'All hell breaks loose at the circus as Bruce Wayne and gal pal Vicki Vale witness a young boy''s life shattered before their eyes. Orphaned, Dick Grayson has nowhere to go and no one to turn to -- no one but Bruce Wayne!', 'Bruce Wayne takes in orphaned Dick Grayson, forging a dark, intense Batman and Robin origin story. A controversial, violent take on the Dynamic Duo.', 2008, '1401216811', '9781401220082', NULL, NULL, NULL, 'https://books.google.com/books/content?id=l3ePEAAAQBAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL3577219W', NULL, '2008', 'English', NULL, 1, 0, 'allstar-batman-robin-the-boy-wonder-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:08:08', '2026-03-22 04:56:03');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0b775330-ccdd-44d3-8357-a42cfa2f4b45', 'Batman Noir', 'It is ten years after an aging Batman has retired and Gotham City has sunk into decadence and lawlessness. Now as his city needs him most, the Dark Knight returns in a blaze of glory. Joined by Carrie Kelly, a teenage female Robin, Batman takes to the streets to end the threat of the mutant gangs that have overrun the city. And after facing off against his two greatest enemies, the Joker and Two-Face for the final time, Batman finds himself in mortal combat with his former ally, Superman, in a battle that only one of them will survive. Frank Miller''s BATMAN: THE DARK KNIGHT RETURNS in collected here in his and Klaus Janson''s gorgeous black and white pencils and inks.', 'An aging Batman returns to a lawless Gotham, battling iconic foes and societal decay in a dark, gritty tale.', 2015, '140125988X', '9781401259884', NULL, NULL, NULL, 'https://books.google.com/books/content?id=pAI_CQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL37933754W', NULL, '2015', 'English', NULL, 1, 0, 'batman-noir-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:08:09', '2026-03-22 03:11:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ac53a4fe-fc1b-493e-9df6-1e2f0e749bb0', 'Life and Times of Martha Washington in the Twenty-First Century (Second Edition)', 'She will be called a hero, a traitor, and nearly everything in between, but all along the way, her courage, her integrity, and her unwavering commitment to that most valuable of rights-liberty-will inspire a movement that will never surrender. A masterpiece nearly twenty years in the making, this archival volume contains the complete life story of Martha Washington, the twenty-first century freedom fighter created by comic-book megastars Frank Miller (Sin City, 300) and Dave Gibbons (Watchmen).', 'Martha Washington rises from Chicago''s war-torn streets to fight corruption and injustice in a dystopian future.', 2009, '1506700357', '9781595823090', 600, NULL, NULL, 'https://books.google.com/books/content?id=6HskDwAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL21144647W', NULL, '2009', 'English', NULL, 1, 0, 'life-and-times-of-martha-washington-in-the-twentyfirst-century-second-edition-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:09:28', '2026-03-22 04:58:40');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2eee33a7-cc7b-46ef-98c1-c961736b8ac4', 'Martha Washington Saves the World', 'But Venus hasn''t counted on her mortal enemy, Martha Washington, who captains a mission to observe the collision with a massive asteroid whose secrets may provide the key to Venus'' destruction --- and the very key to Creation itself! Frank Miller and Dave Gibbons, along with Angus McKie, have produced another science-fiction tour-de-force of epic magnitude.', 'Martha Washington battles a rogue AI, Venus, in a sci-fi epic full of action and apocalyptic stakes.', 2006, '8498146968', '9788498146967', 112, NULL, NULL, 'https://books.google.com/books/content?id=3Oc_PQAACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL34930738W', NULL, 'Jun 06, 2006', 'English', NULL, 1, 0, 'martha-washington-saves-the-world-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:09:29', '2026-03-22 03:34:43');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('856c160f-a2ee-4843-a84e-0a3d6752541b', 'Give Me Liberty', 'A young girl from the ghetto struggles against impossible odds to save the world from the Fat Boy Burger corporate army, the Aryan Thrust, and the meanest Mr. Clean ever... the Surgeon General! That young girl is Martha Washington, and she redefines heroism in the Eisner Award-winning story.', 'A dystopian graphic novel following Martha Washington, a young girl from the ghetto, as she battles oppressive forces in a satirical future.', 1994, '1569710678', '9781569710678', 208, NULL, NULL, 'https://books.google.com/books/content?id=qWJQAAAAMAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL15016257W', NULL, 'December 1, 1994', 'English', NULL, 1, 0, 'give-me-liberty-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:09:30', '2026-03-22 04:32:04');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('62035631-efc0-42f3-8dfe-420fd6673ee7', 'Daredevil Visionaries - Frank Miller, Vol. 1', 'All the elements that made Miller''s tenure on Daredevil a comic noir classic are here: gritty, street-level action, moody atmosphere, and widescreen adventure told with a cinematic eye. The stories in this volume feature unforgettable characters like the Kingpin, the mammoth king of the New York Underworld; Bullseye, the deranged but deadly assassin; Elektra, the woman Daredevil loves but is forced to oppose; and, of course, Daredevil himself, blind as justice, he is an attorney by day and an urban vigilante by night.', 'A gritty, cinematic take on Daredevil, the blind vigilante attorney, battling crime in New York''s underworld.', 2000, '0785107576', '9780606277143', 176, NULL, NULL, 'https://books.google.com/books/content?id=I3grtAEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL253461W', NULL, 'December 2000', 'English', NULL, 1, 0, 'daredevil-visionaries-frank-miller-vol-1-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:10:21', '2026-03-22 04:08:22');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('492409f3-ad71-4643-a1c2-74ddcabbee23', 'Daredevil de Frank de Miller', NULL, 'A gritty tale of Daredevil, the blind vigilante, battling crime in a dark, urban underworld.', 2009, '8498853656', '9788498853650', NULL, NULL, NULL, 'https://books.google.com/books/content?id=w1yxMwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL35190969W', NULL, 'May 01, 2009', 'English', NULL, 1, 0, 'daredevil-de-frank-de-miller-klaus-janson', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:10:22', '2026-03-22 03:52:24');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('60976456-7da4-4858-b5ca-9fb72524b4c6', 'Frank Miller''s Daredevil Artist''s Edition', 'Frank Miller helped redefine sequential storytelling in the early 1980s. His style, influenced by Will Eisner’s The Spirit, was new and exciting. One of his earliest issues featured the introduction of Elektra and was the first issue Miller wrote. This Artist’s Edition features pages from Miller’s earliest beginnings on Daredevil (issues 159, 163, 165), as well as the glory days when Miller began writing the character as well as drawing it, including #168 (the first appearance of the iconic Elektra), as well as his continuing run on issues 169, 171, 172, 174-181 (#181 being the oversized classic "Death of Elektra"), followed by pages from issues 184-191 (Miller’s final issue).', 'A collection of Frank Miller''s iconic Daredevil artwork, showcasing his groundbreaking storytelling and classic issues.', 2023, NULL, '9798887240046', NULL, NULL, NULL, 'https://books.google.com/books/content?id=ARCSzwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL34200864W', NULL, '2023', 'English', NULL, 1, 0, 'frank-millers-daredevil-artists-edition-roger-mckenzie', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 13:10:24', '2026-03-22 04:07:24');
