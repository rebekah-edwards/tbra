INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9b39a2e0-550a-4876-a1c3-760c0678da44', 'Tobin''s Spirit Guide', 'Absorbing, immersive, and an essential purchase for fans, Ghostbusters: Tobin’s Spirit Guide is the ultimate guide to the franchise’s rogues’ gallery of spirits, specters, demons, and ghouls. This dynamic in-universe book takes fans inside the world of Ghostbusters like never before. Within the world of Ghostbusters, Tobin’s Spirit Guide is a comprehensive supernatural encyclopedia used by our heroes to research ghouls and ghosts. For the first time, this fully-illustrated tome will allow fans to pore through the pages of this legendary guide to the things that go bump in the night, from class 5, free-roaming vapors to giant sloars!', 'An in-universe guide to Ghostbusters'' supernatural entities, detailing spirits and ghouls with immersive illustrations.', 2016, NULL, '9781785654084', NULL, NULL, NULL, 'https://books.google.com/books/content?id=5IyyDAEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL26747174W', NULL, '2016', 'English', NULL, 1, 0, 'tobins-spirit-guide-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:52', '2026-03-22 04:46:11');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6332e24e-b5da-463e-959c-914565ff3643', 'Scenes from the University of Tokyo and Its Hongo Neighborhood', 'One of Japan''s leading young artists, whose imaginative work combines traditional art forms and techniques with the high-tech modern, sketches familiar and unfamiliar sights on the campus of the University of Tokyo and in its historic neighborhood. The set of 24 postcards also includes imaginative renderings of Tokyo''s Narita Airport. Both for those familiar with Tokyo and those to whom it is new, these highly original works will open a whole new world. Prolific young artist Akira Yamaguchi''s work is instantly recognizable in Japan for its unique combination of traditional forms with ultra-modern content.', 'A set of 24 postcards by artist Akira Yamaguchi, depicting imaginative scenes of the University of Tokyo and its Hongo neighborhood.', 2007, '0860085414', '9780860085416', 66, NULL, NULL, 'https://covers.openlibrary.org/b/id/4780911-L.jpg', '/works/OL21430366W', NULL, 'April 30, 2007', 'English', NULL, 0, 0, 'scenes-from-the-university-of-tokyo-and-its-hongo-neighborhood-mark-a-noll', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:46:52', '2026-03-22 04:09:15');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('12572163-d543-4d6b-8420-98676738334f', 'Old Religion in a New World', 'One of our foremost historians of religion here chronicles the arrival of Christianity in the New World, tracing the turning points in the development of the immigrant church that have led to today''s distinctly American faith. Taking a unique approach to this fascinating subject, Noll focuses on what was new about organized Christian religion on the American continent by comparison with European Christianity.', 'A historical exploration of Christianity''s development in North America, focusing on its unique American traits.', 2001, NULL, '9781467414425', NULL, NULL, NULL, 'https://books.google.com/books/content?id=pkHV0QEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL31132120W', NULL, '2001', 'English', NULL, 0, 0, 'old-religion-in-a-new-world-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:53', '2026-03-22 03:16:05');
