INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('717c946f-f59b-4cac-842e-9b893d6838fd', 'In the Beginning Was the Word', 'One of the foremost scholars of American Christianity, Mark Noll brings a wealth of research and wisdom to In the Beginning Was the Word, providing a sweeping, engaging, and insightful survey of the relationship between the Bible and public issues from the beginning of European settlement.', 'A sweeping survey of the Bible''s role in American public life from 1492 to 1783. Explores biblicism and cultural impact.', 2015, NULL, '9780190263980', 448, NULL, NULL, 'https://books.google.com/books/content?id=P7GYCgAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL21109209W', NULL, '2015', 'English', NULL, 0, 0, 'in-the-beginning-was-the-word-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:47:00', '2026-03-22 04:18:29');
