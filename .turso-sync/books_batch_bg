INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('643582d7-0906-478a-8d67-e66ded44323d', 'Godzilla', 'When a coldly single-minded businessman uses an untested element to create clean energy for a profit, he inadvertently awakens the beast from the deep–Godzilla! It will be up to three intrepid middle-school students--with a little magic help from Infant Island--to show Godzilla that not all humans are bad… and that there is still hope for Planet Earth. It''s a kaiju battle like no other by writer Erik Burnham and artist Dan Schoening (Ghostbusters).', 'Middle-grade kids team up with Godzilla to battle kaiju and alien threats in a thrilling comic adventure.', 2024, NULL, '9798887240930', NULL, NULL, NULL, 'https://books.google.com/books/content?id=A2cPEQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL37865237W', NULL, '2024', 'English', NULL, 1, 0, 'godzilla-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:32', '2026-03-22 04:10:00');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4a56f289-9866-4b69-8858-e267fc870cfc', 'Potions Inc', 'The call of adventure always seems to hang up whenever Randelgast Jones tries to answer it, leaving him facing the dull future of working in his family’s successful potion shop. But when a powerful artifact is stolen from his parents and puts them under a terrible curse, Ran finally gets the quest he’s been after his whole life. He and his siblings set off to find the missing artifact – and its trail leads them from their homeland of Primaterra to the very strange realm of…Earth.', 'A reverse portal fantasy where Randelgast Jones seeks adventure, leaving his family''s potion shop to chase a stolen artifact from Primaterra to Earth.', 2022, NULL, '9781960578204', NULL, NULL, NULL, 'https://books.google.com/books/content?id=JmirzwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL37854833W', NULL, '2022', 'English', NULL, 1, 0, 'potions-inc-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:33', '2026-03-22 03:53:23');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1e64d2a8-b63a-4b8f-8e8d-79fbfcbb64c9', 'Beechers', 'They disagreed over issues of slavery, women’s rights, and religion and found themselves at the center of race riots, denominational splits, college protests, a civil war, and one of the most public sex scandals in American history. They were nonetheless unified in their ''Beecherism''—a phrase used to describe their sense of self-importance in reforming the nation.', 'A deep dive into the Beecher family, America''s influential 19th-century dynasty, exploring their impact on slavery, religion, and social reform.', 2024, NULL, '9780807182758', 451, NULL, NULL, NULL, '/works/OL38387783W', NULL, '2024', 'English', NULL, 0, 0, 'beechers-mark-a-noll', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:46:33', '2026-03-22 03:23:47');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f9d3d979-cc44-4612-8286-cfb8fa3d5171', 'Black Science, Vol. 3: Vanishing Point', 'The Anarchist League of Scientists dive deeper into the Onion than ever before. Now veterans of inter-dimensional travel, the team begins to realize how damaging their actions are on the fabric of reality.', 'The Anarchist League of Scientists explores inter-dimensional travel, grappling with the damaging effects on reality in a visually striking comic.', NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, 'English', NULL, 1, 0, 'black-science-vol-3-vanishing-point', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:46:34', '2026-03-20T02:28:56.341Z');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0d0af448-48a8-49bd-86f7-c9267408a108', 'Civil War As a Theological Crisis', 'Viewing the Civil War as a major turning point in American religious thought, Mark A. Noll examines writings about slavery and race from Americans both white and black, northern and southern, and includes commentary from Protestants and Catholics in Europe and Canada. Though the Christians on all sides agreed that the Bible was authoritative, their interpretations of slavery in Scripture led to a full-blown theological crisis.', 'A historical analysis of the Civil War as a theological crisis over slavery and biblical interpretation.', 2006, '0807830127', NULL, 199, NULL, NULL, 'https://books.google.com/books/content?id=599ShoKjwSkC&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL13665439W', NULL, '2006', 'English', NULL, 0, 0, 'civil-war-as-a-theological-crisis-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:35', '2026-03-22 03:12:46');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9e159c2b-e3d1-4f56-9976-df46aaff884c', 'Bill and Ted', 'Party on, dudes! This excellent book of wit and wisdom celebrates the genius of the world-famous Wyld Stallyns and their time-traveling adventure. Once, Bill and Ted made history. Now, they''re ready to share the knowledge they''ve gained traveling through time.', 'Two teens embark on time-traveling adventures to save their future with humor and heart.', 2023, NULL, '9781638720362', NULL, NULL, NULL, 'https://books.google.com/books/content?id=oBko0AEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL36857819W', NULL, '2023', 'English', NULL, 1, 0, 'bill-and-ted-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:35', '2026-03-22 04:48:02');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('07474551-b3b3-405f-949f-ef29216ce5c2', 'Evangelicals', 'Evangelicals provides an illuminating look at who evangelicals are, how evangelicalism has changed over time, and how evangelicalism continues to develop in sometimes surprising ways.', 'A historical analysis of evangelicalism, exploring its intellectual challenges and cultural impact over time.', 2019, NULL, '9780802876959', 288, NULL, NULL, 'https://books.google.com/books/content?id=gGC4EQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL21868204W', NULL, '2019', 'English', NULL, 0, 0, 'evangelicals-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:36', '2026-03-22 03:05:34');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9d746286-75db-458a-ab1f-781da71af2ae', 'Jesus Christ and the Life of the Mind', 'Already an acclaimed Christocentric theology for contemporary evangelical intellectual life, Mark Noll''s Jesus Christ and the Life of the Mind (2011) significantly updates Noll’s critical assessment of evangelical Christian scholarship in his landmark Scandal of the Evangelical Mind (1994).', 'A Christocentric theology exploring how faith in Jesus can inspire evangelical intellectual life and learning.', 2013, NULL, '9781467417891', NULL, NULL, 370, 'https://books.google.com/books/content?id=AHjW0QEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL36120974W', NULL, '2013', 'English', NULL, 0, 0, 'jesus-christ-and-the-life-of-the-mind-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:37', '2026-03-22 04:47:33');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('efe34427-2be9-49a1-8a05-9db4525f4991', 'Prairie Faith', 'In A Prairie Faith, John Fry provides his readers with a nuanced and thoughtful discussion of the spiritual world of Laura Ingalls Wilder. Interweaving these investigations with Wilder’s perennially interesting life story, A Prairie Faith illustrates the Christian practices of pioneers and rural farmers during this dynamic period of American history.', 'A nuanced exploration of Laura Ingalls Wilder''s spiritual life and the Christian practices of pioneers.', 2024, NULL, '9780802876287', NULL, NULL, NULL, NULL, '/works/OL37857062W', NULL, '2024', 'English', NULL, 0, 0, 'prairie-faith-mark-a-noll', 0, NULL, NULL, 0, NULL, 'public', '2026-03-19 00:46:39', '2026-03-23 04:29:42');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1bf26cd0-d6e8-4224-93bd-b92bf621b998', 'Clouds of Witnesses', 'As Africa and Asia take their place as the new Christian heartlands, a new and robust company of saints is coming into view. In seventeen inspiring narratives Mark Noll and Carolyn Nystrom introduce pivotal Christian leaders in Africa and Asia who had tenacious faith in the midst of deprivation, suffering and conflict.', 'Seventeen inspiring narratives of Christian leaders from Africa and Asia, showcasing their faith amid struggles.', 2011, NULL, '9781459621640', NULL, NULL, NULL, 'https://books.google.com/books/content?id=NsOYqq-NtDMC&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL28029097W', NULL, '2011', 'English', NULL, 0, 0, 'clouds-of-witnesses-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:40', '2026-03-22 03:22:21');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0dd9bc09-510b-4fae-8188-083f30236ed2', 'Haunted America', 'New York City doesn''t have a monopoly on the supernatural, and it was only a matter of time before apparitions in other areas were enhanced by the expansion of psychokinetic energy! Haunted America finds the Ghostbusters venturing out far beyond the comfortable confines of the Empire State. This ghostly tour has stops in Detroit, New Orleans, Roswell, and Seattle.', 'The Ghostbusters tackle hauntings across America, from Detroit to Seattle, in a supernatural comic adventure.', 2016, NULL, '9781614794967', NULL, NULL, NULL, 'https://books.google.com/books/content?id=KhyBMAEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL34351821W', NULL, '2016', 'English', NULL, 1, 0, 'haunted-america-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:41', '2026-03-22 03:13:20');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6b38e4de-12b5-4d0e-906b-1ae83b29f36c', 'Wonderful Words of Life', 'While many evangelical congregations have moved away from hymns and hymnals, these were once central fixtures in the evangelical tradition. This book examines the role and importance of hymns in evangelicalism, not only as a part of worship but as tools for theological instruction, as a means to identity formation, and as records of past spiritual experiences of the believing community.', 'A deep dive into the role of hymns in American Protestant history and theology. Explores their impact on worship and identity.', 2004, NULL, '9781467422253', NULL, NULL, NULL, 'https://books.google.com/books/content?id=Oz-4EQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL36092348W', NULL, '2004', 'English', NULL, 0, 0, 'wonderful-words-of-life-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:42', '2026-03-22 04:14:17');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('18c5f27b-f84b-45eb-ac2a-fb40de7c77e3', 'Protestants in America', 'The book covers their involvement in critical issues from temperance to the civil rights movement, the establishment of Protestant organizations like the American Bible Society and the Salvation Army, and the significant expansion of their ethnic base since the first African-American Protestant churches were built in the 1770s. Mark Noll follows their direct impact on American history--from the American Revolution to World War I and beyond--and peppers his account with profiles of leading Protestants, from Jonathan Edwards and Phillis Wheatley to Billy Graham and Martin Luther King, Jr.', 'A detailed history of Protestantism in America, exploring its origins, diversity, and impact on society from colonial times to today.', 2000, NULL, '9781280559921', NULL, NULL, NULL, 'https://books.google.com/books/content?id=CagNAQAAMAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL29375531W', NULL, '2000', 'English', NULL, 0, 0, 'protestants-in-america-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:43', '2026-03-22 03:20:19');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1f9961e9-e949-499d-ab5e-477fb3e15d76', 'Ghostbusters, Volume 3', 'Walter Peck has shipped the Ghostbusters around America to deal with other haunted cities. In this tale, they face the ghost of a Civil War soldier, Major General...', 'The Ghostbusters embark on a spooky road trip across the US, tackling haunted locations and ghostly encounters in this episodic comic adventure.', 2016, '1614794952', '9781614794950', NULL, NULL, NULL, 'https://books.google.com/books/content?id=KhyBMAEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL31673902W', NULL, '2016-08-15', 'English', NULL, 1, 0, 'ghostbusters-volume-3-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:43', '2026-03-22 03:24:46');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('178d37a9-8a5c-48ee-bbdc-8a777b3bdefc', 'Army of Darkness vs Reanimator', 'HORROR ICONS CLASH! When an archaeological dig unveils an important element from the world of the Army of Darkness, it ends up in the absolute worst hands of all: Dr. Herbert West''s. As West tinkers in God''s domain, our reluctant hero is once more drawn into the sphere of destiny as he faces a triple threat of danger! Writer Erik Burnham is joined by returning Dynamite artist Eman Casallos to bring you all the excitement and Deadite action!', 'Horror icons clash as Ash from Army of Darkness battles Dr. Herbert West''s reanimation horrors in a thrilling, violent comic crossover.', 2023, NULL, '9781524123086', 112, NULL, NULL, 'https://books.google.com/books/content?id=dLh_zwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL31126505W', NULL, '2023', 'English', NULL, 1, 0, 'army-of-darkness-vs-reanimator-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:45', '2026-03-22 03:19:38');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('705e8de4-21fe-40a1-b929-2be736709742', 'New Shape of World Christianity', 'With characteristic rigor and insight, in this book Mark Noll revisits the history of the American church in the context of world events. He makes the compelling case that how Americans have come to practice the Christian faith is just as globally important as what the American church has done in the world.', 'Mark A. Noll explores how American Christianity shapes global faith, reflecting on historical and cultural influences.', 2010, NULL, '9780830878819', NULL, NULL, NULL, 'https://books.google.com/books/content?id=wN-bEAAAQBAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL28029845W', NULL, '2010', 'English', NULL, 0, 0, 'new-shape-of-world-christianity-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:45', '2026-03-22 04:17:46');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4010d210-4c87-4059-ac9b-29ed12db8898', 'Lady Hel', 'LADY HEL IS BACK TO RECLAIM HER THRONE - NO MATTER WHO HAS TO PAY! She is the very personification of death - or at least she WAS. When we last saw Lady Hel, she was paying the price for messing with the half-demon, Purgatori.', 'Lady Hel, the personification of death, fights to reclaim her throne in a chaotic underworld. A dark, action-packed comic series.', 2023, NULL, '9781524123116', NULL, NULL, NULL, 'https://books.google.com/books/content?id=rVwGEQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL31098926W', NULL, '2023', 'English', NULL, 1, 0, 'lady-hel-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:45', '2026-03-22 03:46:04');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d8bb27a9-a6cd-4291-94d5-bc8c09e5de31', 'Potions Inc Vol. 1', 'The call of adventure always seems to hang up whenever Randelgast Jones tries to answer it, leaving him facing the dull future of working in his family’s successful potion shop. But when a powerful artifact is stolen from his parents and puts them under a terrible curse, Ran finally gets the quest he’s been after his whole life. He and his siblings set off to find the missing artifact – and its trail leads them from their homeland of Primaterra to the very strange realm of… Earth.', 'Randeelgast Jones, tired of his family''s potion shop, embarks on a quest to recover a stolen heirloom, journeying from Primaterra to Earth.', 2022, NULL, '9781952303210', NULL, NULL, NULL, 'https://books.google.com/books/content?id=JmirzwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL28839701W', NULL, '2022', 'English', NULL, 1, 0, 'potions-inc-vol-1-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:47', '2026-03-23 04:14:22');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9fbd8a5b-4ebd-4194-9793-3dac7cdece82', 'Marvel-Verse', 'In the whole Marvel-Verse, nobody is as skilled a hunter as Kraven - and these are the tales that show how nobody is safe from his predatory prowess! Sergei Kravinoff and his family will prove more than a match for a trio of action-packed arachnid adventurers - Peter Parker, Gwen Stacy and Miles... Whether the Hunter is targeting Peter himself, or setting his sights on the winged menace known as the Vulture, you can guarantee that the ensuing Kraven/Spidey battle will be wild! But when Kraven switches his focus to Deadpool, the chaos will attract the attention of the Avengers! Collecting MARVEL ACTION SPIDER-MAN (2018) #5-6, MARVEL ADVENTURES SPIDER-MAN (2005) #7, MARVEL ADVENTURES SUPER HEROES (2010) #4, SPIDEY (2015) #9.', 'Kraven the Hunter stalks Spider-Man and other heroes in action-packed Marvel tales for new readers.', 2023, NULL, '9781302954659', NULL, NULL, NULL, 'https://books.google.com/books/content?id=rNbJEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL28095831W', NULL, '2024', 'English', NULL, 1, 0, 'marvelverse-erik-burnham', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:48', '2026-03-22 04:49:25');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('eeb1d1d9-8093-4ccb-8153-864efc7c94ab', 'Documentary History of Religion in America', 'For decades students and scholars have turned to the two-volume Documentary History of Religion in America for access to the most significant primary sources relating to American religious history from the sixteenth century to the present. This fourth edition—published in a single volume for the first time—has been updated and condensed, allowing instructors to more easily cover the material in a single semester. With more than a hundred illustrations and a rich array of primary documents ranging from the letters and accounts of early colonists to tweets and transcripts from the 2016 presidential election, this volume remains an essential text for readers who want to encounter firsthand the astonishing scope of religious belief and practice in American history.', 'A comprehensive collection of primary sources tracing the history of religion in America from the 16th century to today.', 2018, '0802873588', '9780802873583', 800, NULL, NULL, 'https://books.google.com/books/content?id=KRG3EQAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL20175536W', NULL, 'Jul 31, 2018', 'English', NULL, 0, 0, 'documentary-history-of-religion-in-america-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:48', '2026-03-23 04:29:05');
