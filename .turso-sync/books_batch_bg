INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9e17164f-7730-41e3-8ff8-7ed8fc5ad024', 'America''s God', 'Mark Noll has given us the definitive history of Christian theology in America from the time of Jonathan Edwards to the presidency of Abraham Lincoln. It is a story of a flexible and creative theological energy that over time forged a guiding national ideology. Tragically, this sense of religious purpose set the stage for the Civil War, as the conviction of Christians both North and South that God was on their side served to deepen a schism that would soon rend the young nation asunder.', 'A definitive history of Christian theology in America from Jonathan Edwards to Abraham Lincoln, exploring its cultural and political impact.', 2002, NULL, '9781435618923', 208, NULL, NULL, 'https://books.google.com/books/content?id=LanKhFle9BUC&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL29381048W', NULL, '2002', 'English', NULL, 0, 0, 'americas-god-mark-a-noll', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:46:54', '2026-03-22 04:48:04');
