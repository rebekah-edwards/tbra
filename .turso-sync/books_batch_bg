INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e6a24b43-e556-4386-a065-e4bdc151ede8', 'RoboCop', 'Miller re-defined the presentation of comic book characters and heroic fiction with his grand-daddy of graphic novels, ''The Dark Knight.'' This revolutionary work not only kicked off the series of Batman films based on his redefinition, but a craze for such material that has thrown dozens of such heroes into multiple film franchise heaven. Certainly chief among these has been Miller''s uniquely classical take on superheroic narrative, ''300,'' and his ''Sin City'' books, each of which entered motion pictures with historic successes, and each now in Miller''s creative phase of achieving its highly-anticipated sequel.', 'A dystopian comic adaptation of Frank Miller''s unfilmed RoboCop 2 script, exploring dark themes of humanity and corporate corruption.', 2014, '2360740008', '9782360740000', 96, NULL, NULL, 'https://books.google.com/books/content?id=eEo1DwAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL24567828W', NULL, 'Aug 21, 2014', 'English', NULL, 1, 0, 'robocop-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:48:13', '2026-03-23 04:23:44');
