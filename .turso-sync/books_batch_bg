INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('43faae25-9b3f-4e0e-aadf-db581ea0556d', 'Year One', 'In 1986, Frank Miller and David Mazzucchelli produced this groundbreaking reinterpretation of the origin of Batman: who he is and how he came to be. Sometimes careless and naive, this Dark Knight is far from the flawless vigilante he is today. In his first year on the job, Batman feels his way around a Gotham City far darker than the one he left.', 'A gritty reinterpretation of Batman''s origin, exploring his first year as a flawed vigilante in a dark Gotham City.', 2001, NULL, '9781852860776', 96, NULL, NULL, 'https://covers.openlibrary.org/b/id/12626155-L.jpg', '/works/OL25641243W', NULL, '2001', 'English', NULL, 1, 0, 'year-one-david-mazzucchelli', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:34', '2026-03-22 03:48:46');
