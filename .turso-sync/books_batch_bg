INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('095ea641-da31-4ce2-a8ba-1fd38707d664', 'Frank Miller''s Sin City Volume 5', 'The girls of Old Town are cashing in old debts in this tale from the acclaimed crime noir series, presented at original size, including a new pinup gallery, and featuring new wrap-around cover art by Frank Miller. Dwight McCarthy owes Gail and the girls of Old Town more than he can ever pay back, and they’re putting him to the test.', 'Dwight McCarthy repays a debt to the girls of Old Town in a gritty crime noir tale of vengeance and family values.', 2022, NULL, '9781506722863', 144, NULL, NULL, 'https://covers.openlibrary.org/b/id/12501575-L.jpg', '/works/OL26673066W', NULL, '2022', 'English', NULL, 1, 0, 'frank-millers-sin-city-volume-5-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:22', '2026-03-22 03:10:27');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b97e98d7-95b9-498e-a7e2-0974f640f572', 'Frank Miller''s Sin City Volume 6', 'Stories of those lost in the gritty and crime-laden asphalt jungle are together in this collection from the acclaimed noir, presented at original size with new wrap-around cover art by Frank Miller. There are all kinds of dark business you might encounter on a cold night in Basin City, and the tales here paint a gloriously dirty portrait.', 'A gritty anthology of dark tales set in the crime-ridden Basin City, exploring noir themes of violence and corruption.', 2022, NULL, '9781506728421', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14756352-L.jpg', '/works/OL27245443W', NULL, '2022', 'English', NULL, 1, 0, 'frank-millers-sin-city-volume-6-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:23', '2026-03-22 05:07:03');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('bb5f0e79-e8ed-49f8-8ef1-cf1030bb4826', 'Frank Miller''s Sin City Volume 2', 'He’d give anything to cut loose, to just feel the fire, one more time. But he can’t let himself lose control again, can’t ever let the monster out . . . And then Ava calls. The fourth editions of Frank Miller’s hit graphic novel series continue with Volume 2 A Dame to Kill For.', 'A dark noir tale of obsession and betrayal in Sin City, where old flames and deadly desires collide.', 2021, NULL, '9781506728384', 216, NULL, NULL, 'https://books.google.com/books/content?id=3O9KEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL25334547W', NULL, '2021', 'English', NULL, 1, 0, 'frank-millers-sin-city-volume-2-frank-miller', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-19 00:48:24', '2026-03-22 05:08:22');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3c525563-4f6b-42e0-8f96-f9244c66b72e', 'Frank Miller''s Sin City Volume 1', 'The acclaimed crime noir from comics legend Frank Miller is presented at original size with new wrap-around cover art and pinup gallery. This tale of Marv and his angel is steeped in murder, mystery, corruption, and vengeance. There is no light in a place like Sin City—only misery, crime, perversion.', 'A gritty crime noir in a dystopian city, following Marv''s violent quest for vengeance after a murder. A dark, ultra-violent graphic novel.', 2021, NULL, '9781506728377', 224, NULL, NULL, 'https://covers.openlibrary.org/b/id/12400105-L.jpg', '/works/OL25317977W', NULL, '2021', 'English', NULL, 1, 0, 'frank-millers-sin-city-volume-1-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:24', '2026-03-22 03:44:07');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b5b5f38c-1ca8-4444-a3f1-05979f2d0299', 'Frank Miller''s Sin City Volume 3', 'The fascinatingly conflicted Dwight McCarthy returns in this blood-soaked chapter of the signature series, presented at original size with new wrap-around cover art by Frank Miller. Dwight owes a debt to the girls of Old Town. These dangerous women who walk the night have saved him more times than he can count, and finding friends like that isn’t easy.', 'Dwight McCarthy returns in a gritty, blood-soaked noir tale, owing a debt to the dangerous women of Old Town in Sin City.', 2022, NULL, '9781506728391', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14697285-L.jpg', '/works/OL26040708W', NULL, '2022', 'English', NULL, 1, 0, 'frank-millers-sin-city-volume-3-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:25', '2026-03-22 05:05:09');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('aaedbc72-66de-48f7-b171-895c0e4ee139', 'Captain America Epic Collection', 'It''s another good collection that sees the Star-Spangled Avenger face old foes and new. The volume begins with a story by Roger Stern and Frank Miller, featuring Cap up against a ring of desperate arsonists, but the rest of the stories are written by Michael Carlin (the first third) and Mark Gruenwald (the rest), and drawn by Paul Neary.', 'Captain America battles foes old and new in thrilling short stories of patriotism and action.', 2014, NULL, '9781302930707', 504, NULL, NULL, 'https://covers.openlibrary.org/b/id/13511075-L.jpg', '/works/OL21083955W', NULL, '2021', 'English', NULL, 1, 1, 'captain-america-epic-collection-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'import_only', '2026-03-19 00:48:28', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9eca0ba9-b05f-4bde-9cd3-1cec21dd288d', 'Hell and Back', 'In the Town Without Pity, good men are hard to find. Enter Wallace, a man of mystery. He''s a nice guy who''s very good at killing people. Out for an evening drive along the beach, he meets the woman of his dreams-and she''s trying to kill herself. Why? And who are the shadowy cabal of power brokers who wrench her from his arms?', 'Wallace, a skilled killer, fights to save a woman from a shadowy cabal in the gritty, violent world of Sin City.', 2001, '1840231270', '9781840231274', 296, NULL, NULL, 'https://covers.openlibrary.org/b/id/12623091-L.jpg', '/works/OL27292757W', NULL, '2001', 'English', NULL, 1, 0, 'hell-and-back-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:29', '2026-03-22 04:48:39');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4f23a301-3f04-409b-b9bb-80128516dc0a', 'Marvel Comics in The 1980s', 'TwoMorrows Publishing presents Marvel Comics in the 1980s, the third volume in Pierre Comtois’ heralded series covering the pop culture phenomenon on an issue-by-issue basis! This new book covers Marvel’s final historical phase, when the movement begun by Stan Lee, Jack Kirby, and Steve Ditko moved into a darker era that has yet to run its course. The 1980s saw Stan Lee''s retreat to the West Coast, Jim Shooter''s rise and fall as editor-in-chief, the twin triumphs of Frank Miller and John Byrne, the challenge of independent publishers, and the weakening hold of the Comics Code Authority that led to the company''s creative downfall―and ultimately the marginalization of the industry itself.', 'A detailed exploration of Marvel Comics in the 1980s, covering iconic series, darker themes, and industry upheaval.', 2015, NULL, '9781605490595', 224, NULL, NULL, 'https://covers.openlibrary.org/b/id/12711867-L.jpg', '/works/OL21276231W', NULL, '2015', 'English', NULL, 0, 0, 'marvel-comics-in-the-1980s-frank-miller', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-19 00:48:30', '2026-03-22 03:56:28');
