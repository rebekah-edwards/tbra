my, tense romance.', 2018, '8381783623', '9781721284443', 391, NULL, 814, 'https://covers.openlibrary.org/b/id/10831263-L.jpg', '/works/OL24314065W', NULL, '2018-06-20', 'English', 'CreateSpace Independent Publishing Platform', 1, 0, NULL, 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-25 02:54:20', '2026-03-25T02:54:33.359Z');
