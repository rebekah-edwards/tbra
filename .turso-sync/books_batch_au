INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('832421e8-3cac-4374-b294-85732b1f1ab2', 'Fully Loaded', 'From the author of DESERT PLACES and LOCKED DOORS comes this complete collection of short stories and novellas. *69 - Tim and Laura West receive a bizarre voicemail on their answering machine that seems to have unintentionally recorded a brutal murder.', 'A chilling collection of short stories by Blake Crouch, packed with horror, suspense, and brutal murder.', 2011, NULL, '9781458140791', NULL, NULL, NULL, NULL, '/works/OL40028419W', NULL, '2011', 'English', NULL, 1, 0, 'fully-loaded-blake-crouch', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:28:59', '2026-03-22 04:30:19');
