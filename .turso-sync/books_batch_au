INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3d8c4481-0672-4903-a120-22f60272d3cb', 'Weather', 'On the same day that it''s icy cold in the Artic, it''s foggy in Louisiana, sunny in Barbados, and blowing wild winds called willy-willies in Austrailia. In this poetic exploration of longitude and weather, with bright and detailed paintings of seventeen different places, the author and illustrator show us what''s happening from the poles to the equator — all on the same day in March.', 'A poetic exploration of weather across the globe, capturing diverse climates on a single day in March.', 2008, NULL, '9781405331319', NULL, NULL, NULL, NULL, '/works/OL37816866W', NULL, '2008', 'English', NULL, 0, 0, 'weather-nicola-barber', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 15:20:26', '2026-03-22 03:44:43');
