INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('4c76c08f-0eda-442f-b2ea-1cd3772b854e', 'Swordheart', 'Halla has unexpectedly inherited the estate of the wealthy distant uncle she''s been caring for for the past decade. Unfortunately, she is also saddled with money-hungry relatives full of devious plans for how to wrest the inheritance away from her.

While hiding in her bedroom to escape her family, Halla inspects the ancient sword that''s been collecting dust on the wall since before she moved in. On a whim, she pulls it down and unsheaths it—and suddenly a man appears in her bedroom. His name is Sarkis, he tells her, and he is an immortal warrior trapped in a prison of enchanted steel.

Sarkis is sworn to protect whoever wields the sword, and for Halla—a most unusual wielder—he finds himself not fending off grand armies and deadly assassins but instead everything from kindly-seeming bandits to roving inquisitors to her own in-laws. But as Halla and Sarkis become closer, they overlook the biggest threat of all—the sword itself.', NULL, 2018, '1614504636', '9781614505228', 456, NULL, 872, 'https://covers.openlibrary.org/b/id/10029991-L.jpg', '/works/OL20783649W', NULL, 'Apr 14, 2020', 'English', NULL, 1, 0, 'swordheart-t-kingfisher', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:29:37', '2026-03-24 23:24:42');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7164c10a-f6f8-4a27-81f1-b208528d5ca7', 'Stirred', 'Lt. Jacqueline ''Jack'' Daniels has seen humanity at its most depraved and terrifying. She''s lost loved ones. Come close to death countless times. But she always manages to triumph over evil. Luther Kite is humanity at its most depraved and terrifying. He''s committed unthinkable acts. Taken human life with unparalleled depravity. Jack has never encountered a serial killer like Luther Kite. So he''s built something especially for Jack. His own private ninth circle of hell--a nightmare world in a forgotten place from which no one has ever escaped. It''s J.A. Konrath''s greatest heroine versus Blake Crouch''s greatest villain in Stirred, the stunning conclusion to both Konrath''s Lt. Jacqueline ''Jack'' Daniels thriller series and Crouch''s Andrew Z. Thomas series. Only one can survive. And it won''t be who you think.', 'Lt. Jack Daniels faces off against the depraved Luther Kite in a thrilling, dark conclusion to two iconic series.', 2012, '1455839973', '9781455839971', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14575181-L.jpg', '/works/OL17455924W', NULL, 'Feb 21, 2012', 'English', NULL, 1, 0, 'stirred-blake-crouch', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:29:38', '2026-03-22 04:18:28');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('72ac0699-76d8-4066-abee-a4fffb61ef67', 'Silanus the Christian', 'In "Silanus the Christian," Edwin A. Abbott crafts a compelling narrative that intertwines themes of faith, identity, and moral struggle against the backdrop of early Christian society. Set in the first century, the novel presents Silanus, a fictional character whose journey reflects the tumultuous conflicts between pagan traditions and the burgeoning Christian faith.', 'A Roman nobleman converts to Christianity in ancient Rome, exploring faith and identity amidst religious turmoil.', 2018, NULL, '9781986955157', 188, NULL, NULL, NULL, '/works/OL40767831W', NULL, '2018', 'English', NULL, 1, 0, 'silanus-the-christian-edwin-abbott-abbott', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:29:38', '2026-03-22 04:19:13');
