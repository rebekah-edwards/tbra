INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('859e8604-292c-4a7c-abee-6e3ae060de5f', 'Movable Type', 'David Finkelstein''s study is a timely one - to use a printing term, a justified history. In three densely argued and fact-filled chapters, David Finkelstein provides an outstanding account of how locally shaped nineteenth-century compositors operated within global contexts... Movable Types is an impressive achievement that will hopefully stimulate extensive scholarly engagement.', 'A historical exploration of Victorian printers and their global impact, blending detailed research with cultural insights.', 2019, NULL, '9781401291341', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/8770121-L.jpg', '/works/OL20110232W', NULL, '2019', 'English', NULL, 0, 0, 'movable-type-kat-howard', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 15:20:53', '2026-03-22 04:32:11');
