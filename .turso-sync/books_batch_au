INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a3b516c5-c297-4e73-8b80-4fd32a4553b1', 'Young Person''s Guide to the Opera', 'Opera--as popular today as ever--comes to life in this elegant introduction. Through conversational text, informative sidebars, and full-color photographs, young readers will learn about the talented people--composers, singers, musicians, stagehands, set and costume designers, makeup crews--and the technical wizardry that go into staging opera''s lavish performances. The rich story lines of many operas also grace these pages, along with lively tales about the composers and singers who have made them so popular. The accompanying CD features musical excerpts from such famous operas as Mozart''s The Magic Flute, Rossini''s The Barber of Seville, and Puccini''s Madama Butterfly.', 'An engaging introduction to opera for young readers, exploring its history, stories, and performers with a companion CD.', 2001, '0152164987', '9780152164980', 55, NULL, NULL, 'https://covers.openlibrary.org/b/id/6878612-L.jpg', '/works/OL15077438W', NULL, '2001', 'English', NULL, 0, 0, 'young-persons-guide-to-the-opera-nicola-barber', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 15:20:38', '2026-03-22 04:52:32');
