INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('dcf5f4c0-3377-47e8-b1a2-39433c628b36', 'Sword in the Stone', 'When Merlyn the magician comes to tutor Sir Ector''s sons Kay and the Wart, schoolwork suddenly becomes much more fun. After all, who wouldn''t enjoy being turned into a fish, or a badger, or a snake? But Merlyn has very particular plans for the Wart. This is the children''s story of King Arthur''s childhood which was the basis for the still popular Disney cartoon of the same title.', 'A whimsical tale of young Arthur, tutored by Merlyn through magical transformations, exploring medieval life and destiny.', 2020, NULL, '9798565946550', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/12387482-L.jpg', '/works/OL1388027W', NULL, '2020', 'English', NULL, 1, 0, 'sword-in-the-stone-t-h-white', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:29:00', '2026-03-23 04:17:05');
