INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2127da03-0720-4b09-add5-a45a4fea92df', 'Famous', 'From New York’s avant-garde, off-off Broadway scene to the glitter of Los Angeles, Lance embarks on a journey toward becoming James Jansen that will take him closer to the star than even he had dreamed—and to darker lengths than he could’ve possibly imagined. Shot through with dark humor and building to a truly shocking conclusion, Famous is a scary, surprising, genre-blending thrill ride as only Blake Crouch can deliver.', 'A man resembling a Hollywood star pursues fame in a darkly humorous, suspenseful tale. A genre-bending thrill ride.', 2025, NULL, '9798217091560', 208, NULL, NULL, NULL, '/works/OL40082808W', NULL, '2025', 'English', NULL, 1, 0, 'famous-blake-crouch', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:28:52', '2026-03-22 03:25:32');
