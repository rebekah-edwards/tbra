INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('40e6d7b0-16ea-41ab-9f76-6c66b513ca17', 'Last American Man', 'Finalist for the National Book Award. From the New York Times bestselling author of Eat Pray Love, Big Magic and City of Girls comes a riveting exploration of manhood and all its complicated meanings through the portrait of an American Mountain Man. In this rousing examination of contemporary American male identity, acclaimed author and journalist Elizabeth Gilbert explores the fascinating true story of Eustace Conway.', 'A captivating biography of Eustace Conway, a modern frontiersman living off the land, exploring American male identity.', 2002, '0670030864', NULL, 271, NULL, 3000, 'https://covers.openlibrary.org/b/id/400229-L.jpg', '/works/OL14955083W', NULL, '2002', 'English', NULL, 0, 0, 'last-american-man-elizabeth-gilbert', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:39:11', '2026-03-22 03:46:28');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ed0fa64e-5ed6-42a0-b407-46f8350ca7ba', 'Heiress Apocalypse', 'Heiress Apocalypse is an enthralling, entertaining, thought-provoking vision of a truly scary future that just might be waiting if we live long enough. After global disaster, a dysfunctional family rules inside an underground mountain city that is crumbling. When it blows up, the daughter takes the survivors to her new outpost away from the mountain…right in the path of the attacking Vagabond army.', 'A gripping tale of a dysfunctional family ruling a crumbling underground city after a global disaster, facing threats from within and without.', 2013, NULL, '9781492189817', 172, NULL, NULL, 'https://books.google.com/books/content?id=idkXnwEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL39952342W', NULL, '2013', 'English', 'CreateSpace Independent Publishing Platform', 1, 0, 'heiress-apocalypse-peter-swanson', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:39:12', '2026-03-23 04:28:10');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('72c33a48-2a28-4a5f-8166-12032aee0543', 'Pilgrims', 'When it appeared in 1997, Elizabeth Gilbert’s story collection, Pilgrims, immediately announced her compelling voice, her comic touch, and her amazing ear for dialogue. The heroes of Pilgrims, Elizabeth Gilbert’s gimmickless story collection, are everyday seekers. This first-time writer has all the hallmarks of a great writer: sympathy, wit, and an amazing ear for dialogue.', 'A debut collection of 12 short stories exploring loneliness and the search for connection across varied settings.', 1998, '0330351745', '9780330351744', 288, NULL, 1500, 'https://covers.openlibrary.org/b/id/3783624-L.jpg', '/works/OL41813W', NULL, 'April 9, 1998', 'English', NULL, 1, 0, 'pilgrims-elizabeth-gilbert', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:39:12', '2026-03-22 04:19:15');
