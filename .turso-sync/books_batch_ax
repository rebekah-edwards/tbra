INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9ee96dd7-8fd6-48a1-9c8a-7caba2857542', 'Play Nice', 'Clio Louise Barnes leads a picture-perfect life as a stylist and influencer, but beneath the glossy veneer she harbors a not-so glamorous secret: she grew up in a haunted house. Well, not haunted. Possessed. After Clio’s parents'' messy divorce, her mother, Alex, moved Clio and her sisters into a house occupied by a demon. Or so Alex claimed. That’s not what Clio’s sisters remember or what the courts determined when they stripped her of custody after she went off the deep end. But Alex was insistent; she even wrote a book about her experience in the house.

After Alex’s sudden death, the supposedly possessed house passes to Clio and her sisters. Where her sisters see childhood trauma, Clio sees an opportunity for house flipping content. Only, as the home makeover process begins, Clio discovers there might be some truth to her mother’s claims. As memories resurface and Clio finally reads her mother’s book, a sinister presence in the house manifests, revealing ugly truths that threaten to shake Clio’s beautiful life to its very foundation.', 'Influencer Clio inherits her childhood home, once claimed to be demon-possessed by her unstable mother.', 2025, '0593642570', '9780593642573', 336, NULL, 617, 'https://covers.openlibrary.org/b/id/15127164-L.jpg', '/works/OL42431897W', NULL, '2025', 'English', NULL, 1, 0, 'play-nice-rachel-harrison', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:39:45', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('285b9a15-ade7-40da-a077-1387a83c27c1', 'Brave New Love', 'When society crumbles, can young love survive? When the young are deprived of their bright future and left to survive day to day, what bonds remain between individuals? Can young love survive a dystopian nightmare? This exciting collection of stories explores the struggles, both emotional and physical, of teenagers trying to survive as society falls apart or as they help build a new world.', 'Brave New Love is an anthology of 15 short dystopian stories centered on young love and desire in crumbling, oppressive worlds.', 2012, NULL, '9781849016018', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/7586019-L.jpg', '/works/OL17441868W', NULL, '2012', 'English', NULL, 1, 0, 'brave-new-love-carrie-ryan', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:39:45', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1e8f8160-c08d-4f0b-8520-e6537d2539eb', 'Reborn', 'The Branch is in shambles, but Anna, Sam, Cas, and Nick can''t rest easy. After following Anna''s narration and relationship with Sam in Altered and Erased, we finally get a chance to hear from fellow team member Nick. The narration in Reborn is split between Nick and a new character, Elizabeth, who has her own connection to the Branch and Nick.', 'A fast-paced dystopian thriller where Nick and Elizabeth uncover secrets tied to the Branch.', 2015, NULL, '9780316197069', 336, NULL, 436, 'https://covers.openlibrary.org/b/id/10800787-L.jpg', '/works/OL21548126W', NULL, '2015', 'English', NULL, 1, 0, 'reborn-jennifer-rush', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:39:46', '2026-03-22 03:23:55');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('ad07e279-c68b-45a5-8c1f-f6a93fc47b9b', 'Foretold', 'Richelle Mead, Lisa McMann, Michael Grant, Meg Cabot, Laini Taylor, and nine more of the hottest YA authors to hit the shelves explore the concepts of prophecy and prediction in this story collection edited by NYT bestselling author of The Forest of Hands and Teeth, Carrie Ryan. Have you ever been tempted to look into the future? To challenge predictions? To question fate? It’s human nature to wonder about life’s twists and turns. But is the future already written—or do you have the power to alter it? From fantastical prophecies to predictions of how the future will transpire, Foretold is a collection of stories about our universal fascination with life’s unknowns and of what is yet to come as interpreted by 14 of young adult fiction’s brightest stars.', 'An anthology of 14 YA stories exploring prophecies and predictions, crafted by top authors like Richelle Mead and Laini Taylor.', 2014, NULL, '9781484412879', NULL, NULL, NULL, 'https://books.google.com/books/content?id=PZZuvgEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL34357394W', NULL, '2014', 'English', 'Random House Books for Young Readers', 1, 0, 'foretold-carrie-ryan', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:39:47', '2026-03-22 04:59:12');
