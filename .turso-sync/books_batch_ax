INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('13be24a4-730d-4add-9155-444013f29a91', 'Framing First Contact', 'Representations of first contact—the first meetings of European explorers and Native Americans—have always had a central place in our nation’s historical and visual record. They have also had a key role in shaping and interpreting that record. In Framing First Contact author Kate Elliott looks at paintings by artists from George Catlin to Charles M. Russell and explores what first contact images tell us about the process of constructing national myths—and how those myths acquired different meanings at different points in our nation’s history.', 'An exploration of first contact imagery in American art, analyzing how artists shaped national myths through paintings of European explorers and Native Americans.', 2020, NULL, '9780806167114', 174, NULL, 1440, NULL, '/works/OL21912869W', NULL, '2020', 'English', NULL, 0, 0, 'framing-first-contact-kate-elliott', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:35:27', '2026-03-22 03:16:53');
