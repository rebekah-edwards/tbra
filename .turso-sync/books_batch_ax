INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('02eca96b-d272-40dc-9968-e1b3419c2922', 'Age of Myth', '"Michael J. Sullivan''s trailblazing career began with the breakout success of his Riyria series: full-bodied, spellbinding fantasy adventures whose imaginative scope and sympathetic characters won a devoted readership and comparisons to fantasy masters Brandon Sanderson, Scott Lynch, and J.R.R. Tolkien himself. Now, Sullivan''s stunning hardcover debut, Age of Myth, inaugurates an original five-book series--and one of fantasy''s finest next-generation storytellers continues to break new ground. Since time immemorial, humans have worshiped the gods they call Fhrey, truly a race apart: invincible in battle, masters of magic, and seemingly immortal. But when a god falls to a human blade, the balance of power between humans and the those they thought were gods changes forever. Now only a few stand between humankind and annihilation: Raithe, reluctant to embrace his destiny as the God Killer. Suri, a young seer burdened by signs of impending doom. And Persephone, who must overcome personal tragedy to lead her people. The Age of Myth is over. The time of rebellion has begun"--

"A new series set in the world of the Riyria Chronicles. In the land of the Rhune, trees can tell the future and the gods are beyond reproach. But when Raithe''s father is slain, he does the unthinkable--he kills a god. From this act, rises the legend of the God Killer, the seeds of a rebellion, and the question of whether the gods are really immortal after all"--', 'In a world where humans revere the immortal, magical Fhrey as gods, a defiant warrior kills one, igniting rebellion and challenging the divine order.', NULL, '1101965339', '9781101965337', 414, NULL, NULL, 'https://covers.openlibrary.org/b/id/13048123-L.jpg', '/works/OL20030224W', NULL, '2016', 'English', NULL, 1, 0, 'age-of-myth-michael-j-sullivan', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:35:59', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('68bd81d9-5deb-4c66-91b5-ff35963ca316', 'This Inevitable Ruin', 'They call it Faction Wars.
The ninth floor.

Nine armies, each led by rich and powerful aliens from across the galaxy. Each team has one objective: to capture and hold the castle at the very center of the battlefield. Strategy, alliances, pitched battles, and, of course, betrayal... It all makes for great fun and even greater television.

After all, none of these powerful aliens really die when they’re playing war.

Except this time. This time, winner takes all. Those who fall, stay in the ground.

As the AI continues its rapid decline, Carl and company take advantage of the chaos. For the first time ever, the crawlers are fighting back. They are now one of the nine teams. And this season, there’s a tenth army on the playing field. The NPCs, who are normally used as nothing but cannon fodder, have become fully self-aware and formed a team of their own.

For Donut and Katia, the stakes are even higher. Only one of them will be allowed to leave this level.

If they all want to survive, they’re going to need a little help from a veteran or two.

This is it.
This is what they’ve been fighting toward.
This is war.', 'In this seventh Dungeon Crawler Carl book, Carl and his allies enter the ninth floor''s Faction Wars, a brutal interstellar battle where only the strongest survive a deadly game show.', 2024, NULL, '9798217190041', 801, NULL, 1720, 'https://covers.openlibrary.org/b/id/15142977-L.jpg', '/works/OL41914127W', NULL, '2025-09-23', 'English', NULL, 1, 0, 'this-inevitable-ruin-matt-dinniman', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:35:59', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5e11be5f-242d-417f-8476-5125383bd7e6', 'The Crown Tower', 'Two men who hate each other. One impossible mission. A legend in the making. Hadrian Blackwater, a warrior with nothing to fight for, is paired with Royce Melborn, a thieving assassin with nothing to lose. Hired by an old wizard, they must steal a treasure that no one can reach. The Crown Tower is the impregnable remains of the grandest fortress ever built and home to the realm''s most prized possessions.', 'Two unlikely partners, a warrior and a thief, must steal a treasure from an impregnable fortress in this epic fantasy adventure.', 2013, '031624371X', '9780316243711', 432, NULL, 4500, 'https://covers.openlibrary.org/b/id/10291902-L.jpg', '/works/OL20920912W', NULL, 'Aug 06, 2013', 'English', NULL, 1, 0, 'the-crown-tower-michael-j-sullivan', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:36:00', '2026-03-22 04:05:55');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7bb87374-2689-402f-85f3-9618ad99d7c6', 'Grinding', 'Six months ago, the world watched in horror as we lost an American city. The Grinder. That''s what the survivors of Tucson called the monster. Just one touch, and they became a part of it. It used their bodies as limbs and as weapons. In just a matter of hours, it became huge, a towering monstrosity made entirely out of tens of thousands of people and animals.', 'A monstrous entity, The Grinder, devastates Tucson, absorbing bodies into its horrifying mass. A gory, emotional horror tale of sacrifice and love.', 2023, NULL, '9798988744412', NULL, NULL, 1440, NULL, '/works/OL36724291W', NULL, '2023', 'English', NULL, 1, 0, 'grinding-matt-dinniman', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:36:01', '2026-03-22 04:25:13');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2c9d96ce-4e97-4563-8529-cbc0dbcbd0e7', 'Rose & Paige', 'On D''Qar, where the jungles are dense and fuel is scarce, Rose tries to build a simple vehicle, but when her sister Paige takes one out for a trial run before everything is finished, they realize it is not yet ready for use.', 'A Star Wars comic focusing on Rose and Paige Tico, exploring self-confidence and sisterhood in the Resistance.', 2018, '153214296X', '9781532142963', 24, NULL, NULL, 'https://covers.openlibrary.org/b/id/9221293-L.jpg', '/works/OL20579665W', NULL, 'Dec 15, 2018', 'English', NULL, 1, 0, 'rose-paige-delilah-s-dawson', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:36:01', '2026-03-22 03:32:55');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e1293bdc-c369-4a53-9c1f-8e8f345380b5', 'Tinder Box', 'A reimagining of Hans Christian Anderson’s original fairytale, Kate Elliott''s “The Tinder Box” tells the story of a witch at the heart of an incipient rebellion—and all of those to come. “One spark. Two sparks. Three. This is what it takes to ignite a revolution.” At the Publisher''s request, this title is being sold without Digital Rights Management Software (DRM) applied.', 'A reimagining of Hans Christian Andersen’s fairytale, focusing on a witch sparking a rebellion.', 2021, NULL, '9781250835406', NULL, NULL, NULL, NULL, '/works/OL26979069W', NULL, '2021', 'English', NULL, 1, 0, 'tinder-box-kate-elliott', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:36:03', '2026-03-23 04:20:03');
