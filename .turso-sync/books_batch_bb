INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('fab26e93-e0d0-4560-84e3-100392fbf75a', 'Great Expectations', 'Great Expectations is the thirteenth novel by Charles Dickens and his penultimate completed novel. It depicts the education of an orphan nicknamed Pip (the book is a bildungsroman; a coming-of-age story). It is Dickens'' second novel, after David Copperfield, to be fully narrated in the first person. The novel was first published as a serial in Dickens''s weekly periodical All the Year Round, from 1 December 1860 to August 1861. In October 1861, Chapman and Hall published the novel in three volumes.

The novel is set in Kent and London in the early to mid-19th century and contains some of Dickens''s most celebrated scenes, starting in a graveyard, where the young Pip is accosted by the escaped convict Abel Magwitch. Great Expectations is full of extreme imagery – poverty, prison ships and chains, and fights to the death – and has a colourful cast of characters who have entered popular culture. These include the eccentric Miss Havisham, the beautiful but cold Estella, and Joe, the unsophisticated and kind blacksmith. Dickens''s themes include wealth and poverty, love and rejection, and the eventual triumph of good over evil. Great Expectations, which is popular both with readers and literary critics, has been translated into many languages and adapted numerous times into various media.', 'In Victorian England, orphan Pip''s mysterious benefactor elevates him from poverty, sparking a journey of self-discovery amid vivid characters and themes of ambition and class.', 1861, '8418695218', '9780811468237', 482, NULL, 167, 'https://covers.openlibrary.org/b/id/14972723-L.jpg', '/works/OL8721462W', NULL, 'June 1991', 'English', NULL, 1, 0, 'great-expectations-charles-dickens', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:57:43', '2026-03-23 04:37:15');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('71b31dcf-f21c-4e9f-8f1a-ceb1f20f45be', 'A Child''s History of England', NULL, 'Charles Dickens offers a lively, opinionated chronicle of England''s history from ancient Roman times to the late 17th century, with a brief extension to Queen Victoria''s era.', NULL, NULL, NULL, 400, NULL, 982, 'https://books.google.com/books/content?id=OIvqDwAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL45005421W', NULL, '1881', 'English', NULL, 0, 0, 'a-childs-history-of-england-charles-dickens', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:57:45', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2c8da144-1501-4193-bfe6-131b848f03af', 'The Testaments', '15 years after the sons of Jacob seized power in the USA and became Gilead.  The story is told from three female viewpoints;  Daisy, Agnes and Lydia. Daisy struggles with coming to the realization of her past and who she really is, Agnes tells her story and life in Gilead, and Lydia contemplates her life and decisions made.


When the van door slammed on Offred''s future at the end of The Handmaid''s Tale, readers had no way of telling what lay ahead for her--freedom, prison or death.

With The Testaments, the wait is over.

Margaret Atwood''s sequel picks up the story more than fifteen years after Offred stepped into the unknown, with the explosive testaments of three female narrators from Gilead.

In this brilliant sequel to The Handmaid''s Tale, acclaimed author Margaret Atwood answers the questions that have tantalized readers for decades.

"Dear Readers: Everything you''ve ever asked me about Gilead and its inner workings is the inspiration for this book. Well, almost everything! The other inspiration is the world we''ve been living in." --Margaret Atwood', NULL, 2019, '0525562621', '9780593149096', 502, NULL, 799, 'https://covers.openlibrary.org/b/id/12369527-L.jpg', '/works/OL20129837W', NULL, '2019', 'English', NULL, 1, 0, 'the-testaments-margaret-atwood', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:57:46', '2026-03-24 23:24:42');
