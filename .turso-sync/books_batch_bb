INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b7e47bb2-7f32-4ac4-9752-585b66ac196d', 'Voices in the dark', 'Andrew Coburn reaffirms his position as a novelist who has taken the crime thriller to new heights of storytelling suspense and new depths of insight and compassion as he weaves a spellbinding tale out of the sins men and women commit and the veil they do to each other and themselves. Unfolding with nerve-crackling tension, Voices in the Dark will have you reading far into the night to unravel a tangle of intertwined lives, lusts, and lies and to discover how fragile is the seam that separates guilt from innocence, how deadly the line that separates love from hate.', 'A gripping crime thriller set in small-town New England, exploring dark secrets, lust, and lies among intertwined lives.', 1995, '0451405900', NULL, 303, NULL, NULL, 'https://covers.openlibrary.org/b/id/9625567-L.jpg', '/works/OL2651475W', NULL, '1995', 'English', NULL, 1, 0, 'voices-in-the-dark-coburn-andrew', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:54:48', '2026-03-22 05:06:15');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c9cf2dbf-740b-467c-b517-9a55f3f23d63', 'Ruin', 'War has erupted in the Banished Lands as the race for power intensifies. Corban flees his homeland searching for peace, but he soon discovers that there is no haven in the west as the agents of Rhin and roaming bands of giants hound his every step. Veradis leaves the battleground and rushes to his King''s side. But he has witnessed both combat and betrayal and his duty weighs heavily upon him. Maquin seeks only revenge, but pirate slavers and the brutal world of pit-fighting stand in his way. Nathair becomes embroiled in the wars of the west as Queen Rhin marches against King Owain. The need to find the cauldron of the giants drives him on. Sides are chosen and oaths will be fulfilled or broken in a land where hell has broken loose.', 'A dark tale of trauma and passion, where broken characters confront inner demons and heal through intense connection.', 2015, '0316386324', '9780316386326', 782, NULL, 927, 'https://covers.openlibrary.org/b/id/14649449-L.jpg', '/works/OL20053900W', NULL, '2015', 'English', NULL, 1, 0, 'ruin', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:54:49', '2026-03-22 05:18:04');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9fe34cbe-312e-4c35-8b79-d44bbf42297c', 'The Dark Forest', 'Soon to be a Netflix Original Series!

"Wildly imaginative." —President Barack Obama on The Three-Body Problem trilogy

This near-future trilogy is the first chance for English-speaking readers to experience this multiple-award-winning phenomenon from Cixin Liu, China''s most beloved science fiction author.

In The Dark Forest, Earth is reeling from the revelation of a coming alien invasion-in just four centuries'' time. The aliens'' human collaborators may have been defeated, but the presence of the sophons, the subatomic particles that allow Trisolaris instant access to all human information, means that Earth''s defense plans are totally exposed to the enemy. Only the human mind remains a secret. This is the motivation for the Wallfacer Project, a daring plan that grants four men enormous resources to design secret strategies, hidden through deceit and misdirection from Earth and Trisolaris alike. Three of the Wallfacers are influential statesmen and scientists, but the fourth is a total unknown. Luo Ji, an unambitious Chinese astronomer and sociologist, is baffled by his new status. All he knows is that he''s the one Wallfacer that Trisolaris wants dead.', 'Humanity grapples with an impending alien invasion, exposed by subatomic spies, leading to the secretive Wallfacer Project where four individuals devise hidden defenses.', 2015, '8804686529', '9786053758921', 562, NULL, NULL, 'https://covers.openlibrary.org/b/id/12392944-L.jpg', '/works/OL16314245W', NULL, 'Aug 22, 2018', 'English', NULL, 1, 0, 'the-dark-forest-cixin-liu', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:54:50', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0c9e0428-e0e9-4709-8dbe-8572a33b3c2c', 'The babysitter', 'Returning home to find their babysitter bludgeoned to death and their daughter gone, John and Merle Wright hunt for the victim''s identity in order to learn of their child''s fate and encounter the sinister presence of federal agents in charge of the investigation.', 'A chilling mystery unfolds as parents return to find their babysitter murdered and child missing.', 1981, '0722124724', NULL, 215, NULL, NULL, NULL, '/works/OL2651476W', NULL, '1981', 'English', NULL, 1, 0, 'the-babysitter-coburn-andrew', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:54:50', '2026-03-22 03:12:24');
