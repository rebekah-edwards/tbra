INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('199bcaf0-2dd4-43b1-b434-d73ddff2455b', 'Daughter of the Empire', 'Mara, a young, untested Ruling Lady of Kelewan, is called upon to lead her people in a heroic stuggle for survival. But first she must rally an army of rebel warriors, form a pact with the alien cho-ja and marry the son of a hated enemy. Queen Mara of Acoma vows to avenge the deaths of her brother and father, even if it means killing her own husband.', 'In the exotic empire of Kelewan, young Mara of the Acoma is thrust into leadership after her family''s massacre, forcing her to master political scheming, alliances,', 1987, NULL, '9780007375646', 528, NULL, 4500, 'https://covers.openlibrary.org/b/id/15166509-L.jpg', '/works/OL554742W', NULL, '2012', 'English', NULL, 1, 0, 'daughter-of-the-empire-raymond-e-feist', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:54:34', '2026-03-22 03:20:51');
