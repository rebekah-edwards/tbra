INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('655e0267-0301-422a-a50c-1679e6a1b988', 'Birthright', 'In this original novel, fact and fiction intertwine in a story at once suspenseful and powerfully moving. It centers on the crime of the century.

Sometimes ordinary men play major roles in a greater destiny. Charles and Anne Morrow Lindbergh neither know Joseph Shellenbach nor suspect that he is both the source of and the answer to the pain that has seared their lives and will haunt them for the rest of their days. They know only that someone has stolen their infant son, demanded ransom, then left behind his broken body.

What they never know, or even suspect, is that the child they buried was not theirs but that of a young couple whose own baby had died tragically hours before the kidnapping. And they therefore never know the young man, named David, who grew up the son of a devoted father named Shell and an unstable mother named Helen.

Shell locks away in the innermost darkness of his soul the secret of David''s birth, guarding it with all the passion of a loving and protective father. Then comes a time of personal crisis when Shell must decide whether to tell David, now turning fifty, of his true birthright. Would David despise him? Though his real father has died, what of his real mother? Anne Lindbergh is still alive. What would the revelation of the existence of her firstborn do to her and her other children?

And would David really want them to know the truth? Would he really want to know it himself?', 'This speculative crime novel reimagines the Lindbergh baby kidnapping, where the child survives and is raised by a couple who lost their own infant.', 2003, '068481529X', NULL, 473, NULL, NULL, 'https://covers.openlibrary.org/b/id/425512-L.jpg', '/works/OL2651469W', NULL, '1997', 'English', NULL, 1, 0, 'birthright-coburn-andrew', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:54:57', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('f8925da4-bdf1-497b-a6d5-dc476affbb25', 'Drink, Slay, Love', 'Vampire romance takes a snarky turn in this humorous novel, coming soon to TV screens as a Lifetime Original Movie! Pearl is a sixteen-year-old vampire…fond of blood, allergic to sunlight, and mostly evil…until the night a sparkly unicorn stabs her through the heart with his horn.', 'A snarky vampire romance where 16-year-old Pearl, a bloodthirsty vampire, develops a conscience after an unicorn attack.', 2012, '1442423749', '9781442423749', 400, NULL, NULL, 'https://covers.openlibrary.org/b/id/12568148-L.jpg', '/works/OL27055038W', NULL, 'Sep 11, 2012', 'English', NULL, 1, 0, 'drink-slay-love-sarah-beth-durst', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:54:57', '2026-03-23 04:35:57');
