INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('453e7639-d7a1-44cb-91c6-cf115f2f650e', 'Sweetheart', 'Andrew Coburn’s The Babysitter was a bestseller; his previous book, Off Duty, was hailed by the New York Times Book Review as ''a flawlessly plotted, stylishly written account. The rewards are many and exceptional.'' Now, in Sweetheart, a novel about the Boston Mafia, Andrew Coburn has surpassed himself. Revenge, the defining motif of this suspenseful tale of crime, is a joyous emotion in the Mafia.', 'A hard-boiled crime novel set in the Boston Mafia, centered on revenge and moral dilemmas.', 1987, '0006173691', NULL, 288, NULL, NULL, 'https://covers.openlibrary.org/b/id/4211225-L.jpg', '/works/OL2651474W', NULL, '1987', 'English', NULL, 1, 0, 'sweetheart-coburn-andrew', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:54:47', '2026-03-22 03:49:41');
