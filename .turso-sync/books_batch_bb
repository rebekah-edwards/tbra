INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('2792ec77-178a-482e-9938-23273b9fc74b', 'Dare to Lead', 'Leadership is not about titles, status, and wielding power. A leader is anyone who takes responsibility for recognizing the potential in people and ideas, and has the courage to develop that potential.

When we dare to lead, we don’t pretend to have the right answers; we stay curious and ask the right questions. We don’t see power as finite and hoard it; we know that power becomes infinite when we share it with others. We don’t avoid difficult conversations and situations; we lean into vulnerability when it’s necessary to do good work.

But daring leadership in a culture defined by scarcity, fear, and uncertainty requires skill-building around traits that are deeply and uniquely human. The irony is that we’re choosing not to invest in developing the hearts and minds of leaders at the exact same time as we’re scrambling to figure out what we have to offer that machines and AI can’t do better and faster. What can we do better? Empathy, connection, and courage, to start.', 'Brené Brown demystifies leadership by emphasizing vulnerability, courage, and empathy as key to fostering brave cultures.', 2018, '147356252X', '9781473562523', 320, NULL, 1500, 'https://covers.openlibrary.org/b/id/10304768-L.jpg', '/works/OL19754782W', NULL, '2018', 'English', NULL, 0, 0, 'dare-to-lead-brene-brown', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:58:13', '2026-03-22 20:32:05');
