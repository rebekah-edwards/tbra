INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d9b29f58-8a2d-436e-9d01-c76dae534d20', 'Strengths-Based Leadership', 'From the author of the bestselling and still in demand StrengthsFinder 2.0 comes a new in-depth study on what it takes to be a successful leader. Using decades worth of research, interviews with more than 20,000 leaders and 10,000 followers, author Tom Rath and well-known leadership consultant Barry Conchie break down this data into actionable ways of understanding leadership and improving your leadership skills.', 'A guide to effective leadership using personal strengths, based on Gallup''s 30-year research.', 2009, '1595620257', '9781595620255', 216, NULL, NULL, 'https://covers.openlibrary.org/b/id/7244159-L.jpg', '/works/OL14991527W', NULL, 'January 6, 2009', 'English', NULL, 0, 0, 'strengthsbased-leadership-tom-rath', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:58:26', '2026-03-23 04:14:57');
