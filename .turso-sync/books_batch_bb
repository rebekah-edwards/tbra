INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('58211eae-f29e-4eb3-98c3-7c7a07b39000', 'A Time of Dread', 'Set in the same world as the Faithful and the Fallen quartet, A Time of Dread takes place one hundred years after the end of Wrath. The Banished Lands are experiencing a new era of peace, imposed often forcibly by the angelic Ben-Elim. But this peace is fragile, and something rotten lurks at its heart. Young soldier Rae will do anything to join the White Wings, the Ben-Elim''s peace keeping force. But a shocking betrayal shakes her view of the world and she must decide where her true allegiances lie. In the west, the giantess Sig investigates demon sightings with an elite band of warriors, though the Kadoshim were defeated long before. Sig discovers signs of an uprising and black magic - but just how serious is this threat? And in the snow-bound north, Drem and his father hunt for a living. On one excursion, they discover mutilated corpses in the silent forests behind their home. Yet is it the work of a predator, or something far worse? It seems mankind are little more than pawns in a bigger game - and in the shadows, demons bide their time, waiting to strike ...', 'In the Banished Lands, warrior angels enforce a brutal peace after defeating demons, but ancient evils stir anew.', 2018, '0316502243', '9780316502245', 492, NULL, 931, 'https://m.media-amazon.com/images/I/91EA1YSCliL._SL1500_.jpg', '/works/OL19735029W', NULL, '2018', 'English', NULL, 1, 0, 'a-time-of-dread-john-gwynne', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:54:52', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('03e131dc-5866-433f-ae1e-3a64233a3aab', 'Lake House', 'Yellowjackets meets One of Us Is Lying in this masterful survival thriller from New York Times bestselling author Sarah Beth Durst. ''Formidably scary, Durst''s survival/horror story is the stuff of late-night campfire legends. With three deftly drawn, powerful girls at the center, reading felt like I had found a crew of clever, loyal best friends, even as I stayed up long into the night, trembling with dread.''', 'Three girls arrive at a remote camp to find danger and mystery in this chilling YA horror survival thriller.', 2023, NULL, '9780063214071', 368, NULL, NULL, 'https://covers.openlibrary.org/b/id/13900684-L.jpg', '/works/OL28107441W', NULL, '2023', 'English', NULL, 1, 0, 'lake-house-sarah-beth-durst', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:54:53', '2026-03-22 02:56:10');
