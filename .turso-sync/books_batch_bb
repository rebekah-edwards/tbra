INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5da46ccc-d508-44c3-9df0-0fd93e08e1c2', 'End Times Bible Prophecy', 'What if you found out that everything that modern prophecy pundits are looking for -- the Rapture, the Tribulation, the Antichrist, The Beast -- was not what they told you it was, but something different? Respected biblical author Brian Godawa draws from Evangelical theological scholarship and deconstructs the popular ''Left Behind'' interpretation to uncover a far more fascinating and far more Biblical view of End Times Bible prophecy.', 'A provocative exploration of End Times prophecy, challenging popular interpretations with biblical scholarship.', 2017, '1942858310', '9781942858317', 194, NULL, 399, NULL, '/works/OL29233146W', NULL, 'Feb 21, 2017', 'English', NULL, 0, 0, 'end-times-bible-prophecy-brian-godawa', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:56:33', '2026-03-22 04:05:38');
