INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a45a966c-edcf-4fd4-8253-4464341d26a0', 'The Power of Vulnerability', 'Brown offers an invitation and a promise—that when we dare to drop the armor that protects us from feeling vulnerable, we open ourselves to the experiences that bring purpose and meaning to our lives. Here she dispels the cultural myth that vulnerability is weakness and reveals that it is, in truth, our most accurate measure of courage. “The Power of Vulnerability is a very personal project for me,” Brené explains.', 'Brené Brown explores vulnerability as a source of courage, connection, and meaning in life.', 2012, '1604078588', '9781604078589', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/10217748-L.jpg', '/works/OL20888485W', NULL, 'Nov 15, 2012', 'English', NULL, 0, 0, 'the-power-of-vulnerability-brene-brown', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:58:41', '2026-03-22 04:53:05');
