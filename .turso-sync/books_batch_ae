INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('066438d7-ce95-4a04-9900-5b490b485f9d', 'King of Wrath - Signing Exclusive', 'Ruthless. Meticulous. Arrogant. 
