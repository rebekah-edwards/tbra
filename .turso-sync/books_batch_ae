INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('a6865c1f-b7a4-4575-a109-4a3b6fbf9bf5', 'Regretting You', 'Morgan Grant and her sixteen-year-old daughter, Clara, would like nothing more than to be nothing alike.

Morgan is determined to prevent her daughter from making the same mistakes she did. By getting pregnant and married way too young, Morgan put her own dreams on hold. Clara doesn’t want to follow in her mother’s footsteps. Her predictable mother doesn’t have a spontaneous bone in her body.

With warring personalities and conflicting goals, Morgan and Clara find it increasingly difficult to coexist. The only person who can bring peace to the household is Chris—Morgan’s husband, Clara’s father, and the family anchor. But that peace is shattered when Chris is involved in a tragic and questionable accident. The heartbreaking and long-lasting consequences will reach far beyond just Morgan and Clara.

While struggling to rebuild everything that crashed around them, Morgan finds comfort in the last person she expects to, and Clara turns to the one boy she’s been forbidden to see. With each passing day, new secrets, resentment, and misunderstandings make mother and daughter fall further apart. So far apart, it might be impossible for them to ever fall back together.', NULL, 2019, '154201641X', '9781542016414', 363, NULL, NULL, 'https://covers.openlibrary.org/b/id/8581190-L.jpg', '/works/OL36090166W', NULL, 'December 10, 2019', 'English', NULL, 1, 0, 'regretting-you-colleen-hoover', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:22:02', '2026-03-25 00:23:59');
