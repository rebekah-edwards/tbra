INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c471481c-c9dd-47c7-bc2b-137ecaed7d74', 'Ugly Love', 'ATTRACTION AT FIRST SIGHT CAN BE MESSY… When Tate Collins finds airline pilot Miles Archer passed out in front of her apartment door, it is definitely not love at first sight. They wouldn’t even go so far as to consider themselves friends. But what they do have is an undeniable mutual attraction. He doesn’t want love and she doesn’t have time for a relationship, but their chemistry cannot be ignored. Once their desires are out in the open, they realize they have the perfect set-up, as long as Tate can stick to two rules: Never ask about the past and don’t expect a future. Tate is determined that she can handle it, but when she realises that she can’t, will she be able to say no to her sexy pilot when he lives just next door?', NULL, 2014, NULL, '9781476753188', 336, NULL, NULL, 'https://covers.openlibrary.org/b/id/12856728-L.jpg', '/works/OL20577143W', NULL, 'August 5, 2014', 'English', NULL, 1, 0, 'ugly-love-colleen-hoover', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 05:22:06', '2026-03-25 00:23:59');
