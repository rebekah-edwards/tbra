INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('99ee7402-444a-444e-a73b-4107d2d3c448', 'Where the Crawdads Sing', 'For years, rumors of the “Marsh Girl” have haunted Barkley Cove, a quiet town on the North Carolina coast. So in late 1969, when handsome Chase Andrews is found dead, the locals immediately suspect Kya Clark, the so-called Marsh Girl. But Kya is not what they say. Sensitive and intelligent, she has survived for years alone in the marsh that she calls home, finding friends in the gulls and lessons in the sand. Then the time comes when she yearns to be touched and loved. When two young men from town become intrigued by her wild beauty, Kya opens herself to a new life–until the unthinkable happens.

Perfect for fans of Barbara Kingsolver and Karen Russell, Where the Crawdads Sing is at once an exquisite ode to the natural world, a heartbreaking coming-of-age story, and a surprising tale of possible murder. Owens reminds us that we are forever shaped by the children we once were, and that we are all subject to the beautiful and violent secrets that nature keeps.', 'Abandoned by her family as a child, Kya Clark survives alone in the North Carolina marshes, forging a deep connection with nature.', 2018, '8417743391', '9788417743390', 416, NULL, 732, 'https://covers.openlibrary.org/b/id/8362947-L.jpg', '/works/OL18766691W', NULL, 'Oct 16, 2019', 'English', NULL, 1, 0, 'where-the-crawdads-sing-delia-owens', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 05:25:02', '2026-03-22 20:32:05');
