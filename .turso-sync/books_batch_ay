INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b8aa9bcf-300c-4e72-b43a-a75921f89778', 'Echoes', 'Echoes is a why choose asylum secret society dark romance. It contains adult themes, sensitive topics, and is solely intended for mature audiences over 18. It is recommended that readers check the trigger warnings before diving in.', 'A dark romance in an asylum setting, exploring secret societies and unhinged minds with intense, mature themes.', 2019, '1534413472', '9781534413474', 816, NULL, NULL, 'https://covers.openlibrary.org/b/id/8782309-L.jpg', '/works/OL20130656W', NULL, 'Aug 20, 2019', 'English', NULL, 1, 0, 'echoes-stephen-graham-jones', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:31', '2026-03-22 05:06:46');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('8f6613a4-e66c-4ac1-8e1b-fd49e5796b20', 'Music, Body, and Desire in Medieval Culture: Hildegard of Bingen to Chaucer (Figurae: Reading Medieval Culture)', 'Ranging chronologically from the twelfth to the fifteenth centuries and thematically from Latin to vernacular literary modes, this book challenges standard assumptions about the musical cultures and philosophies of the European Middle Ages. Engaging a wide range of premodern texts and contexts, from the musicality of sodomy in twelfth-century polyphony to Chaucer’s representation of pedagogical violence in the Prioress’s Tale, from early Christian writings on the music of the body to the plainchant and poetry of Hildegard of Bingen, the author argues that medieval music was quintessentially a practice of the flesh. The book reveals a sonorous landscape of flesh and bone, pleasure and pain, a medieval world in which erotic desire, sexual practice, torture, flagellation, and even death itself resonated with musical significance and meaning.', 'A scholarly exploration of music, body, and desire in medieval culture from Hildegard of Bingen to Chaucer.', 2001, '0804740585', '9780804740586', 496, NULL, NULL, 'https://covers.openlibrary.org/b/id/577877-L.jpg', '/works/OL269377W', NULL, 'June 11, 2001', 'English', 'Stanford University Press', 0, 0, 'music-body-and-desire-in-medieval-culture-hildegard-of-bingen-to-chaucer-figurae-reading-medieval-culture-bruce-holsinger', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:32', '2026-03-22 04:38:53');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('dd89c81f-aa5c-4471-8c1c-f8e410f3e641', 'The Answered Call', 'This is what happened to William Carey who, 200 years ago, obeyed God''s call and went to India - setting the pattern for all modern missions. This book traces the growth of the modern mission movement, focusing especially on the Baptist Missionary Society which this year celebrates its bicentenary.', 'A historical account of William Carey and the dawn of modern missions, tracing the Baptist Missionary Society''s bicentenary.', 1992, '0551027118', '9780551027114', 192, NULL, NULL, 'https://covers.openlibrary.org/b/id/10702764-L.jpg', '/works/OL9439805W', NULL, 'September 17, 1992', 'English', 'Marshall Pickering', 0, 0, 'the-answered-call-gwenda-bond', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:32', '2026-03-23 04:17:27');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('e02e2b00-0b82-4032-90b0-3fd6f10a47ba', 'Minority Report', 'In the world of The Minority Report, Commissioner John Anderton is the one to thank for the lack of crime. He is the originator of the Precrime System, which uses "precogs"--people with the power to see into the future--to identify criminals before they can do any harm. Unfortunately for Anderton, his precogs perceive him as the next criminal. But Anderton knows he has never contemplated such a thing, and this knowledge proves the precogs are fallible. Now, whichever way he turns, Anderton is doomed--unless he can find the precogs''s "minority report"--the dissenting voice that represents his one hope of getting at the truth in time to save himself from his own system.A film version of The Minority Report, directed by Steven Spielberg and starring Tom Cruise, will be released this summer--further proof of the enduring appeal of Philip K. Dick''s visionary fiction.From the Hardcover edition.', NULL, 1998, '1857989473', '9783453217492', 304, NULL, 3000, 'https://covers.openlibrary.org/b/id/911061-L.jpg', '/works/OL2172414W', NULL, 'Oct 01, 2003', 'English', NULL, 1, 0, 'minority-report-philip-k-dick', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:43:33', '2026-03-24 23:24:42');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('31800854-6a78-46f8-bd0d-eee86fa11289', 'Final Cuts', '**Legendary genre editor Ellen Datlow brings together eighteen dark and terrifying original stories inspired by cinema and television. A BLUMHOUSE BOOKS HORROR ORIGINAL.**

From the secret reels of a notoriously cursed cinematic masterpiece to the debauched livestreams of modern movie junkies who will do anything for clicks, *Final Cuts* brings together new and terrifying stories inspired by the many screens we can''t peel our eyes away from. Inspired by the rich golden age of the film and television industries as well as the new media present, this new anthology reveals what evils hide behind the scenes and between the frames of our favorite medium. With original stories from a diverse list of some of the best-known names in horror, *Final Cuts* will haunt you long after the credits roll.', 'An anthology of horror tales centered on Hollywood and cinematic spectacles, blending dread with storytelling.', 2020, '0525565752', '9780525565758', 480, NULL, NULL, 'https://covers.openlibrary.org/b/id/10097655-L.jpg', '/works/OL20800806W', NULL, 'Jun 02, 2020', 'English', 'Anchor', 1, 0, 'final-cuts-stephen-graham-jones', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:33', '2026-03-22 03:36:33');
