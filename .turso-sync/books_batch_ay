INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1c3b4052-5084-4fb3-9cb1-a7d53a12defc', 'On Parchment', 'For centuries, premodern societies recorded and preserved much of their written cultures on parchment: the rendered skins of sheep, cows, goats, camels, deer, gazelles, and other creatures. These remains make up a significant portion of the era’s surviving historical record. In a study spanning three millennia and twenty languages, Bruce Holsinger explores this animal archive as it shaped the inheritance of the Euro-Mediterranean world, from the leather rolls of ancient Egypt to the Acts of Parliament in the United Kingdom.', 'A sweeping history of parchment, exploring its animal origins and cultural impact over millennia.', 2023, NULL, '9780300260212', NULL, NULL, NULL, 'https://books.google.com/books/content?id=DU6qEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api', '/works/OL28806938W', NULL, '2023', 'English', 'Yale University Press', 0, 0, 'on-parchment-bruce-holsinger', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:43:17', '2026-03-22 03:22:29');
