INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('22680128-d964-4f5e-89bf-9c40a14bd1e2', 'Strange Alchemy', 'On Roanoke Island, the legend of the Lost Colony and the 114 colonists who vanished without a trace more than four hundred years ago still haunts the town. As the unlikely pair works to uncover the secrets of the new Lost Colony, they must dodge everyone from the authorities to long-dead alchemists as they race against time to save their family and friends before they too are gone for good.', 'A YA paranormal thriller unraveling the Roanoke mystery with romance and supernatural twists.', 2017, '1630790761', '9781630790769', 336, NULL, NULL, 'https://covers.openlibrary.org/b/id/10489997-L.jpg', '/works/OL19649385W', NULL, 'Aug 01, 2017', 'English', NULL, 1, 0, 'strange-alchemy-gwenda-bond', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:23', '2026-03-22 03:26:25');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('fac6685f-d01a-45d4-bfbf-ec6c34fd1c3c', 'Gifted School', 'A smart, insightful, and engrossing story about how the prospect of getting their children into a school for the gifted causes a group of competitive parents to comport themselves in the most unseemly and ultimately destructive ways. Snapping with tension, this is a book for our times. It will push a lot of buttons for a lot of people.” — Shari Lapena, New York Times-bestselling author of The Couple Next Door', 'A satirical tale of competitive parents vying for spots in a gifted school, exposing privilege and ambition.', 2020, NULL, '9781472271518', 464, NULL, 833, 'https://covers.openlibrary.org/b/id/14785371-L.jpg', '/works/OL20073917W', NULL, '2020', 'English', NULL, 1, 0, 'gifted-school-bruce-holsinger', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:23', '2026-03-23 04:37:20');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('640d0b4e-dd65-4911-8915-749ea754b23b', 'Neomedievalism, Neoconservatism, and the War on Terror', 'Yet as Bruce Holsinger argues here, this cloying post-9/11 rhetoric has served to obscure the more intricate ideological machinations of neomedievalism, the global idiom of the non-state actor: NGOs, transnational corporate militias, and terrorist organizations like Hezbollah and al Qaeda. While International Relations theorists promote neomedievalism as a model for understanding emergent modes of global sovereignty, neoconservatives exploit its conceptual slipperiness for tactical ends. Holsinger concludes with a careful parsing of the Bush administration’s torture memos, which enlist neomedievalism’s model of feudal sovereignty on behalf of the abrogation of human rights.', 'A critical analysis of neomedievalism in politics and the War on Terror post-9/11.', 2008, NULL, '9780976147596', 84, NULL, NULL, 'https://covers.openlibrary.org/b/id/14391022-L.jpg', '/works/OL5821693W', NULL, '2008', 'English', NULL, 0, 0, 'neomedievalism-neoconservatism-and-the-war-on-terror-bruce-holsinger', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:25', '2026-03-22 04:09:53');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('5bdca684-4e93-4a66-8e0e-bcfbcbf8e53c', 'The Shadow Arts', 'The thrilling sequel to Monstrous Devices - Alex and his grandfather hold the fate of history itself in their hands in a Rick Riordan meets Raiders of the Lost Ark adventure of epic proportions! In the wrong hands, these stolen artifacts could unlock an ancient secret bigger than anything Alex ever dreamed of. If they can''t solve the riddle in time, innocent lives - and even history itself - could be at stake.', 'Alex and his grandfather battle to save history itself in a thrilling fantasy adventure.', 2020, NULL, '9780451478610', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/9294531-L.jpg', '/works/OL20652039W', NULL, '2020', 'English', NULL, 1, 0, 'the-shadow-arts-damien-love', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:43:26', '2026-03-22 04:04:25');
