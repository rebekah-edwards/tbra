INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('15338f8b-bf82-4b0c-bad8-472a8e80873d', 'Three Miles Past', 'In these three novellas by Stephen Graham Jones, the dead talk, ancient evil opens its eyes, and that guy across the parking lot, he''s watching you, and has been for a while now. Lock the door, tell yourself it''s nothing, turn the radio up. It won''t matter. You''re already three miles past where you meant to stop.', 'Three disturbing horror novellas explore dark nightmares, ancient evils, and lurking threats.', 2024, NULL, '9781504096294', 160, NULL, NULL, 'https://m.media-amazon.com/images/I/81AvM2P14yL._SL1500_.jpg', '/works/OL38665608W', NULL, '2024', 'English', 'Open Road Integrated Media, Inc.', 1, 0, 'three-miles-past-stephen-graham-jones', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:43:44', '2026-03-22 03:18:03');
