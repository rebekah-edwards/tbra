INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3c38b0f7-d93b-4f39-a584-c977234964e2', 'Invisible Traces', 'So is the four-year-old relationship between the unnamed characters, a man and woman, two lovers on their last night together, reflecting on how they met. Will they find a way to remember one another, so their love might survive ''tabula rasa?'' Heart-wrenching but with hope, Invisible Traces is romantic, poetic, intimate, and emotional. Sarina Dahlan''s writing is exquisite.', 'Two lovers spend their last night together in a futuristic world, grappling with memory and love. A poignant, romantic short story.', 2019, NULL, '9781795681056', NULL, NULL, NULL, 'https://books.google.com/books/content?id=Q8vCwQEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL29640763W', NULL, '2019', 'English', 'Independently Published', 1, 0, 'invisible-traces-sarina-dahlan', 1, 'google_books', NULL, 0, NULL, 'public', '2026-03-16 21:42:06', '2026-03-22 03:44:02');
