INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('381a4ffb-0de8-4890-a667-ae9297770190', 'Law & Disorder', 'No one is better acquainted with the subject of humanity’s most notorious crimes and the wrenching challenges of bringing those criminals to justice than John Douglas, the model for Agent Jack Crawford in The Silence of the Lambs. In this provocative and deeply personal book, the most prominent criminal investigator of our time recounts his twenty-five-year FBI career tracking down master criminals, writing true crime bestsellers, and developing forensic science and the art of criminal profiling. In his earlier works, Douglas wrote only about the guilty; in Law & Disorder, he writes about the guilty, innocents accused, and even innocents convicted as he addresses every law enforcement professional’s worst nightmare: those cases where, for one reason or another, justice was delayed.', 'A legendary FBI profiler explores notorious murder cases and justice system failures in a deeply personal account.', 2013, '0758273126', '9780758273123', 404, NULL, NULL, 'https://covers.openlibrary.org/b/id/8002266-L.jpg', '/works/OL17725216W', NULL, '2013', 'English', NULL, 0, 0, 'law-disorder-john-e-douglas', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:42:08', '2026-03-22 03:41:14');
