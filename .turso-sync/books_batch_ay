INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('80819005-048d-4127-a51e-90b169a8dc69', 'Sexual Homicide', 'Who are the men committing the rising number of serial homicides in the U.S. -- and why do they kill? The increase in these violent crimes over the past decade has created an urgent need for more and better information about these men: their crime scene patterns, violent acts, and above all, their motivations for committing these shocking and repetitive murders. This authoritative book represents the data, findings, and implications of a long-term F.B.I.-sponsored study of serial sex killers.', 'An authoritative FBI study on serial sex killers, exploring their patterns, motives, and societal impact.', 1995, '0028740637', '9780028740638', 234, NULL, NULL, 'https://covers.openlibrary.org/b/id/7256818-L.jpg', '/works/OL15211795W', NULL, 'June 1, 1995', 'English', NULL, 0, 0, 'sexual-homicide-john-e-douglas', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:42:38', '2026-03-22 04:28:30');
