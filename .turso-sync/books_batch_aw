INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('3a1c2d50-b26d-4020-a3bb-4892646facfd', 'Language of Elk', 'This debut collection of stories, The Language of Elk, by the award-winning author of Red Moon, assembles its cast from the mountain towns and low life taverns and high desert ranches of Oregon--a state that in isolated pockets remains a still-unfinished place, the frontier. Here myths haunt the moss-laden woods and Benjamin Percy shines his light on them, revealing bearded ladies and Bigfoot and marijuana colonies and elk hunting ranches and haunted Indian burial sites, the underside of contemporary western America. With a salty mystical voice that partners the landscape and a vision as wild as his characters, Percy explores a world of surprising violence and gentleness, hilarity and heartbreak, loveliness and ugliness, and in doing so emerges as a beautifully raw voice of the West.', 'A debut collection of dark, violent stories set in the rugged frontier of Oregon, exploring wildness and human struggle.', 2013, NULL, '9781306742610', NULL, NULL, NULL, NULL, '/works/OL29389082W', NULL, '2013', 'English', NULL, 1, 0, 'language-of-elk-benjamin-percy', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:33:43', '2026-03-22 03:42:42');
