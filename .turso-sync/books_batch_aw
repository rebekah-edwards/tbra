INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('c1749e26-4384-49ed-9d56-161661b58af4', 'Ghost Rider Vol. 3', 'The F.B.I. has cast out Johnny Blaze and Talia Warroad, maybe because they’re too destructive and unmanageable — or maybe because corruption reaches inside the very institution meant to protect us! As Johnny and Talia head to Savannah to investigate a necropolis, old friends and new foes appear on the horizon. A fresh chapter of horror begins for the Ghost Rider — and Danny Ketch is roaring up in the rearview mirror!', 'Johnny Blaze and Talia Warroad face corruption and horror as they investigate a necropolis in Savannah.', 2023, NULL, '9781302948627', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/14718226-L.jpg', '/works/OL34488833W', NULL, '2023', 'English', NULL, 1, 0, 'ghost-rider-vol-3-benjamin-percy', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 21:33:22', '2026-03-22 05:12:33');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('08c0c749-6ffa-46ff-bc69-7baa5bc494cb', 'A Wonder Book for Girls & Boys', 'Six legends of Greek mythology, retold for children by Nathaniel Hawthorne. Included are The Gorgon’s Head, The Golden Touch, The Paradise of Children, The Three Golden Apples, The Miraculous Pitcher, and The Chimaera. In 1838, Hawthorne suggested to Henry Wadsworth Longfellow that they collaborate on a story for children based on the legend of the Pandora’s Box, but this never materialized. He wrote A Wonder Book between April and July 1851, adapting six legends most freely from Charles Anton’s A Classical Dictionary (1842). He set out deliberately to “modernize” the stories, freeing them from what he called “cold moonshine” and using a romantic, readable style that was criticized by adults but proved universally popular with children. With full-color illustrations throughout by Arthur Rackham.', NULL, NULL, '1721206094', '9781721206094', 206, NULL, NULL, 'https://covers.openlibrary.org/b/id/13201462-L.jpg', '/works/OL455667W', NULL, '2018-06-16', 'English', NULL, 1, 0, 'a-wonder-book-for-girls-boys-nathaniel-hawthorne', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 21:33:24', '2026-03-24 23:24:42');
