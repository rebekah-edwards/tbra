INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('cfaeff7b-7898-4f5d-bb79-5d7315ecfe84', 'All things new', 'In the aftermath of the Civil War, Josephine Weatherly and her mother, Eugenia, struggle to pick up the pieces of their lives when they return to their Virginia plantation. But the bitter realities of life after the war cannot be denied: their home and land are but shells of their previous grandeur; death has claimed her father and brother; and her remaining brother, Daniel, has returned home bitter and broken. The privileged childhood Josephine enjoyed now seems like a long-ago dream. And the God who failed to answer any of her prayers during the war is lost to her as well.

Josephine soon realizes that life is now a matter of daily survival--and recognizes that Lizzie, as one of the few remaining servants, is the one she must rely on to teach her all she needs to know. Josephine''s mother, too, vows to rebuild White Oak... but a bitter hatred fuels her.

With skill and emotion, Lynn Austin brings to life the difficult years of the Reconstruction era by interweaving the stories of three women--daughter, mother, and freed slave--in a riveting tale.', 'In post-Civil War Virginia, young Josephine Weatherly and her mother fight to restore their plantation amid ruin and resentment, turning to former slave Lizzie for survival skills.', 1958, NULL, '9781611735581', 192, NULL, NULL, 'https://covers.openlibrary.org/b/id/7316452-L.jpg', '/works/OL16769881W', NULL, '2012', 'English', NULL, 1, 0, 'all-things-new-lynn-n-austin', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:02:36', '2026-03-23 04:08:36');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('35995c46-9ff3-4143-935e-a2b2ee919b54', 'Without a Trace', 'When a plane carrying Bree Nichols'' husband and son disappears, her life changes forever. Her relentless determination to find them starts an investigation that links their disappearance to a violent crime threatening to tear the peaceful town of Rock Harbor apart. Full of suspense and romance, this new series draws the reader into the life and operation of a canine search-and-rescue team as it unravels the secrets of an enchanting wilderness', 'After a plane crash kills her husband and son, Bree Nichols uses her search-and-rescue dog to investigate connections to a violent crime rocking her small Michigan town.', 2003, '0849944295', '9781595542861', 352, NULL, 535, 'https://covers.openlibrary.org/b/id/646403-L.jpg', '/works/OL5707394W', NULL, 'April 10, 2007', 'English', NULL, 1, 0, 'without-a-trace-colleen-coble', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:02:38', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b2c45f9f-d771-48b8-b988-a3eb3255eff8', 'The Housemaid', 'Every day I clean the Winchesters'' beautiful house top to bottom. I collect their daughter from school. And I cook a delicious meal for the whole family before heading up to eat alone in my tiny room on the top floor.

I try to ignore how Nina makes a mess just to watch me clean it up. How she tells strange lies about her own daughter. And how her husband Andrew seems more broken every day. But as I look into Andrew''s handsome brown eyes, so full of pain, it''s hard not to imagine what it would be like to live Nina''s life. The walk-in closet, the fancy car, the perfect husband.

I only try on one of Nina''s pristine white dresses once. Just to see what it''s like. But she soon finds out... and by the time I realize my attic bedroom door only locks from the outside, it''s far too late.

But I reassure myself: the Winchesters don''t know who I really am.

They don''t know what I''m capable of . . .', 'A desperate woman accepts a live-in housemaid position with a seemingly perfect wealthy family, only to discover disturbing secrets and manipulative behaviors.', 2022, '1538768542', '9781408728512', 336, NULL, 586, 'https://covers.openlibrary.org/b/id/15112868-L.jpg', '/works/OL27729743W', NULL, 'August 27, 2023', 'English', NULL, 1, 0, 'the-housemaid-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:07', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0a68c63c-6cd2-4e01-98a8-a9e95016e3a1', 'Rock Harbor Search and Rescue', NULL, 'Young Emily O''Reilly, obsessed with search and rescue, is falsely accused of stealing a necklace at a festival, jeopardizing her dream of getting a puppy and joining the team.', 2013, '1400321069', '9781400321063', NULL, NULL, NULL, 'https://covers.openlibrary.org/b/id/7828161-L.jpg', '/works/OL17563292W', NULL, '2013', 'English', NULL, 1, 0, 'rock-harbor-search-and-rescue-colleen-coble', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:08', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('7db4825a-a741-4b56-b0d2-6e743f1fd26e', 'The Housemaid Is Watching', '“You must be our new neighbors!” Mrs. Lowell gushes and waves across the picket fence. I clutch my daughter’s hand and smile back: but the second Mrs. Lowell sees my husband a strange expression crosses her face. In that moment I make a promise. We finally have a family home. My past is far, far behind us. And I’ll do anything to keep it that way…

I used to clean other people’s houses—now, I can’t believe this home is actually mine. The charming kitchen, the quiet cul-de-sac, the huge yard where my kids can play. My husband and I saved for years to give our children the life they deserve.

Even though I’m wary of our new neighbor Mrs. Lowell, when she invites us over for dinner it’s our chance to make friends. Her maid opens the door wearing a white apron, her hair in a tight bun. I know exactly what it’s like to be in her shoes.

But her cold stare gives me chills…

The Lowells’ maid isn’t the only strange thing on our street. I’m sure I see a shadowy figure watching us. My husband leaves the house late at night. And when I meet a woman who lives across the way, her words chill me to the bone: Be careful of your neighbors.

Did I make a terrible mistake moving my family here?

I thought I’d left my darkest secrets behind. But could this quiet suburban street be the most dangerous place of all?', 'A former housemaid relocates her family to a seemingly perfect suburban neighborhood, but eerie neighbors and shadowy figures stir suspicions of hidden dangers.', 2024, '1420523740', '9781464221132', 398, NULL, 702, 'https://covers.openlibrary.org/b/id/14633290-L.jpg', '/works/OL37576476W', NULL, '2024', 'English', NULL, 1, 0, 'the-housemaid-is-watching-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:46', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('664bbdf9-49fd-43c3-a5e8-65fa3f85b419', 'Dear Debbie', 'Sometimes, enough is enough…

Debbie Mullen is losing it. For years, she has compiled all of her best advice into her column, Dear Debbie, where the wives of New England come for sympathy and neighborly advice. Through her work, Debbie has heard from countless women who are ignored, belittled, or even abused by their husbands. And Debbie does her best to guide them in the right direction. Or at least, she did.

These days, Debbie’s life seems to be spiraling out of control. She just lost her job. Something strange is happening with her teenage daughters. And her husband is keeping secrets, according to the tracking app she installed on his phone. Now, Debbie’s done being the bigger person.

She’s done being reasonable and practical. It’s time to take her own advice.

And now it’s time for payback against all the people in her life who deserve it the most.', 'Advice columnist Debbie Mullen spirals after losing her job and suspecting her husband''s secrets, embracing her own vengeful advice in a twisted path of payback and murder.', 2026, '1464249628', '978-1464249624', 336, NULL, 460, 'https://covers.openlibrary.org/b/id/15171146-L.jpg', '/works/OL44950254W', NULL, 'January 27, 2026', 'English', NULL, 1, 0, 'dear-debbie-freida-mcfadden', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 07:03:46', '2026-03-22 04:11:31');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('0f7a268b-c265-4198-9118-505774aa3e73', 'The Housemaid''s Secret', '*As he continues showing me their incredible penthouse apartment, I have a terrible feeling about the woman behind closed doors. But I can''t risk losing this job – not if I want to keep my darkest secret safe . . .*

It''s hard to find an employer who doesn''t ask too many questions about my past. So I thank my lucky stars that the Garricks miraculously give me a job, cleaning their stunning penthouse with views across the city and preparing fancy meals in their shiny kitchen. I can work here for a while, stay quiet until I get what I want. It''s almost perfect. But I still haven''t met Mrs Garrick, or seen inside the guest bedroom. I''m sure I hear her crying. I notice spots of blood around the neck of her white nightgowns when I''m doing laundry. And one day I can''t help but knock on the door. When it gently swings open, what I see inside changes everything...

That''s when I make a promise. After all, I''ve done this before. I can protect Mrs. Garrick while keeping my own secrets locked up safe. Douglas Garrick has done wrong. He is going to pay. It''s simply a question of how far I''m willing to go...', 'Millie, a housemaid hiding her criminal past, takes a job with the wealthy Garricks and suspects the wife is being abused by her controlling husband.', 2023, '0349132607', '9781538742587', 352, NULL, 584, 'https://covers.openlibrary.org/b/id/13439869-L.jpg', '/works/OL34113490W', NULL, '2023', 'English', NULL, 1, 0, 'the-housemaids-secret-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:46', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('84a5ce7e-51bb-485f-949f-1bfb60c3b301', 'The Housemaid''s Wedding', 'The Housemaid’s Wedding is a **winter-themed short story** meant to fill in the long gap between Book 2 of the Housemaid series (The Housemaid’s Secret) and Book 3 (The Housemaid is Watching). It can be read either between Book 2 and Book 3, or after Book 3.

Today is supposed to be the happiest day of my life.

I''m **engaged to the man of my dreams**, and in a few short hours, I''m going to stand before a judge, who will declare us husband and wife, till death does us part. Despite some bumps in the road, this day is everything I dreamed it would be.

There''s only one problem:

**Someone out there doesn''t want me to live long enough to say my vows.**

And if I''m not careful, **they may very well get their wish.**', 'In this suspenseful short story, Millie anticipates her winter wedding to Enzo, the man of her dreams, but a deadly stalker threatens to end her life before the vows.', 2024, '9032521527', '9789032521523', 69, NULL, 104, 'https://covers.openlibrary.org/b/id/15162542-L.jpg', '/works/OL42487395W', NULL, 'January 15, 2025', 'English', NULL, 1, 0, 'the-housemaids-wedding-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:47', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('847904ad-fe81-4660-bdf1-5ad3c34b1bfa', 'The Crash', NULL, 'A pregnant woman fleeing her troubled past crashes her car in a blizzard and is rescued by a seemingly helpful but suspicious couple.', 1954, '1420521357', '9781420521351', 243, NULL, 553, NULL, '/works/OL44366063W', NULL, '2025-02-05', 'English', NULL, 1, 0, 'the-crash-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:54', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('6f80b82e-7ad9-4244-ac6b-cbe81be37741', 'The Intruder', 'Who knows what the storm will blow in…

Casey''s cabin in the wilderness is not built for a hurricane. Her roof shakes, the lights flicker, and the tree outside her front door sways ominously in the wind. But she''s a lot more worried about the girl she discovers lurking outside her kitchen window.

She’s young. She’s alone. And she’s covered in blood.

The girl won''t explain where she came from or loosen her grip on the knife in her right hand. And when Casey makes a disturbing discovery in the middle of the night, things take a turn for the worse.

The girl has a dark secret. One she’ll kill to keep. And if Casey gets too close to the truth, she may not live to see the morning.', NULL, 2025, '1464260915', '9781464260919', 279, NULL, NULL, 'https://covers.openlibrary.org/b/id/15130686-L.jpg', '/works/OL44220759W', NULL, 'October 7, 2025', 'English', NULL, 1, 0, 'the-intruder-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 07:03:54', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('450b0189-1bc3-4857-bb6c-959e3a0ff957', '11 Out Of 10', '"What is your pain level on a scale of 1 to 10, where zero would be no pain, and 10 would be if you had an attack of kidney stones while in active labor, and while all that was going on, you were set on fire. Starting with your genitals. And then you were disemboweled, and the bowels that were removed were then also set on fire. And then while you were running around in active labor, passing a kidney stone, on fire with your bowels also on fire, you accidentally stepped on a Lego with your bare foot. And that Lego was also on fire."

"It''s an 11."

Medicine can be funny. It can be sad, painful, inspirational, but also sometimes funny. "11 out of 10" is a collection of humorous medical stories from practitioners in all fields, ranging from physicians to nurses to EMTs to medical students. Some are totally true, some are exaggerated, and some are mostly fiction. But every single one of them aims to put a smile on your face.', 'This anthology collects humorous short stories inspired by medical experiences, blending true tales, exaggerations, and fiction to poke fun at doctors, patients, and hospital absurdities.', 1963, '1517492483', '9781517492489', 222, NULL, NULL, 'https://books.google.com/books/content?id=CdRrjgEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api', '/works/OL41735980W', NULL, '2015', 'English', NULL, 1, 0, '11-out-of-10-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:03:56', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1b6f43d0-d0ce-4eac-9e90-ac38f311ed91', 'Death Row', 'With all hope of an appeal fading away, the fate of a condemned murderess takes a shocking turn in a breathtaking short story by the #1 New York Times bestselling author of The Housemaid.

Talia Kemper is on death row for murdering her husband. She had an alibi and no known motive, yet Talia’s unwavering protestations of innocence have always been ignored. Then one day in the visiting area, she sees a recognizable stranger she’s certain is her husband. It turns out the man she’s been convicted of killing may not be dead after all. But as the days tick away toward Talia’s execution, what will it take for her to be believed?

*Freida McFadden’s Death Row is part of Alibis, a collection of stories about lies, truth, and deception. It’s just a matter of what you can get away with. They can be read or listened to in one sitting.*', 'Talia Kemper awaits execution on death row for murdering her husband, despite her claims of innocence and an alibi.', 2025, '1662532261', '9781662532269', 74, NULL, 104, 'https://covers.openlibrary.org/b/id/15103391-L.jpg', '/works/OL43696498W', NULL, '01/06/2025', 'English', NULL, 1, 0, 'death-row-freida-mcfadden', 1, 'openlibrary', NULL, 0, NULL, 'public', '2026-03-16 07:03:56', '2026-03-22 03:22:01');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('b5aceb2d-5357-4371-8700-0462c1cf0542', 'Ward D', '**All she has do is make it through the night shift...**

Ward D is the hospital''s mental health unit and as a medical student, Amy is required to gain experience on the floor. But little do her colleagues know it may force her to confront a past she''s fought hard to forget.

The night starts. The countdown begins. 

As the hours tick by, Amy grows increasingly convinced something terrible is happening within the ward''s tightly secured walls. When patients and staff start to vanish without a trace, it becomes clear that everyone on the unit is in grave danger. 

Amy never wanted to spend the night on Ward D. Now she might not make it out alive.', NULL, 2025, NULL, '9781464233005', 312, NULL, NULL, 'https://covers.openlibrary.org/b/id/15125127-L.jpg', '/works/OL42406707W', NULL, '2025', 'English', NULL, 1, 0, 'ward-d-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 07:03:57', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('154684dd-f2d9-4e00-8c76-168f566d0e27', 'The Locked Door', '**Some doors are locked for a reason…**

While eleven-year-old Nora Davis was up in her bedroom doing homework, she had no idea her father was killing women in the basement.

Until the day the police arrived at their front door.

Decades later, Nora’s father is spending his life behind bars, and Nora is a successful surgeon with a quiet, solitary existence. Nobody knows her father was a notorious serial killer. And she intends to keep it that way.

Then Nora discovers one of her young female patients has been murdered. In the same unique and horrific manner that her father used to kill his victims.', NULL, 2023, '1464221359', '9781464221354', 311, NULL, NULL, 'https://covers.openlibrary.org/b/id/13156268-L.jpg', '/works/OL28954802W', NULL, '2023', 'English', NULL, 1, 0, 'the-locked-door-freida-mcfadden', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 07:03:59', '2026-03-25 00:23:59');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d97e570c-988e-41fb-8474-f082b5e3396c', 'The Teacher', 'Lesson #1: **Trust no one**.

**Eve has a good life**. She wakes up each day, kisses her husband Nate, and heads off to teach math at the local high school. All is as it should be. Except…

Last year, Caseham High **was rocked by a scandal involving a student-teacher affair**, with one student, Addie, at its center. But Eve knows there is far more to these ugly rumors than meets the eye.

