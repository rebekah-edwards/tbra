  [1]: https://www.jkrowling.com/book/harry-potter-chamber-secrets/', 'Harry Potter returns to Hogwarts for his second year, plagued by warnings from a house-elf and mysterious attacks petrifying students.', 1998, '0320038491', '9780807286012', 339, NULL, 580, 'https://covers.openlibrary.org/b/id/15159946-L.jpg', '/works/OL82537W', NULL, '1999', 'English', NULL, 1, 0, 'harry-potter-and-the-chamber-of-secrets-j-k-rowling', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 02:59:31', '2026-03-22 20:32:05');
INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('82c96b55-7288-4033-a0a8-cdad99992862', 'Harry Potter and the Prisoner of Azkaban', 'For Harry Potter, it’s the start of another far-from-ordinary year at Hogwarts when the Knight Bus crashes through the darkness and comes to an abrupt halt in front of him.

It turns out that Sirius Black, mass-murderer and follower of Lord Voldemort, has escaped – and they say he is coming after Harry.

In his first Divination class, Professor Trelawney sees an omen of death in Harry’s tea leaves.

And perhaps most frightening of all are the Dementors patrolling the school grounds with their soul-sucking kiss – in search of fresh victims.

([source][1])


  [1]: https://www.jkrowling.com/book/harry-potter-prisoner-azkaban/', 'Harry Potter''s third year at Hogwarts brings new dangers as escaped convict Sirius Black hunts him, while soul-draining Dementors guard the school.', 1999, '1526606208', '9788989708698', 416, NULL, 790, 'https://covers.openlibrary.org/b/id/14646577-L.jpg', '/works/OL82536W', NULL, '2003', 'English', NULL, 1, 0, 'harry-potter-and-the-prisoner-of-azkaban-j-k-rowling', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 02:59:34', '2026-03-22 20:32:05');
