INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('9d7a3405-fdea-4643-aa20-5f2f8c47465b', 'The 48 Laws of Power', 'Amoral, cunning, ruthless, and instructive, this piercing work distills three thousand years of the history of power in to forty-eight well explicated laws. As attention--grabbing in its design as it is in its content, this bold volume outlines the laws of power in their unvarnished essence, synthesizing the philosophies of Machiavelli, Sun-tzu, Carl von Clausewitz, and other great thinkers. Some laws teach the need for prudence ("Law 1: Never Outshine the Master"), the virtue of stealth ("Law 3: Conceal Your Intentions"), and many demand the total absence of mercy ("Law 15: Crush Your Enemy Totally"), but like it or not, all have applications in real life. Illustrated through the tactics of Queen Elizabeth I, Henry Kissinger, P. T. Barnum, and other famous figures who have wielded--or been victimized by--power, these laws will fascinate any reader interested in gaining, observing, or defending against ultimate control.', 'Robert Greene compiles 48 timeless laws of power from historical and philosophical sources, offering cunning, often ruthless strategies for influence and control.', 1998, '0140280197', '9781101042458', 452, NULL, 593, 'https://covers.openlibrary.org/b/id/6424160-L.jpg', '/works/OL1968368W', NULL, '2009', 'English', NULL, 0, 0, 'the-48-laws-of-power-robert-greene', 0, NULL, NULL, 0, NULL, 'public', '2026-03-16 07:14:02', '2026-03-22 20:32:05');
