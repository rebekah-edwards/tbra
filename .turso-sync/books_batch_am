INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('1242a5d6-ebba-4484-9065-771ca13e6fee', 'Emily Wilde''s Compendium of Lost Tales', 'Emily Wilde has spent her life studying faeries. A renowned dryadologist, she has documented hundreds of species of Folk in her Encyclopaedia of Faeries. Now she is about to embark on her most dangerous academic project yet: studying the inner workings of a faerie realm—as its queen.

Along with her former academic rival—now fiancé—the dashing and mercurial Wendell Bambleby, Emily is immediately thrust into the deadly intrigues of Faerie as the two of them seize the throne of Wendell’s long-lost kingdom, which Emily finds a beautiful nightmare filled with scholarly treasures.

Emily has been obsessed with faerie stories her entire life, but at first she feels as ill-suited to Faerie as she did to the mortal world: How can an unassuming scholar such as herself pass for a queen? Yet there is little time to settle in, for Wendell’s murderous stepmother has placed a deadly curse upon the land before vanishing without a trace. It will take all of Wendell’s magic—and Emily’s knowledge of stories—to unravel the mystery before they lose everything they hold dear.', 'Scholar Emily Wilde ascends to queenship in a cursed faerie realm alongside her fiancé, the exiled prince Wendell, unraveling deadly mysteries through folklore and magic.', 2025, '0356519228', '9780356519197', 368, NULL, 704, 'https://covers.openlibrary.org/b/id/14845206-L.jpg', '/works/OL42408823W', NULL, '2025', 'English', NULL, 1, 1, 'emily-wildes-compendium-of-lost-tales-heather-m-fawcett', 0, NULL, NULL, 0, NULL, 'import_only', '2026-03-16 14:47:38', '2026-03-25 00:23:59');
