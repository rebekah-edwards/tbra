INSERT INTO books (id, title, description, summary, publication_year, isbn_10, isbn_13, pages, words, audio_length_minutes, cover_image_url, open_library_key, asin, publication_date, language, publisher, is_fiction, is_box_set, slug, cover_verified, cover_source, series_cover_url, needs_review, review_reason, visibility, created_at, updated_at) VALUES ('d554c021-7953-434f-94c1-9d24e70a4423', 'Alex Stern Series 2-Book Set', 'Galaxy "Alex" Stern is the most unlikely member of Yale''s freshman class. Raised in the Los Angeles hinterlands by a hippie mom, Alex dropped out of school early and into a world of shady drug-dealer boyfriends, dead-end jobs, and much, much worse. In fact, by age twenty, she is the sole survivor of a horrific, unsolved multiple homicide. Some might say she''s thrown her life away. But at her hospital bed, Alex is offered a second chance: to attend one of the world''s most prestigious universities on a full ride. What''s the catch, and why her?

Still searching for answers, Alex arrives in New Haven tasked by her mysterious benefactors with monitoring the activities of Yale''s secret societies. Their eight windowless "tombs" are the well-known haunts of the rich and powerful, from high-ranking politicos to Wall Street''s biggest players. But their occult activities are more sinister and more extraordinary than any paranoid imagination might conceive. They tamper with forbidden magic. They raise the dead. And, sometimes, they prey on the living.

Don''t miss the highly-anticipated sequel, ***Hell Bent***.

Find a gateway to the underworld. Steal a soul out of hell. A simple plan, except people who make this particular journey rarely come back. But Galaxy "Alex" Stern is determined to break Darlington out of purgatory--even if it costs her a future at Lethe and at Yale.

Forbidden from attempting a rescue, Alex and Dawes can''t call on the Ninth House for help, so they assemble a team of dubious allies to save the gentleman of Lethe. Together, they will have to navigate a maze of arcane texts and bizarre artifacts to uncover the societies'' most closely guarded secrets, and break every rule doing it. But when faculty members begin to die off, Alex knows these aren''t just accidents. Something deadly is at work in New Haven, and if she is going to survive, she''ll have to reckon with the monsters of her past and a darkness built into the university''s very walls.

Thick', 'Alex Stern, a survivor with the rare ability to see ghosts, joins Yale to oversee its secret societies practicing dangerous magic.', 2023, '1637990693', '9781637990698', 981, NULL, NULL, 'https://covers.openlibrary.org/b/id/15157284-L.jpg', '/works/OL36854808W', NULL, '2023', 'English', NULL, 1, 1, 'alex-stern-series-2book-set-leigh-bardugo', 0, 'openlibrary', NULL, 0, NULL, 'import_only', '2026-03-16 14:52:47', '2026-03-25 00:23:59');
